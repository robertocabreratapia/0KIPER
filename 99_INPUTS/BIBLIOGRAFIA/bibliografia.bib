@article{Dougherty.Heckelman_2008,
  title = {Voting on Slavery at the {{Constitutional Convention}}},
  author = {Dougherty, Keith L. and Heckelman, Jac C.},
  year = 2008,
  month = sep,
  journal = {Public Choice},
  volume = {136},
  number = {3-4},
  pages = {293},
  issn = {0048-5829, 1573-7101},
  doi = {10.1007/s11127-008-9297-7},
  urldate = {2022-08-09},
  abstract = {Este art\'iculo presenta el primer an\'alisis emp\'irico del comportamiento de voto de los delegados en la Convenci\'on Constitucional de Estados Unidos en relaci\'on con la esclavitud. El estudio se centra en dos tipos de decisiones clave: aquellas relativas a la asignaci\'on de representaci\'on pol\'itica y aquellas vinculadas a la regulaci\'on del comercio de esclavos. Metodol\'ogicamente, los autores reconstruyen las posiciones individuales de los delegados a partir de fuentes hist\'oricas, dado que los registros oficiales solo consignan votos por delegaci\'on estatal. Sobre esta base, estiman modelos que eval\'uan el efecto de distintos factores explicativos, entre ellos los intereses del estado, los intereses personales, las predisposiciones morales o ideol\'ogicas y la posici\'on socioecon\'omica. Los resultados muestran que los intereses estatales influyen de manera significativa en los votos sobre la regulaci\'on del comercio de esclavos, aunque este efecto var\'ia seg\'un la regi\'on. En cambio, en las votaciones sobre representaci\'on, los comportamientos se explican tambi\'en por factores individuales, como los intereses personales y las creencias morales. Asimismo, se encuentra evidencia de que consideraciones vinculadas a decisiones de carrera, como la posibilidad de acceder a cargos futuros, condicionan ciertas posiciones de los delegados. El art\'iculo concluye que el comportamiento de los delegados no puede explicarse exclusivamente por intereses colectivos estatales. En su lugar, propone una interpretaci\'on que combina factores estructurales e individuales, lo que permite una comprensi\'on m\'as matizada de las decisiones adoptadas en torno a la esclavitud durante el proceso constitucional.},
  langid = {english},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: designado,0Cargo: Constituyente,0Division funcional: constituyente,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la ambicion politica en el voto sobre la esclavitud (regulacion del comercio y voto proporcional) en la convencion constituyente de Estados Unidos,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: Constituyentes,2Poblacion: Constituyentes,Ambition theory,ambition theory,Base documental: SI,Cargo: Constituyente,Constitutional Convention,Constituyentes fueron designados por las legislaturas de los estados,slavery,Slavery,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
