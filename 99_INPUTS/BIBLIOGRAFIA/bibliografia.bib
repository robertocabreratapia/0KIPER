  annotation = {7 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NRKLNIPY/Allen y Cutts - 2017 - Aspirant candidate behaviour and progressive polit.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/XPA37GZC/supplementary_material.pdf}
