@article{Cordero.etal_2021,
  type = {Article; Early Access},
  title = {Higher Means Harder for Female Descriptive Representation? {{Women}} with Family Responsibilities and Party Primaries for Local, Regional and National Chambers in Spain},
  author = {Cordero, Guillermo and Perez, Santiago and Parades, Marta and Coller, Xavier},
  year = 2021,
  journal = {South European Society and Politics},
  volume = {26},
  number = {4},
  pages = {517--540},
  doi = {10.1080/13608746.2022.2105417},
  abstract = {Despite academic interest in the negative effects of primaries on gender descriptive representation, we have little evidence on how this impact varies across territorial levels, especially among women with family responsibilities. We focus on Spain as a multilevel polity (national, regional, local chambers) with mandatory quotas to show that very few females with family responsibilities are selected in primaries at upper territorial levels. While primaries frequently facilitate women becoming local councillors, this method seems to exclude those with family responsibilities at regional and national levels where, to fulfil gender quotas, female candidates are more commonly appointed by the party elite. This process has repercussions since representatives selected by the leadership tend to be more disciplined and homogeneous than those selected in primaries.},
  affiliation = {Cordero, G (Corresponding Author), Univ Autonoma Madrid UAM, Polit Sci \& Int Relat Dept, Madrid, Spain. Cordero, Guillermo; Perez-Nievas, Santiago, Univ Autonoma Madrid UAM, Polit Sci \& Int Relat Dept, Madrid, Spain. Cordero, Guillermo, Univ Essex, Colchester, Essex, England. Cordero, Guillermo, Univ Michigan, Ann Arbor, MI 48109 USA. Cordero, Guillermo, Univ Montreal, Montreal, PQ, Canada. Cordero, Guillermo; Parades, Marta, Univ Mannheim, Mannheim, Germany. Cordero, Guillermo; Coller, Xavier, Univ Calif Berkeley, Berkeley, CA 94720 USA. Parades, Marta, Univ Pontificia Comillas, Madrid, Spain. Parades, Marta, Univ Carlos III Madrid, Getafe, Spain. Parades, Marta, Univ Autonoma Madrid, Madrid, Spain. Parades, Marta, European Univ Inst Florence, Fiesole, Italy. Coller, Xavier, Univ Nacl Educ Distancia, Polit Sci, Madrid, Spain. Coller, Xavier, Univ Warwick, Coventry, W Midlands, England. Coller, Xavier, Univ Montpellier I, Montpellier, France. Coller, Xavier, LUISS, Rome, Italy.},
  author-email = {guillermo.cordero@uam.es},
  da = {2022-09-27},
  earlyaccessdate = {SEP 2022},
  times-cited = {0},
  unique-id = {WOS:000853513200001},
  keywords = {03Continente: Europa,04Pais: Espana,2022-WoS,2024-WoS,Base documental: NO,candidate selection,councillors,decentralisation,gender quotas,members of parliament,party elite,political recruitment,Primarias,Teoria de la Ambicion Politica,Women in politics,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
