@article{Haraldsson_2021,
  type = {Article; {{Early Access}}},
  title = {Media Discrimination and Gender Differences in Political Ambition in a Laboratory Experiment},
  author = {Haraldsson, Amanda},
  year = 2021,
  month = oct,
  journal = {Political Research Quarterly},
  pages = {106591292110468},
  issn = {10659129},
  doi = {10.1177/10659129211046890},
  abstract = {Very little research has considered how media discrimination could impact men and women's political ambition. Yet, media discrimination could impact both beliefs about gender roles and political competence, and beliefs about voter bias, both of which could decrease women's political ambition and increase men's. Alternatively, media discrimination could lead women to react against discrimination and be motivated politically. This study tests how political ambition of men and women is impacted by media discrimination in a campaign and election lab experiment. Media discrimination in this experiment under-reports on women and uses traditional, stereotypical depictions of men and women. The results suggest that in certain conditions, media discrimination in political news may lead to a reactance or positive challenge effect for women, increasing their political ambition. Men, instead, may feel an aversion to entering politics, lowering their political ambition.},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: expresada,00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03Continente: Europa,04Pais: Italia,1Concepto evaluado: cobertura medios de comunicacion,1Diseno experimental: 2x3 factorial,1Diseno experimental: control grupos aleatoriedad,1Empirico: experimental,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Tipo de experimento: laboratorio/online,1Tratamiento: (1) prominencia del genero (propio y de los otros /conocido y no conocido) (2) exposicion mediatica (discriminatorio contradisciminatorio y neutral),2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Participantes: estudiantes universitarios,2Participantes: residentes Italia,2Participantes: Universidad de Bolonia,2Plataforma experimental: oTree,2Poblacion: >18 anos,Base documental: NO,Brecha de genero,Experimento,gender difference,laboratory experiment,media discrimination,political ambition,reactance effect,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/CNV7PR8G/Haraldsson - 2021 - Media discrimination and gender differences in pol.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/ESHSKGWL/Haraldsson_2022_Media Discrimination and Gender Differences in Political Ambition in a.pdf}
}

@article{Harmi.etal_2022,
  title = {How {{Great Is}} the {{Level}} of {{Youth Cultural Sensitivity}}? {{A Multicultural Education}} from {{One Ethnic}} in {{Indonesia}}},
  author = {Harmi, H. and Ramdhani, M.I. and Amalia, S. and Apriani, E. and Syafryadin, S. and Supardan, D. and Zarin, I.},
  year = 2022,
  journal = {Education Research International},
  volume = {2022},
  publisher = {Hindawi Limited},
  issn = {20904002 (ISSN)},
  doi = {10.1155/2022/7983961},
  abstract = {Indonesia is a multiethnic and cosmopolitan country. To realize a multicultural society, the variety of the Indonesian nation is employed as a feature, as the Indonesian nation's identity. Different cultures complement each other, do not stand alone, and are even capable of adapting (flexibly) to each other in the arena of daily life. Musi Rawas Utara is one of the regencies in South Sumatra Province, Indonesia, with a diversified community in terms of religion and race. Cultural, religious, political ambitions, economic divisions, and educational distinctions are among the most widely felt throughout Indonesia, particularly in the Musi Rawas region. The goal of this study was to look at the intercultural understanding of ethnic youngsters in the Musi Rawas area. The demographics of this study include all youth ethnic groups in the Musi Rawas area. A purposive sample was used, with 75 participants drawn from three villages in Musi Rawas Utara Regency, South Sumatra. A nontest strategy was used to collect data in the form of a questionnaire. The research tool employed in this study was a questionnaire with four response options: strongly agree, agree, disagree, and strongly disagree. In this sense, it may be argued that the youth ethnic groups, Orang Rimba, in Musi Rawas Utara, have a good understanding of multiculturalism.  \copyright{} 2022 Hendra Harmi et al.},
  langid = {american},
  keywords = {2024 STATUS: Pendiente de procesar,2024-Scopus,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/5N3Z3XP2/Harmi et al_2022_How Great Is the Level of Youth Cultural Sensitivity.pdf}
}

@incollection{Hasselberg.etal_2013,
  title = {Conclusion: {{On}} the Verge of Breakdown},
  booktitle = {Higher {{Education Dynamics}}},
  author = {Hasselberg, Y. and Rider, S. and Waluszewski, A.},
  year = 2013,
  volume = {39},
  pages = {201--214},
  abstract = {The unifying theme of the contributions to this volume is a perceived transfiguration in higher education and research, which the authors and editors of this volume believe is related to markets and marketisation. The transformation of the global economy into an amorphous network transgressing national borders is the prime mover in the present reorganisation of `knowledge production', which has the effect of undermining the legitimacy of the university as an essential component in the project of modernity. Whether or not the modern research university ever actually lived up to the aim of the disinterested and universal quest for knowledge for the common good without regard to partisan interests or political ambitions, this role was part and parcel of its self-understanding and its mission and as such was a cornerstone of its activities. On the one hand, the loss of that self-understanding can be seen as a loss of innocence, which we are better off without. The realisation that the university is no more unfettered than the rest of society can thus be regarded as a new realism and thus as inevitable if not beneficial. On the other hand, if the ideal of value-free (or at least value-neutral) science is disavowed in favour of the norm of science on demand, what will the consequences be? The choice seems to stand between research and teaching faculty actively arguing and fighting for the right to be non-partisan and universalist, in practice enacting the ideal of the democratic university, or we have to hope and trust that some contingent of individual scientists and teachers will continue to exercise scientific judgement and that these will constitute a large enough community to make a difference. \copyright{} 2013, Springer Science+Business Media Dordrecht.},
  affiliation = {Department of Economic history, Uppsala University, Kyrkog\aa rdsg 10, Uppsala, S-751 20, Sweden; Department of Philosophy, Uppsala University, Thunbergsv\"ag 3 H, Uppsala, 751 26, Sweden; Department of Economic History, Centre for Science and Technology Studies, Uppsala University, Ekonomikum, Kyrkog\aa rdsgatan 10, Uppsala, Sweden},
  author_keywords = {Economic Landscape; Global Economy; High Education; Political Ambition; Scientific Judgement},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Economic Landscape,Global Economy,High Education,Political Ambition,Scientific Judgement,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Hassell_2020,
  type = {Article},
  title = {It's Who's on the inside That Counts: Campaign Practitioner Personality and Campaign Electoral Integrity},
  author = {Hassell, Hans J.G.},
  year = 2020,
  month = dec,
  journal = {Political Behavior},
  volume = {42},
  number = {4},
  pages = {1119--1142},
  issn = {15736687},
  doi = {10.1007/s11109-019-09535-y},
  abstract = {Candidates for public office (and the individuals who run their campaigns) are not a randomly selected subset of the general population. Individuals with certain personality traits are more likely to become involved in political campaigns, are more likely to harbor political ambition, are more likely to be recruited to run for public office, and are more likely to actually run for office. But what influence do differences in individual traits have on the behavior of political campaigns? Using a unique survey of staff and candidates working on congressional, senatorial, and gubernatorial campaigns in the 2016 election cycle, this research shows that individual personality traits influence the decisions that campaigns make during the election. Personality traits affect the acceptance of campaign negativity and unethical campaign behaviors.},
  keywords = {2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,Campaign negativity,Campaign tactics,Campanas electorales,Ethical behavior,Personality,Political campaigns,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/3Q4ZQ2UD/Hassell - 2020.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/4JWUJTIU/11109_2019_9535_MOESM1_ESM.docx}
}

@article{Hassell.etal_2025,
  title = {Seeking the {{Public Good}}: {{Public Service Motivation}} and {{Political Ambition}}},
  author = {Hassell, H.J.G. and Hollibaugh, G.E. and Miles, M.R.},
  year = 2025,
  journal = {Political Behavior},
  volume = {47},
  number = {3},
  pages = {1087--1111},
  publisher = {Springer},
  issn = {15736687 (ISSN); 01909320 (ISSN)},
  doi = {10.1007/s11109-024-09981-3},
  abstract = {Many previous studies have shown that public service motivation (PSM) is associated with public sector employment. However, with few exceptions, such studies have focused on unelected positions in public sector bureaucracies, despite many other avenues for public service. Using a nationally representative survey of United States respondents, a survey of federal bureaucrats, and a survey of law students, we show that PSM is associated with ambition for holding elected office, high-level public sector positions, and judicial positions, at least in the United States. Moreover, the results are broadly comparable across different types of ambition (i.e., bureaucratic, electoral, and judicial), suggesting that the PSM dimensions---and especially Attraction to Policy Making (APM)---transcend institutions in explaining individuals' interest in service in public sector offices of all types. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
