@article{Millett_2001,
  title = {Short-Term Policies, Long-Term Consequences: {{US}} Relations with {{Nicaragua}}'s {{Armed Forces}}},
  author = {Millett, R.},
  year = 2001,
  journal = {Low Intensity Conflict and Law Enforcement},
  volume = {10},
  number = {3},
  pages = {117--142},
  abstract = {During the first third of the twentieth century the United States created or completely reformed the military and police in five nations of the Caribbean Basin: Cuba, Dominican Republic, Haiti, Nicaragua and Panama. In each case military and police functions were combined into a single force (in Panama there were no real military functions). The theory was that this would contribute to political stability, reduce corruption, and promote internal order. The creation of the Nicaraguan Guardia Nacional was the last of these efforts. Existing forces, loyal to rival political factions, were disarmed, and a new force created, both commanded and trained by US Marines. The force was better trained and equipped, and more mobile than any previous Nicaraguan force. But the US command inhibited the development of a national officer corps, an ongoing struggle with an insurgent force hampered training, and adequate resources were threatened by the onset of the Depression. Following the Marine's withdrawal the Guardia rapidly became an instrument of the political ambitions of General Anastasio Somoza and for the next 45 years served to maintain the Somozas in power Many Marine officers and at least one US ambassador saw the flaws in US policy, but were never able to effectively communicate their concerns to Washington.},
  affiliation = {Southern Illinois University, PRS Group, Edwardsville, IL, United States},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Central America,corruption,foreign policy,national security,Nicaragua,North America,police force,Relaciones Internacionales,United States,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Mimica.etal_2024,
  title = {Party {{Affiliation}}, {{District-Level Incentives}} and the {{Use}} of {{Parliamentary Questions}} in {{Chile}}'s {{Presidential Democracy}}},
  author = {Mimica, Nicol{\'a}s and Navia, Patricio and C{\'a}rcamo, Ignacio},
