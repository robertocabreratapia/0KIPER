@article{Thompson.etal_1996,
  title = {We've {{Lost That Family Feeling}}: {{The Changing Norms}} of the {{New Breed}} of {{State Legislators}}},
  shorttitle = {We've {{Lost That Family Feeling}}},
  author = {Thompson, Joel A. and Kurtz, Karl and Moncrief, Gary F.},
  year = 1996,
  journal = {Social Science Quarterly},
  volume = {77},
  number = {2},
  eprint = {42863471},
  eprinttype = {jstor},
  pages = {344--362},
  publisher = {[University of Texas Press, Wiley]},
  issn = {0038-4941},
  urldate = {2022-08-09},
  abstract = {Objective. State legislatures have undergone substantial change in the past three decades. Institutional and individual changes have been driven by attempts to accommodate the legislative agendas and political ambitions of the "new breed" of state legislator. Given these changes, one may hypothesize that there have been corresponding changes in the "informal" rules of legislative life---legislative norms---which define acceptable legislative behavior. Methods. The authors conducted a survey of all state legislators who had served for 15 years or longer. Of the 747 legislators in the target population, 330 responded (44 percent). All states were represented. The median years served among respondents was 21. Results. The results indicate that longtime legislators perceive substantial changes have occurred during their tenures in many aspects of legislative life. These changes are most pronounced in behavior toward the institution and, to a lesser extent, group-related norms. There is little perceived change in interpersonal norms. Finally, there is strong evidence that perceived change in norms is related to the degree of legislative professionalism. Conclusions. The findings are consistent with theoretical expectations. As legislatures adapted, first in response to external societal pressures and then in response to internal stresses, legislative norms and behaviors were modified to accommodate changing member expectations and ambitions.},
  keywords = {03Continente: America,04Pais: EEUU,0Division territorial: subnacional,1NoExperimental_Tecnicas: encuesta,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,Comportamiento legislativo,Normas de comportamiento aceptable,Normas informales,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/38AM8H9S/Thompson et al. - 1996 - We've Lost That Family Feeling The Changing Norms.pdf}
}

@article{Thorneycroft_2024,
  title = {Crip {{Theory}} and the {{Subject}} of {{Abledness}}},
  author = {Thorneycroft, R.},
  year = 2024,
  journal = {Scandinavian Journal of Disability Research},
  volume = {26},
  number = {1},
  pages = {95--109},
  publisher = {Stockholm University Press},
  issn = {17453011 (ISSN); 15017419 (ISSN)},
  doi = {10.16993/sjdr.1067},
  abstract = {Building on the productive and transgressive aspects of crip theory, this article seeks to proliferate (and not appropriate) its insights, and particularly, with the abled (or nondisabled) subject in mind. My contribution is based on a contemplation of how crip theory can speak for or include the abled subject, particularly with the aim that abled subjects can embody and/or elaborate crip politics to build a more crip world. Crip worlds reject ableism and compulsory abledness and foreground the importance of interdependencies, accessible futures, and generative understandings of disability, and I am interested in imagining a space in which abled subjects can learn from and embody crip politics. The political ambition of this article is concerned with contemplating what kind of reckoning might unfold through an engagement between abled subjectivity and crip theory, and while this political association comes with risks, it also comes with possibilities that help to re/write the dis/abled body, proliferate anti-ableist politics, and imagine cripper worlds. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {american},
  keywords = {abledness,ableism,Article,crip identification,crip theory,disability,disability studies,education,emotionality,employment,epistemology,homosexual female,housing,human,masculinity,queer theory,systematic review,theory,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/XD5IA6A5/Thorneycroft - 2024 - Crip Theory and the Subject of Abledness.pdf}
}

@article{Thorneycroft.Smilges_2022,
  title = {Choosing Disability: Bug Chasing and Gift Giving in Gay Pornography},
  author = {Thorneycroft, R. and Smilges, J.L.},
  year = 2022,
  journal = {Porn Studies},
  doi = {10.1080/23268743.2022.2066567},
  abstract = {Starting with the premise that pornography is dominated by abled (or non-disabled) porn performers, this speculative article considers the extent to which logics and figurations of disability pervade the genre of gay porn, particularly the film Viral Loads. Produced by Treasure Island Media, Viral Loads eroticizes the deliberate transmission of HIV (popularly known as bug chasing and gift giving), and, as such, powerfully conveys the permeability of abledness/disabledness. If HIV can be coded as a disability, and if bug chasing and gift giving constitute agentic sexual practices, then we speculate about the ways in which disability can be a source of sexual agency in these types of films. Central to this discussion is fantasy, as many of the performers involved are already HIV-positive or unlikely to receive the gift in the context of pre-exposure prophylaxis and treatment as prevention. The political ambition for our article is imagining spaces in which the choosing and un-choosing of disability can be de-pathologized and bringing HIV discourses and practices to bear upon Disability Studies, particularly given the disavowals that historically and contemporarily occur across and between HIV and disability discourses. \copyright{} 2022 Informa UK Limited, trading as Taylor \& Francis Group.},
  affiliation = {School of Social Sciences, Western Sydney University, Penrith, NSW, Australia; Department of English Language and Literatures, Texas Woman's University, Denton, TX, United States; They are now at the University, of British Columbia, Vancouver, BC, Canada},
  author_keywords = {ableism; bug chasing; crip theory; gay pornography; gift giving; HIV transmission},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,ableism,Base documental: NO,bug chasing,crip theory,gay pornography,gift giving,HIV transmission,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/7FSR3E5R/Thorneycroft y Smilges - 2022 - Choosing disability bug chasing and gift giving in gay pornography.pdf}
}

@article{Topak_2013,
  title = {Governing Turkey's Information Society},
  author = {Topak, {\"O}.E.},
  year = 2013,
  journal = {Current Sociology},
  volume = {61},
  number = {5-6},
  pages = {565--583},
  doi = {10.1177/0011392113486633},
  abstract = {This article analyses the information society developments in Turkey. Utilizing analytical insights of Foucault's governmentality to move beyond state-centric approaches and to focus on the practical, productive and imperfect operations of power, it identifies four main actors of governance through which the rationalities and practices of information society are developed and disseminated: the Justice and Development Party, the European Union, global development organizations and information society experts. The article demonstrates that despite their different and sometimes competing backgrounds and projections, each actor promoted neoliberal governmentality and maintained that Turkey's information society strategy should be regarded as an opportunity for further liberalizing the economy and mobilizing citizens of Turkey with digital and entrepreneurial skills. While Turkey's information society strategy has certain technical inefficiencies and limitations in its reach, it clearly demonstrates the political ambitions of integrating Turkey into global capitalism, and the contemporary governmental phase in Turkish modernity in which local and global actors have started playing important roles. Such decentralization of governance does not mean that authoritarianism in Turkey has ended. In fact, neoliberal rationalities have intersected with the existing authoritarian ones to produce globalized yet compliant citizens who are under digital surveillance. The case of Turkey demonstrates that rather than being a linear process, governmentality advances through complex local and global articulations and may coexist with authoritarianism and surveillance. \copyright{} The Author(s) 2013.},
  affiliation = {Queen's University, Canada},
  author_keywords = {Authoritarianism; governmentality; information society; neoliberalism; Turkey},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Authoritarianism,Base documental: NO,governmentality,information society,neoliberalism,Turkey,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/2TGFYSKC/Topak - 2013 - Governing turkey's information society.pdf}
}

@article{Toro.Valenzuela_2018,
  title = {Chile 2017: Ambiciones, Estrategias y Expectativas En El Estreno de Las Nuevas Reglas Electorales},
  shorttitle = {Chile 2017},
  author = {Toro, Sergio and Valenzuela, Macarena},
  year = 2018,
  month = aug,
  journal = {Revista de Ciencia Pol\'itica},
  volume = {38},
  number = {2},
  pages = {207--232},
  issn = {0718-090X},
  doi = {10.4067/s0718-090x2018000200207},
  urldate = {2022-08-09},
  abstract = {Abstract Este art\'iculo analiza el proceso pol\'itico chileno durante 2017, con especial atenci\'on al impacto de la reforma electoral que reemplaz\'o el sistema binominal por uno proporcional con distritos de magnitud variable. El argumento central sostiene que este cambio institucional gener\'o tres efectos principales en los actores pol\'iticos: transformaci\'on de las ambiciones, adaptaci\'on de las estrategias de campa\~na y modificaci\'on de las expectativas de participaci\'on pol\'itica. El estudio combina un an\'alisis descriptivo del contexto pol\'itico, econ\'omico e institucional con una evaluaci\'on del comportamiento de partidos y candidatos en el ciclo electoral. Se examinan eventos coyunturales relevantes, como los incendios forestales y las crisis institucionales, as\'i como el funcionamiento de los poderes Ejecutivo y Legislativo en un a\~no marcado por tensiones pol\'iticas y reconfiguraci\'on del sistema de partidos. En el plano electoral, los resultados muestran que la reforma introdujo incertidumbre que llev\'o a los incumbentes a diversificar sus decisiones de carrera, incluyendo mayores niveles de retiro, competencia por cargos superiores y menor tasa de reelecci\'on. Asimismo, las campa\~nas se adaptaron a distritos m\'as amplios mediante estrategias de segmentaci\'on territorial, mientras que las nuevas reglas ampliaron las oportunidades para actores previamente excluidos, como nuevos partidos y candidaturas femeninas. El art\'iculo concluye que el nuevo sistema electoral alter\'o de manera significativa la din\'amica pol\'itico-electoral en Chile, aunque sus efectos a\'un requieren evaluaci\'on de largo plazo. En particular, plantea interrogantes sobre la persistencia de pr\'acticas como el personalismo, el peso del trabajo territorial y la forma en que los actores se adaptar\'an a las nuevas reglas institucionales.},
  langid = {english},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: discreta,00Ambicion Politica: estatica,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,00Causas: efecto del contexto institucional,01Diseno investigacion: no experimental,01Tipo de estudio: descriptivo,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,04Pais_sigla: CHI,04Pais: Chile,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: unitario,1Concepto evaluado: efecto de la ambicion politica en la estrategia electoral ante la introduccion de limites a la reeleccion,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en la unidad,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unidad de analisis: individuo,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: miembros de la Camara Baja,2Poblacion: miembros de la Camara Baja,Base documental: SI,Chile,Electoral reform,Estrategia electoral,Limites a la reeleccion,Police corruption,TEST-BORRAR,Wildfires,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {4 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NDWAGUZE/Toro Maureira y Valenzuela Beltrán - 2018 - Chile 2017 ambiciones, estrategias y expectativas.pdf}
}

