@book{Faulkner_2008,
  title = {The Case for Greatness: {{Honorable}} Ambition and Its Critics},
  author = {Faulkner, R.K.},
  year = 2008,
  pages = {1--264},
  abstract = {The Case for Greatness is a spirited look at political ambition, good and bad, with particular attention to honorable ambition. Robert Faulkner contends that too many modern accounts of leadership slight such things as determination to excel, good judgment, justice, and a sense of honor-the very qualities that distinguish the truly great. And here he offers an attempt to recover "a reasonable understanding of excellence," that which distinguishes a Franklin D. Roosevelt and a Lincoln from lesser leaders. Faulkner finds the most telling diagnoses in antiquity and examines closely Aristotle's great-souled man, two accounts of the spectacular and dubious Athenian politician Alcibiades, and the life of the imperial conqueror Cyrus the Great. There results a complex and compelling picture of greatness and its problems. Faulkner dissects military and imperial ambition, the art of leadership, and, in the later example of George Washington, ambition in the service of popular self-government. He also addresses modern indictments of even the best forms of political greatness, whether in the critical thinking of Hobbes, the idealism of Kant, the relativism and brutalism of Nietzsche, or the egalitarianism of Rawls and Arendt. He shows how modern philosophy came to doubt and indeed disdain even the best forms of ambition. This book is a nuanced defense of admirable ambition and the honor-seeking life, as well as an irresistible invitation to apply these terms to our own times and leaders. \copyright{} 2007 by Yale University. All rights reserved.},
  affiliation = {Boston College, United States},
  document_type = {Book},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Filosofia,Filosofia y Clasicos,No prioritario,Teoria de la Ambicion Politica,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/SE9AXC3T/Faulkner_2008_The case for greatness.pdf}
}

@article{Fejes_2008,
  title = {To Be One's Own Confessor: {{Educational}} Guidance and Governmentality},
  author = {Fejes, A.},
  year = 2008,
  journal = {British Journal of Sociology of Education},
  volume = {29},
  number = {6},
  pages = {653--664},
  doi = {10.1080/01425690802423320},
  abstract = {Educational guidance is often seen as something good and empowering for the individual. In the present article, such taken-for-granted ideas will be destabilised by analysing educational guidance as a practice in which confession operates as a technology that fosters and governs specific subjectivities. White papers produced by the Swedish Ministry of Education will be analysed drawing on Foucault's concepts of technologies of the self and governmentality. I shall argue that the practice of educational guidance fosters our will to learn through the technology of confession. We are not only confessing ourselves to, and are the confessors of others, we are also our own confessors; that is, we confess our inner desires to ourselves, thus participating in shaping desirable subjectivities. Our desires in life coincide with the political ambition to govern, and thus we govern ourselves.},
  affiliation = {Department of Behavioural Sciences and Learning, Linkoping University, Linkoping, Sweden},
  author_keywords = {Confession; Educational guidance; Governmentality; Technologies of the self},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Confession,Educational guidance,Governmentality,Technologies of the self,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/WGTDY64B/Fejes_2008_To be one's own confessor.pdf}
}

