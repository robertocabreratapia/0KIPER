@incollection{Lopez_2016,
  title = {Manuel {{Fraga Iribarne}}},
  booktitle = {Political {{Leadership}} in the {{Spanish Transition}} to {{Democracy}} (1975-1982)},
  author = {L{\'o}pez, L.},
  year = 2016,
  pages = {93--112},
  abstract = {Manuel Fraga represents a type of singular leadership within the context of the Spanish Transition. His biography is characterized by a dense intellectual education, vast and diverse experience in the public service, and an intense working ability. The aforementioned capacities are combined with a clear political ambition and his involvement in the public sphere. Why did Fraga obtain only a limited success in the Transition in spite of his large theoretical and practical knowledge of politics, society and of the role of public opinion? His actions were profuse and visible in a context of great uncertainty and competition among political elites. Fraga was not able to counteract the predominance of his political adversaries' discourse who excluded him for being reformist, ambitious and independent during the Francoism and identified him with the authoritarian regime during the Transition, in the context of antagonistic political culture of limited democratic quality, in spite of the establishment of consensual practices. When and how did his leadership become fruitful? The essential features of his biography confirm a limited short-term success. Some of the diagnosis, reforms and projects of political action supported by him before and during the Transition, became real only a posteriori. Among them, the political union of the Spanish center-right, fragmented after two centuries of constitutional history; and the prevention of emerging far-right political parties. Fraga had foreseen this problem and planned and became leader of the setting up of People's Alliance (Alianza Popular - AP), fourth national political force during the two first democratic elections and second political party during the bipartisan period after 1982. Eventually, he would play a decisive role in the re-launching of AP as People's Party (Partido Popular - PP) in 1989, which has remained since then either an opposition or governing party, with J.M. Aznar and later on with M. Rajoy. His involvement in the drafting of the Constitution was another of his relevant shortterm contributions. Fraga got personally involved and managed to introduce some of his initiatives in the constitutional text. In the long term, Fraga diagnosed problems and suggested alternative solutions to be included in the constitutional text, such as those regarding the role of the Senate and the solution of the historical center-periphery conflict (cleavage), which he understood would not serve to solve the problem, as it became patent afterwards. \copyright{} 2016 Nova Science Publishers, Inc.},
  affiliation = {Universidad Nacional de Educaci\'on a Distancia (UNED), Madrid, Spain},
  author_keywords = {Center-right; Francoism; Leadership; Manuel Fraga; Transition},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Center-right,Francoism,Leadership,Liders y liderazgo,Manuel Fraga,Transition,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

