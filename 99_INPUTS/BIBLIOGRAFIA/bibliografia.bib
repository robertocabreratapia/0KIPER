@article{Prewitt.Nowlin_1969,
  title = {Political {{Ambitions}} and the {{Behavior}} of {{Incumbent Politicians}}},
  author = {Prewitt, Kenneth and Nowlin, William},
  year = 1969,
  month = jun,
  journal = {The Western Political Quarterly},
  volume = {22},
  number = {2},
  eprint = {446999},
  eprinttype = {jstor},
  pages = {298},
  issn = {00434078},
  doi = {10.2307/446999},
  urldate = {2022-08-09},
  abstract = {Abstract Este art\'iculo examina la relaci\'on entre ambici\'on pol\'itica y comportamiento de los incumbentes, con el objetivo de identificar c\'omo las aspiraciones de carrera estructuran las decisiones y estrategias de los pol\'iticos en ejercicio. El estudio se sit\'ua en los desarrollos iniciales de la teor\'ia de la ambici\'on pol\'itica y busca establecer v\'inculos sistem\'aticos entre tipos de ambici\'on y patrones de conducta. El marco anal\'itico distingue entre diferentes orientaciones de ambici\'on, en l\'inea con la tipolog\'ia desarrollada posteriormente por Joseph A. Schlesinger, y plantea que estas orientaciones generan incentivos diferenciados que afectan la forma en que los incumbentes se relacionan con su cargo, sus electores y el sistema pol\'itico. A partir de evidencia emp\'irica sobre pol\'iticos en ejercicio, el an\'alisis muestra que las aspiraciones de carrera influyen en aspectos clave del comportamiento, como la orientaci\'on hacia el distrito, la visibilidad p\'ublica y la participaci\'on en actividades pol\'iticas. En particular, aquellos con ambici\'on progresiva tienden a adoptar estrategias orientadas a maximizar su proyecci\'on futura, mientras que quienes buscan la reelecci\'on priorizan la consolidaci\'on de su base electoral. El art\'iculo concluye que la ambici\'on pol\'itica constituye un determinante central del comportamiento de los incumbentes, proporcionando un marco explicativo que permite integrar motivaciones individuales y contextos institucionales. Este trabajo contribuye a sentar las bases de la literatura posterior sobre decisiones de carrera y comportamiento pol\'itico. Informaci\'on contrastada: objetivo, enfoque te\'orico, relaci\'on entre tipos de ambici\'on y co},
  keywords = {00Ambicion Politica: causa+efecto,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Consejero local,0Division funcional: legislativo,0Division territorial: local,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: relacion entre edad y ambicion politica y entre esta y la mirada del incumbente respecto a la relacion de poder local-estatal,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en la unidad,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individuo,2022-WoS,2024-WoS,2Muestra: Consejeros Locales de California Bahia de San Francisco,2Poblacion: Consejeros locales de la Bahia de San Francisco,Base documental: SI,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
