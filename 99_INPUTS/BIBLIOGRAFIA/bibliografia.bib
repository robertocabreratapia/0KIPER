@article{Marks.etal_2002,
  title = {What Do Subnational Offices Think They Are Doing in {{Brussels}}?},
  author = {Marks, G. and Haesly, R. and Mbaye, H.A.D.},
  year = 2002,
  journal = {Regional and Federal Studies},
  volume = {12},
  number = {3},
  pages = {1--23},
  doi = {10.1080/714004755},
  abstract = {This article describes and analyses the goals of subnational offices in the European Union. Our evidence is drawn from a 1999 survey conducted by the Center for European Studies at the University of North Carolina at Chapel Hill. To what extent do subnational offices seek to shape political decisions in the European Union? We find that larger and better funded offices are most likely to assert political pressure as a goal, as are offices representing regions that are entrenched in their respective national polities. We also find that offices representing associations of local governments aim for political influence in the EU. A simple structural equation model allows us to evaluate how type of office and office resources shape the political ambitions of subnational offices in Brussels.},
  affiliation = {Center for European Studies, University of North Carolina, Chapel Hill, United States},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,administration,Base documental: NO,Belgium,Brussels,Europe,European Union,political relations,regional politics,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
