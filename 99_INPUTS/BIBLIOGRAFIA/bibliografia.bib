@incollection{Coman_2022,
  title = {The European Council's Role in Day-to-Day Decision-Making: {{Increasing}} the {{EU}}'s Authority through a General Regime of Conditionality (Regulation 2020/2092)?},
  booktitle = {Palgrave {{Studies}} in {{European Union Politics}}},
  author = {Coman, R.},
  year = 2022,
  pages = {195--240},
  abstract = {Regulation 2020/2092 on a general regime of conditionality for the protection of the Union budget was put forward by the Commission in 2018 in a context of heightened dissensus over rule of law concerns. Applauded by the EP, the proposal strongly divided member states in the Council. The regulation was only adopted after two disputed compromises were reached by the European Council in July and December 2020. It had been shaped by increased contestation and ended in a very disputed consensus. The chapter shows that EU institutional actors held different views on how to frame this Regulation, divided over the core rule of law dimensions: legality, control, consent, and substance. Ultimately, in terms of power, the outcome was largely determined by the powerful role of the European Council. Despite its disputed nature, the outcome marks a shift from governance to more integration. Drawing on content analysis, parliamentary debates, and interviews, this chapter is organised as follows: Section 7.1 discusses the Commission's initial political ambitions. Section 7.2 focuses on contestation in the Council over the legal basis of the text. Section 7.3 looks at the consensus/dissensus nexus in national and European Parliaments over the establishment of such a conditionality. Section 7.4 examines the interplay between the Council and the European Council. Section 7.5 shows who got what and how. \copyright{} 2022, The Author(s), under exclusive license to Springer Nature Switzerland AG.},
  affiliation = {Department of Political Science, Universite libre de Bruxelles, Bruxelles, Belgium},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Conroy.Green_2020,
  type = {Article},
  title = {It Takes a Motive: Communal and Agentic Articulated Interest and Candidate Emergence},
  author = {Conroy, Meredith and Green, Jon},
  year = 2020,
  month = dec,
  journal = {Political Research Quarterly},
  volume = {73},
  number = {4},
  pages = {942--956},
  issn = {10659129},
  doi = {10.1177/1065912920933668},
  abstract = {More women ran for office in 2018 than any previous election year. This represents progress toward parity, but it remains unclear whether this surge in women's political ambition signals an easing of the candidate emergence path, which has typically favored men. We leverage over ten thousand intake forms of prospective candidates provided by Run for Something, a candidate recruitment nonprofit founded in 2017, to examine patterns in candidate emergence based on articulated interest through the lens of ``communion'' and ``agency,'' two basic behavioral orientations with gendered significance. We find that differences in articulated interest along the dimensions of communion and agency are greater between candidates and noncandidates than they are between men and women, supporting previous findings of similarities in men and women who emerge as candidates. Our results suggest the candidate emergence path is still easier for women (and men) whose motives are congruent with agency, and therefore the ``masculine ethos'' of politics.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,agency,Base documental: NO,communion,descriptive representation,gender,political ambition,political behavior,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/R8BLEGLP/Conroy y Green - 2020 - It takes a motive communal and agentic articulate.pdf}
}

