@article{Schlesinger_1985,
  title = {The {{New American Political Party}}},
  author = {Schlesinger, Joseph A.},
  year = 1985,
  month = dec,
  journal = {American Political Science Review},
  volume = {79},
  number = {4},
  pages = {1152--1169},
  issn = {0003-0554, 1537-5943},
  doi = {10.2307/1956253},
  urldate = {2023-01-02},
  abstract = {To understand changes taking place within political parties we must work from a realistic theory, one that accepts these parties as office-seeking coalitions. On that premise I lay out three interacting sets of variables: 1) The structure of political opportunities, or the rules for office seeking and the ways they are treated, and 2) the party system, or the competitive relations among parties, define the expectations of politicians, and thus lead them to create 3) party organizations, or the collective efforts to gain and retain office. Hypotheses derived from the relations among these variables allow us to examine changes in American parties in the twentieth century. They explain why the Progressive era reforms, in tandem with the post-1896 party system, produced an uneven distribution of party organization and weak linkages among candidates and officeholders. The same theory also explains why changes taking place since the 1950s are producing greater organizational effort and stronger partisan links among candidates and officeholders.},
  langid = {english},
  file = {D:\OneDrive - Universidad Complutense de Madrid (UCM)\Zotero\Schlesinger\Schlesinger_1985_The New American Political Party.pdf}
}

@incollection{Schneider.Bos_2023,
  title = {{{THE POLITICAL PSYCHOLOGY OF GENDER}}},
  booktitle = {The {{Oxford Handb}}. of {{Political Psychology}}, {{Third Edition}}},
  author = {Schneider, M.C. and Bos, A.L.},
  year = 2023,
  pages = {694--732},
  publisher = {Oxford University Press},
  doi = {10.1093/oxfordhb/9780197541302.013.18},
  abstract = {The goal of this chapter is to underscore how political psychology contributes to our understandings of how gender, a social construction tied to power, influences how one understands and experiences politics. We present theoretical frameworks for understanding gender and gender socialization, key measures in the field, and review empirical tests of these frameworks within the study of political socialization, public opinion, political behavior, elite behavior, and leader evaluation. The chapter highlights how political psychologists are well situated theoretically, substantively, and methodologically to address key questions in gender and politics. We highlight how the field can push forward in promising ways by broadening the definition of gender/sex and challenging the gender binary, directly testing psychological theories regarding how gender shapes the behavior of women as political actors and the evaluations of women as political leaders, and deepening the field's emphasis on intersectional identities. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  isbn = {9780197541333 (ISBN); 9780197541302 (ISBN)},
  langid = {english},
  keywords = {gender,gender stereotypes,leader evaluations,political ambition,political attitudes,political behavior,sex,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)}
}

@article{Schneider.etal_2016,
  type = {Article},
  title = {Power, Conflict, and Community: How Gendered Views of Political Power Influence Women's Political Ambition},
  author = {Schneider, Monica C. and Holman, Mirya R. and Diekman, Amanda B. and McAndrew, Thomas},
  year = 2016,
  month = aug,
  journal = {Political Psychology},
  volume = {37},
  number = {4},
  pages = {515--531},
  publisher = {Blackwell Publishing Ltd},
  issn = {14679221},
  doi = {10.1111/pops.12268},
  abstract = {We provide a novel approach to understanding the political ambition gap between men and women by examining perceptions of the role of politician. Across three studies, we find that political careers are viewed as fulfilling power-related goals, such as self-promotion and competition. We connect these goals to a tolerance for interpersonal conflict and both of these factors to political ambition. Women's lack of interest in conflict and power-related activities mediates the relationship between gender and political ambition. In an experiment, we show that framing a political career as fulfilling communal goals---and not power-related goals---reduces the ambition gap.},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: naciente,2022-WoS,2024-WoS,Base documental: NO,conflict avoidance,gender,political ambition,political behavior,role congruity,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
