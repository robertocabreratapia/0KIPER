@article{Frederick_2013,
  type = {Article},
  title = {Bringing Narrative in: Race-Gender Storytelling, Political Ambition, and Women's Paths to Public Office},
  author = {Frederick, Angela},
  year = 2013,
  month = apr,
  journal = {Journal of Women, Politics and Policy},
  volume = {34},
  number = {2},
  pages = {113--137},
  issn = {1554477X},
  doi = {10.1080/1554477X.2013.776379},
  abstract = {Gender and politics scholars have yet to recognize political leaders' "deciding to run" accounts as storytelling performances that draw from and contest dominant cultural discourses. In this article, I present findings from interviews I conducted with 33 women candidates in Texas, analyzing my subjects' "deciding to run" accounts as narratives that illuminate much about women's attempts to negotiate contradictions between dominant race-gender values and their drive for public office. I find that women tell quite different narratives about their decisions to run for office, with Black women and Latinas expressing more confidence and self-direction in their stories than white women. I also reveal that many of these stories contain complexities and contradictions that are not illuminated in survey research on candidate emergence. \copyright{} 2013 Copyright Taylor \& Francis Group, LLC.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,candidate emergence,Candidate emergence,gender,intersectionality,narrative,political representation,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
