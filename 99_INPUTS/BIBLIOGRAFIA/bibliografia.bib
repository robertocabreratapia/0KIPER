  month = sep,
  journal = {Political Research Quarterly},
  volume = {47},
  number = {3},
  eprint = {448852},
  eprinttype = {jstor},
  pages = {733},
  issn = {10659129},
  doi = {10.2307/448852},
  abstract = {It is generally agreed that legislative leadership is contextual (Sinclair 1990). In this article, I explore the context of leadership by examining the relationship between members' political, electoral and institutional constraints and their expectations of legislative leaders. The study of 120 state senators in Maryland, North Carolina, and Ohio reveals that members look to leaders to help them attain the legislative goals inherent in their particular situation. The analysis reveals statistically significant relationships between respondents' legislative experience, political ambition, campaign expenditures, electoral vulnerability, party status, party strength, and partisan relationship with the executive, and their expectations of legislative leaders. The findings of this study underscore the importance of membership environment and goals in explaining and defining successful leadership and encourage furdier study of the effects of environmental context on successful legislative leadership.},
