}

@article{Dubois_2004,
  title = {The Dilemmas of Institutionalisation: {{From}} Cultural Mobilisation to Cultural Policies in a {{French}} Suburban Town ({{Bron}}, 1970--1990)},
  author = {Dubois, V.},
  year = 2004,
  journal = {International Journal of Cultural Policy},
  volume = {10},
  number = {3},
  pages = {331--349},
  doi = {10.1080/1028663042000312561},
  abstract = {Local cultural policies in France became institutionalised essentially over two decades: the 1970s and the 1980s. This institutionalisation process comprised the cultural specialisation of local administrative services, the professionalisation of local cultural agents and the promotion of culture as one of the mains sectors for local public policies, from the political as well as financial point of view. Based upon the case study of a middle-sized town, this article shows that this was a conflictual process. In the late 1960s and early 1970s, association activists from the new middle classes, politically and culturally close to the political mobilisations of the post-1968 period, launched programmes of cultural action. At first, the municipalisation of their policy was a success for them. However, progressively, this local cultural policy was driven less and less by these former activists, who were replaced by new professionals, and earlier socio-cultural and political ambitions (revolving, for example, around a culture of everyday life designed to promote greater local democracy) were replaced by a more technical orientation. Finally, this institutionalisation process also consisted of the dispossession and disillusion of those who had believed they could change social and political relations through cultural involvement. \copyright{} 2004, Copyright Taylor \& Francis Group, LLC.},
  affiliation = {Professor of Sociology and Political Science, Groupe de Sociologie Politique Europ\'eenne, Institut d'\'etudes politiques, 47 avenue de la For\^et noireStrasbourg cedex F-67082, France},
  author_keywords = {cultural action; culture of everyday life; municipalisation; new middle classes; professionals},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,cultural action,culture of everyday life,municipalisation,new middle classes,professionals,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/TCWKVC3E/Dubois - 2004 - The dilemmas of institutionalisation From cultural mobilisation to cultural policies in a French su.pdf}
}

