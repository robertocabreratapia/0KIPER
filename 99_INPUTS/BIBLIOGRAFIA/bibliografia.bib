@article{Burge_2020,
  type = {Article},
  title = {Introduction to Dialogues: Black Affective Experiences in Politics},
  author = {Burge, Camille D.},
  year = 2020,
  month = mar,
  journal = {Politics, Groups, and Identities},
  volume = {8},
  number = {2},
  pages = {390--395},
  issn = {2156-5503},
  doi = {10.1080/21565503.2020.1757804},
  abstract = {What role might emotions play in Black public opinion and political decision-making? Extant literature in political psychology and Black politics provide us with incomplete answers to this question. While political psychology scholars have only recently begun to explore collective emotional experiences in the form of affective polarization, scholars of Black politics have largely relied on cognitive understandings of racial identity (i.e., linked fate) and its implications for policy opinions and political participation. A burgeoning body of literature in Black politics is beginning to fill these voids. This Dialogue section is devoted to understanding how emotions like pride, anger, sadness, and fear shape Black politics. Through the use of cutting edge survey experiments, these articles address the role of emotions in reactions to police killing unarmed individuals, political ambition, and political mobilization via micro-targeting in campaign advertisements. This Dialogue section will provide a critical interjection in the field as we aim to understand the political implications of the emotions of Black people who seem to be experiencing increasing levels of trauma on a daily basis.},
  keywords = {00Ambicion Politica: naciente,2022-WoS,2024-WoS,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/7AFTVCD7/Burge - 2020 - Introduction to dialogues black affective experie.pdf}
}

@article{Burt-Way.Kelly_1992,
  title = {Gender and Sustaining Political Ambition: {{A}} Study of Arizona Elected Officials},
  author = {{Burt-Way}, B.J. and Kelly, R.M.},
  year = 1992,
  journal = {Political Research Quarterly},
  volume = {45},
  number = {1},
  pages = {11--25},
  doi = {10.2307/448760},
  abstract = {Extant literature and data indicate that there are many differences and few similarities between men and women who express comparable levels of political ambition. By studying male political elites, researchers have constructed a model of political ambition which predicts that women who deviate from the male model cannot be ambitious or successful. Yet, we know that women are ambitious and do hold political office. Some set of circumstances must exist that explains their ambition, and we suggest it is their attitudes and beliefs about the political and electoral system that sustains their ambition. In this exploratory case study of Arizona elected officials, we seek to advance our knowledge about gender differences in sustaining political ambition. To achieve this objective, we first examine how gender relates to sociopolitical status and political opportunity explanations of political ambition. Second, we explore gender differences in beliefs about barriers to electoral success and identify how these officials think electoral success occurs. Finally, we provide an explanation for why women sustain political ambition even though the prevailing male-based explanatory model suggests they will not be ambitious or successful.},
  affiliation = {California State Polytechnic University, Pomona, United States; Arizona State University, United States},
  document_type = {Article},
  langid = {american},
  source = {Scopus},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: causas,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de estudio: exploratorio,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03Continente: America,042Estado: Arizona,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Mix var_cargo,0Division funcional: mix,0Division territorial: multinivel,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: examina la forma en que las actitudes y creencias de las mujeres sobre el sistema politico y electoral junto a las opciones que tienen fuera del sector publico afectan su ambicion politica,1Diseno experimental: no aplica,1Empirico: no experimental,1Encuesta: propia,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individual,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: consejeros locales de condado ejecutivos de condado y miembros de ambas camaras estatales de Arizona,2Poblacion: consejeros locales de condado ejecutivos de condado y miembros de ambas camaras estatales de Arizona,Base documental: SI,Brecha de genero,Cargo: consejeros locales de condado ejecutivos de condado y miembros de ambas camaras estatales de Arizona,Cargo: mix cargos locales y subnacionales,examina la forma en que las actitudes y creencias de las mujeres sobre el sistema politico y electoral junto a las opciones que tienen fuera del sector publico afectan su ambicion politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {13 citations (Crossref) [2024-05-14]},
