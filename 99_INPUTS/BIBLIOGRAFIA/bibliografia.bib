  issn = {0195-7732},
  doi = {10.1300/J014v25n04_03},
  abstract = {Researchers are divided on women's standing as political contenders, whether equal standing offsets gender-related challenges, and whether gender affects votes. Our analysis of U.S. House data from 1978 to 1996 focuses on incumbents seeking re-election. Using one-way ANOVA and multivariate regression analysis, we test if competitive environments and vote shares vary by sex and party. We find that men and women do not run in comparable districts, competition effects are not gender-neutral, and these effects do vary by sex and party. These findings portend increasing gender effects as women run in increasingly competitive House districts. (C) 2003 by The Haworth Press, Inc. All rights reserved.},
