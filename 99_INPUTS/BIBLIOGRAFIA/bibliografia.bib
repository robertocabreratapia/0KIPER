@article{Gronvall_2022,
  title = {Social Workers' Navigation between Repression and Social Support for Men Purchasing Sex [{{Socialarbetares}} Navigering Mellan Repression Och Socialt St\"od F\"or M\"an Som K\"oper Sex]},
  author = {Gr{\"o}nvall, Y.},
  year = 2022,
  journal = {European Journal of Social Work},
  doi = {10.1080/13691457.2022.2083587},
  abstract = {Considering an increasingly repressive focus on sex buyers in recent years, the focus of this study is to explore social work in Sweden targeting individuals who purchase sex. The aim of this study is to explore social workers' understanding of the purchase of sex as a social problem. More specifically, the study focuses on social workers' approaches to the purchase of sex in relation to values, professional practices, and political goals, and how they navigate these aspects in their encounters with individuals who purchase sex. Based on interviews with 10 social workers who meet such individuals, an inductive thematic analysis has been employed. The participants navigated between focusing on the individual sex purchaser and his situation, and having moral opinions on the issue, with some being positive to force change through repressive measures. The participants tried to navigate social work's role in relation to social policy and political ambitions regarding the purchase of sex in Sweden, and did this by navigating between doing moral work, being diplomats or specialists. They did moral work both as individuals and as working groups, which was influenced by moral values, professional ideals, and ideas about social work's role in relation to the judiciary system. \copyright{} 2022 The Author(s). Published by Informa UK Limited, trading as Taylor \& Francis Group.},
  affiliation = {Department of Social Work, Centre for Sexology and Sexuality Studies, Malm\"o University, Malm\"o, Sweden},
  author_keywords = {Buying sex; commercial sex; prostitution; purchase of sex; social work},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,adult,article,Base documental: NO,Buying sex,clinical article,commercial sex,controlled study,diplomat,human,interview,male,morality,policy,professional practice,prostitution,purchase of sex,purchasing,social problem,social support,social work,social worker,Sweden,thematic analysis,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/LE688XU7/Grönvall_2022_Social workers’ navigation between repression and social support for men.pdf}
}

