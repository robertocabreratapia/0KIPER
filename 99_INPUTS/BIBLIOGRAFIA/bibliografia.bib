}

@article{Azmi.etal_2024,
  title = {Revisiting the Concept of Women's Political Ambitions: {{A}} Case Study of {{Malaysia}}},
  author = {Azmi, Z. and Ann, T.S. and Waringin Onn, S. and Selamat, N.H. and Ambak, N.J.},
  year = 2024,
  journal = {Asian Journal of Women's Studies},
  publisher = {{Taylor and Francis Ltd.}},
  issn = {12259276 (ISSN)},
  doi = {10.1080/12259276.2024.2330246},
  abstract = {Studies have revealed that fewer and fewer women are keen on pursuing leadership positions in Malaysian politics as they lack political ambitions. It has been revealed that they prefer to be party members, work for the welfare of their constituents, and mobilize political support for the party and its leadership, especially during general elections. This preference is often viewed as being subordinate to male dominance. However, this present study contends that the political ambitions of women are self-ascribed and should be understood based on their preferred ways of participation and the extent of their influence. Qualitative data from in-depth interviews and focus group discussions were used to demonstrate that women can be politically ambitious party members. Furthermore, the male-dominated leadership of a party may not hinder these ambitions but give women more ease and flexibility to be the influencers and welfare providers of the party. The political ambitions of these women were determined by examining their interests, aspirations, and relentless efforts in the roles that they play in their respective political parties. The findings of this present study broaden our perspectives and understanding of the intersection between gender and political ambitions. \copyright{} 2024 Asian Center for Women's Studies, Ewha Womans University.},
  langid = {english},
  keywords = {2024 STATUS: Pendiente de procesar,2024-Scopus,Ambicion No Electoral,Brecha de genero,Militantes de partido,Political ambition,women leaders,women's narrative,women's political leadership,women's political participation,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)}
}

