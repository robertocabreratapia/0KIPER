  keywords = {0Cargo electo: si,0Division funcional: legislativo,2022-WoS,2024-WoS,Base documental: NO,Consecuencias de los limites a la reeleccion,Limites a la reeleccion,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
