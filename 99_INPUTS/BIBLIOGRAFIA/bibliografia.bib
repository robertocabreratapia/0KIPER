@article{Allen.Cutts_2018,
  type = {Article},
  title = {An Analysis of Political Ambition in Britain},
  author = {Allen, Peter and Cutts, David},
  year = 2018,
  journal = {Political Quarterly},
  volume = {89},
  number = {1},
  pages = {73--81},
  publisher = {Wiley},
  issn = {1467923X},
  doi = {10.1111/1467-923X.12457},
  abstract = {Representative democracies require sufficient numbers of citizens to put themselves forward as candidates for political office. Existing studies have shown that political institutions are not representative of the population as a whole, suggesting that political ambition is not evenly distributed across all potential candidates. We discuss evidence from the first systematic study of political ambition in Britain, examining the question of who is interested in putting themselves forward for political office. We find patterns in the distribution of political ambition that help to explain why British political institutions do not look like the British people as a whole and include a gender gap, a social class gap, an education gap, a north-- south divide, and a personality gap. We discuss the implications of our findings for political parties, arguing that they need to adjust practices of candidate recruitment in such a way that minimises the effects of these biases.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,Brecha de genero,Brecha social,Gender and politics,Political ambition,Political disaffection,Political participation,Political recruitment,Social class,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/2KW878EB/Allen_Cutts_2018_An Analysis of Political Ambition in Britain.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/ELMA36QI/Allen y Cutts - 2018 - An analysis of political ambition in britain.pdf}
}

@article{Allen.Cutts_2020,
  title = {Personality and the Gender Gap in Political Ambition},
  author = {Allen, Peter and Cutts, David},
  year = 2020,
  journal = {European Journal of Politics and Gender},
  volume = {3},
  number = {1},
  pages = {11--32},
  doi = {10.1332/251510819X15728541544002},
  abstract = {In this article, we offer an analysis of the gender gap in political ambition that takes personality and other canonical predictors of levels of ambition into account simultaneously. We use original large-N survey data from Britain. We find that the gender gap in nascent ambition is robust to the inclusion of measures of personality alongside traditional socio-economic predictors of political ambition. Second, we find that increased extraversion is related to higher levels of nascent ambition, but only for women. Third, we find that personality does not drive any move from intending to run for office to actually doing so. \copyright{} Bristol University Press. All rights reserved.},
  affiliation = {University of Bath, United Kingdom; University of Birmingham, United Kingdom},
  author_keywords = {Britain; Five Factor Model; Gender gap; Personality; Political ambition; Political participation},
  document_type = {Article},
  source = {Scopus},
  keywords = {00Ambicion Politica: expresada,00Ambicion Politica: naciente,2022-Scopus,2024-Scopus,Base documental: NO,Brecha de genero,Britain,Five Factor Model,Gender gap,Personalidad,Personality,Political ambition,Political participation,Teoria de la Ambicion Politica,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
