@article{Isik_2019,
  title = {The Politics of Giving: {{Charity}}, State, Civil Society and Governance in Contemporary {{Turkey}}},
  author = {Isik, D.},
  year = 2019,
  journal = {Journal of Muslim Philanthropy and Civil Society},
  volume = {3},
  number = {2},
  pages = {1--25},
  doi = {10.2979/muslphilcivisoc.3.2.01},
  abstract = {Charitable giving has always been centrally important for both the political ambitions of the state and its governing structures, and the Muslim feelings of public belonging and commitment to religious duty. In Turkey, associations and vak\i fs provide the technical assemblages to devise projects that go beyond the dichotomies of secular/religious, of charity/philanthropy and develop communities that transcend national boundaries. This paper highlights charitable associations and vak\i fs as not only places where formal and informal mechanisms of social protection manifest themselves, but also as places where new understandings of the role of the state are fashioned. Visibility of the poor, tinged with nostalgia, becomes a way to remember the ``just'' and ``fatherly'' Ottoman Empire and an Islamic charitable heritage based on transnational religious feeling of brotherhood/sisterhood. Consequentially, charitable communities inadvertently aid and abet the neoliberal agenda of the government. Copyright \copyright{} 2019 Damla Isik},
  affiliation = {Regis University, United States},
  author_keywords = {Charity; Civil society; Governance; State; Turkey; Vakifs},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Charity,Civil society,Governance,State,Turkey,Vakifs,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@incollection{Isumonah_2025,
