@article{Einstein.etal_2020,
  type = {Article},
  title = {Do Mayors Run for Higher Office? {{New}} Evidence on Progressive Ambition},
  author = {Einstein, Katherine Levine and Glick, David M. and Palmer, Maxwell and Pressel, Robert J.},
  year = 2020,
  month = jan,
  journal = {American Politics Research},
  volume = {48},
  number = {1},
  pages = {197--221},
  publisher = {SAGE Publications Inc.},
  issn = {15523373},
  doi = {10.1177/1532673X17752322},
  abstract = {The mayor's office potentially offers a launchpad for statewide and national political ambitions. We know relatively little, however, about how frequently mayors actually run for higher office, and which mayors choose to do so. This article combines longitudinal data on the career paths of the mayors of 200 big cities with new survey and interview data to investigate these questions. While we find that individual and city traits---especially gender---have some predictive power, the overwhelming story is that relatively few mayors---just under one-fifth---ever seek higher office. We suggest that ideological, institutional, and electoral factors all help to explain why so few mayors exhibit progressive ambition.},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,03Continente: America,04Pais: EEUU,0Cargo electo: si,0Division funcional: ejecutivo,0Division territorial: local,1Concepto evaluado: factores que afectan la ambicion progresiva de los alcaldes,1No experimental: diacronico/longitudinal,1Tecnica: mix encuesta y entrevista,1Unidad de analisis: individuo-ciudad,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: alcaldes de 200 ciudades grandes (mas de 150 mil personas capitales de estado y ciudades mas grandes del estado),2Poblacion: alcaldes de ciudades grandes,American politics,Base documental: NO,Cargo: Alcalde o similar,local politics,mayors,progressive ambition,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: descartado (revision final)},
