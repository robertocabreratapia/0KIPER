@incollection{VanElsuwege_2011,
  title = {The {{EU}}'s Governance of External Energy Relations: {{The}} Challenges of a `Rule-Based Market Approach'},
  booktitle = {The {{EU}}'s Governance of External Energy Relations: {{The}} Challenges of a `Rule-Based Market Approach'},
  author = {Van Elsuwege, P.},
  year = 2011,
  pages = {215--237},
  doi = {10.1017/CBO9781139519625.012},
  abstract = {With the Lisbon Treaty, the legal framework for the development of an `Energy Policy for Europe' was significantly strengthened. For the first time, a specific title and provision is devoted to energy. Even though Article 194 TFEU makes no explicit reference to the external dimension of the European energy policy, the well-known implied-powers doctrine codified in Article 3(2) TFEU - provides the authority to adopt international measures that are necessary to achieve the EU's internal objectives. Moreover, the principles and objectives of the EU's external action, including inter alia the promotion of `an international system based on stronger multilateral cooperation and good global governance' also apply to the external aspects of the EU's internal policies. Hence, the political ambition to play a more active role in the development of an international, or at least pan-European, legal energy framework has a sound foundation in the EU Treaties. The aim of this chapter is first to clarify the building blocks of the EU's external energy policy based upon an analysis of relevant policy documents and instruments. It is argued that the EU's strategy can best be defined as the promotion of a `rule-based market approach', which is inspired by the EU's own mechanisms and procedures. Secondly, the legal challenges surrounding the implementation of this approach are addressed. Specific attention is devoted to the relationship between EU law and international investment law, the uniform application of EU law principles in international contexts and the peculiar energy partnership with Russia. Last, but not least, the governance of the EU's external energy policy is confronted with the ethical dimension of the EU's external action. The Union's many engagements with the international legal order Reflecting on the contributions in this edited volume covering a wide range of policy areas and activities beyond the borders of the EU's own territory there can be little doubt that the Union is not only firmly established within the international legal order, but is also actively involved in shaping it. This role is arguably a conscious choice rather than an unexpected side-effect of the Union's engagement with the international legal order. Gr\'ainne de B\'arca in her contribution observes that Europe has developed from a project that was `primarily inwardly focused on repairing and strengthening a damaged continent so as to deliver internal peace and prosperity', to `enhancing Europe's global economic and political influence and role'. The case studies included in this book certainly support the latter conclusion. Yet one could also argue that from the start European integration was geared towards playing an active role in securing global stability and peace precisely because of the inward focus de B\'arca refers to. Evidence for this seemingly paradoxical observation can be found in the grand promise of the Schuman Declaration which opens by stating that `World peace cannot be safeguarded without the making of creative efforts proportionate to the dangers which threaten it. The contribution which an organized and living Europe can bring to civilization is indispensable to the maintenance of peaceful relations'. \copyright{} Cambridge University Press.},
  affiliation = {European Union Law, Faculty of Law, University of Ghent, Belgium; European Union Law, Faculty of Law, University of Ghent, Belgium},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/UAU7MRB7/Van Elsuwege - 2011 - The EU’s governance of external energy relations The challenges of a ‘rule-based market approach’.pdf}
}

