@article{Mezey_1970,
  title = {Ambition {{Theory}} and the {{Office}} of {{Congressmen}}},
  author = {Mezey, Michael L.},
  year = 1970,
  month = aug,
  journal = {The Journal of Politics},
  volume = {32},
  number = {3},
  pages = {563--579},
  issn = {0022-3816, 1468-2508},
  doi = {10.2307/2128831},
  urldate = {2022-08-09},
  abstract = {In a Journal of Politics article of eight years ago, Herbert Jacob criticized "sociological and career ladder studies" of political recruitment on the grounds that their lack of a theoretical framework left the reader "wondering about the significance of it all."' In a more recent study, Joseph Schlesinger makes much the same point. He notes that "despite the industry which has gone into the accumulation of [career] data, they have been notably fruitless in producing predictive propositions . . . and this failure has been due primarily to the lack of a useful political theory." Schlesinger goes on to elaborate "ambition theory" as a means of bringing order to the disparate data on political careers. He suggests the utility of focusing our attention on the nature of the opportunities that confront the aspirant for political office and the role these opportunities play in structuring the ambitions and expectations of politicians as well as our expectations about political careers.4 The basic assumption of the approach is that politicians are rational actors who make political decisions consonant with their political ambitions in order to maximize the probability of realizing these ambitions. The key variable in this decisionmaking process is the structure of opportunities for the political office toward which the politician's ambitions are directed. In the present analysis, a model of congressional recruitment based on ambition theory will be developed. The structure of opportunities for election to the United States House of Representatives will be measured in the context of comparative state politics. Three variables will be operationalized and related for the purpose of testing the model: inter-party opportunities for congressional seats, intra-party opportunities, and past elective experience of successful candidates. This will constitute an experiment to determine whether the elements of ambition theory can help us along the road to "predictive propositions" about political careers},
  langid = {english},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Base de datos: propia,1Concepto evaluado: efecto de la estructura de oportunidades intrapartido y la trayectoria previa del candidato en la ambicion politica,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: no,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre unidades,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unidad de analisis: legislador-legislatura,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: miembros de la Camara Baja de EEUU,2Poblacion: miembros de la Camara Baja,Base documental: SI,Cargo: Legisladores,Carrera politica,manifest office,Periodo: 1949-1967,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {7 citations (Crossref) [2024-05-14]},
