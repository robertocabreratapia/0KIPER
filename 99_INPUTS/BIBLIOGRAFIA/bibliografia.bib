@article{Birkmose_2018,
  title = {Forcing Shareholder Engagement: {{Theoretical}} Underpinning and Political Ambitions},
  author = {Birkmose, H.S.},
  year = 2018,
  journal = {European Business Law Review},
  volume = {29},
  number = {4},
  pages = {613--642},
  abstract = {This paper explores the post-crisis debate on shareholder engagement and argues that the debate and subsequent legislative initiatives aimed at increasing shareholder engagement and accountability seem to be moving away from the traditional corporate governance basis. While corporate governance theory may explain the need for shareholders to balance management powers, it does not support that shareholders have an obligation to engage in investee companies. Neither do we find that the ownership rhetoric supports any duties for shareholders. Finally, we examine elements of stakeholder theory and public policy theory. While these theories emphasise that companies should include other interests than shareholders' financial interests, they do not support a stronger shareholder role in that respect. Thus, the paper concludes that the post-crisis debate on shareholder engagement should be seen as the result of a strong political agenda and that the theoretical basis for pushing shareholder engagement further is weak. \copyright{} 2018, Kluwer Law International.},
  affiliation = {Department of Law, Aarhus BSS, Aarhus University, Denmark},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@incollection{Bitrus_2019,
  title = {The Power of Political Prayer in Nigeria},
  booktitle = {The Power of Political Prayer in Nigeria},
  author = {Bitrus, I.S.},
  year = 2019,
  pages = {81--111},
  abstract = {Prayer has traditionally been used in Christianity as a spiritual means to commune with God, but also to beseech God to address the felt needs and fears of the petitioners. But prayer has lately been used in the church by many Nigerian politicians for personal gain. In particular, politicians have deployed prayer as a campaign tool to mobile the church to support the struggle for achieving their political ambitions. In this article I explore this phenomenon of politicians employing prayer in the church as a potent political tool to subtly campaign for election and reelection in Nigeria. I would argue that the phenomenon of seeking political power through prayer by politicians confers reciprocal political power on both the politicians and the clergy alike. \copyright{} 2019 by Nova Science Publishers, Inc.},
  affiliation = {Department of Systematic Theology, Bronnum Lutheran Seminary, Yola, Nigeria},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Black_1972,
  type = {Article},
  title = {A Theory of Political Ambition: Career Choices and the Role of Structural Incentives},
  author = {Black, Gordon S.},
  year = 1972,
  month = mar,
  journal = {American Political Science Review},
  volume = {66},
  number = {1},
  pages = {144--159},
  issn = {0003-0554},
  doi = {10.2307/1959283},
  abstract = {Office-holders periodically face the problem of choosing among a set of career alternatives, and these alternatives customarily include the choice of dropping out of political life, or seeking reelection, or of choosing to seek higher office. This paper assumes that officeholders behave according to a rational calculus in making such choices, and that the main elements involved in the choice process include the probabilities and values attached by the candidate to his alternatives, and the investments required to obtain these alternatives. Political ambition, or the desire to seek higher office, is shown to develop as a product of the investments that politicians make in their political careers, and the investments are shown to be associated with the structural characteristics of community size and electoral competitiveness. The subjects of the research are 435 city councilmen from 89 cities of the San Francisco Bay Region, and the data include information derived from interviews with the councilmen and aggregate election data collected on each city.},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: causas\elementos considerados,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Consejero local,0Division funcional: legislativo,0Division territorial: local,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la estructura de incentivos (costos beneficios) en la ambicion politica,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: entrevista,1Tipo de experimento: no aplica,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: Consejeros Locales de California Bahia de San Francisco,2Poblacion: Consejeros locales de la Bahia de San Francisco,Base documental: SI,California: San Francisco Bay Area,Costos personales de estar en politica,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {200 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NVMA6BDF/Black_1972_A Theory of Political Ambition.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/U5VQEMPR/Black - 1972 - A Theory of Political Ambition Career Choices and.pdf}
