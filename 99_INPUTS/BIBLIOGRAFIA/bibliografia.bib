@phdthesis{Montilla_2017,
  title = {La Producci\'on Legislativa En El Bicameralismo: Un Estudio Sobre Los Reg\'imenes Presidenciales. {{La}} Ambici\'on Pol\'itica Como Un Determinante Del Comportamiento Legislativo},
  author = {Montilla, Adriana P.},
  year = 2017,
  eprint = {10366/137106},
  eprinttype = {hdl},
  address = {Salamanca},
  urldate = {2024-06-06},
  abstract = {El objetivo de la investigaci\'on es indagar sobre \textquestiondown c\'omo la ambici\'on pol\'itica de los representantes afecta su comportamiento legislativo?. En la primera parte se aborda la estructura de las carreras, se describen las trayectorias que han seguido los senadores y diputados y, a partir de esto se definen cuatro tipos de ambici\'on: est\'atica, progresiva, cesante y discreta. La segunda parte profundiza sobre el comportamiento de los congresistas propone cuatro indicadores para medir las actividades que desarrollan en la Asamblea y en el distrito. Los resultados muestran que la ambici\'on es uno de los factores que influye en la cercan\'ia que los representantes tienen con sus electores, en el n\'umero de acciones que hacen por sus circunscripciones y en los actos de posicionamiento. Adem\'as, permite contrastar como la antig\"uedad, ser del gobierno o de la oposici\'on y el ciclo electoral determinan el trabajo legislativo.},
  school = {Universidad de Salamanca},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/33UXTR34/Montilla_2017_La producción legislativa en el bicameralismo.pdf}
}

@article{MoodyP.R._1973,
  title = {Policy and Power: {{The}} Career of {{T}}'ao Chu 1956--66},
  author = {Moody, P.R., {\relax Jr}.},
  year = 1973,
  journal = {The China Quarterly},
  volume = {54},
  pages = {267--293},
  doi = {10.1017/S0305741000015496},
  abstract = {Kremlinological '' approaches to the study of contemporary Chinese politics are sometimes criticized for seeming to embody the ``rather crude view of politics being concerned with factional strife and power politics.''1Certainly, for most politicians most of the time, it would be wrong as well as cynical to regard `` power '' as being the ultimate goal.2 On the other hand, few would deny that politics does, in part, involve factional strife and power politics, and some political scientists believe that political behaviour may be best explained through a focus on the play of power. Thus, Joseph Schlesinger explains certain aspects of American politics by what he calls ``ambition theory'': ``A politician's behavior is a response to his office goals.''3 Anthony Downs works out a good deductive explanation of the behaviour of political parties in a democracy by starting with the hypothesis that politicians act in a rational manner, espousing ideologies and policies which enable them to maintain or expand their power.4The point of these hypotheses is not that politicians are an unusually venal race of men; the hypotheses do not purport to be accurate descriptions of political motivations. Rather, the assertion is that whatever the ultimate motives of political actors, an approach which hypothesizes that they will behave as though power were their goal does yield helpful and concise explanations of their behaviour. This article about the political career of one Chinese politician, T'ao Chu, from 1956 through 1966, will attempt to see how far hypotheses concentrating on ``pure power'' provide a useful explanation of events in comparison with those which give more weight to stated political opinions. \copyright{} 1973, The China Quarterly. All rights reserved.},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/LKPZYK5J/Moody, P.R. - 1973 - Policy and power The career of T'ao chu 1956–66.pdf}
}

@article{Moore_2005,
  type = {Article},
  title = {Religion, Race, and Gender Differences in Political Ambition},
  author = {Moore, Robert G.},
  year = 2005,
  month = dec,
  journal = {Politics and Gender},
  volume = {1},
  number = {4},
  pages = {577--596},
  issn = {17439248},
  doi = {10.1017/S1743923X05050154},
  abstract = {Existing studies of political ambition tell two different stories, male and female. Most research on political ambition focuses on the desire of men and women to hold political office at the state or national level and examines the ambitions of those already employed in the labor force. Scholarly inattention to ambition among activists at the local, neighborhood level may lead us to erroneous conclusions about people's motivations for engaging in politics, particularly along racial lines. A focus on those already in the workforce may distort our understanding of the factors that drive the political ambitions of women in particular. This study confirms that men and women have distinct paths of family socialization, qualifications, high school and college socialization, and life situations on the trail to ambition. It also shows that the local context changes the explanations for ambition. In particular, race, combined with the holding of conservative religious beliefs, varies in its impact upon white and minority women's expressions of ambition for future public office. In addition, the experience of sex discrimination has the countersocialization effect of increasing women's ambition. \copyright{} 2005, The Women and Politics Research Section of the American Political Science Association. All rights reserved.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/GGDLMLJA/Moore - 2005 - Religion, race, and gender differences in politica.pdf}
}

@book{Morton.Williams_2010,
  title = {Experimental Political Science and the Study of Causality: From Nature to the Lab},
  shorttitle = {Experimental Political Science and the Study of Causality},
  author = {Morton, Rebecca B. and Williams, Kenneth C.},
  year = 2010,
  publisher = {Cambridge University Press},
  address = {Cambridge ; New York},
  abstract = {"Increasingly, political scientists use the term 'experiment' or 'experimental' to describe their empirical research. One of the primary reasons for doing so is the advantage of experiments in establishing causal inferences. In this book, Rebecca B. Morton and Kenneth C. Williams discuss in detail how experiments and experimental reasoning with observational data can help researchers determine causality. They explore how control and random assignment mechanisms work, examining both the Rubin causal model and the formal theory approaches to causality. They also cover general topics in experimentation such as the history of experimentation in political science; internal and external validity of experimental research; types of experiments - field, laboratory, virtual, and survey - and how to choose, recruit, and motivate subjects in experiments. They investigate ethical issues in experimentation, the process of securing approval from institutional review boards for human subject research, and the use of deception in experimentation"--Provided by publisher},
  isbn = {978-0-521-19966-7 978-0-521-13648-8},
  lccn = {JA71 .M675 2010},
  keywords = {Methodology,Political science,Research,Thought experiments},
  annotation = {OCLC: ocn567165773},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/BICF247F/Morton_Williams_2010_Experimental political science and the study of causality.pdf}
}

@article{Mufti.Ali_2025,
  title = {Political Elite Careers in {{Pakistan}}},
  author = {Mufti, M. and Ali, S.A.M.},
  year = 2025,
  journal = {Regional and Federal Studies},
  volume = {35},
  number = {3},
  pages = {463--486},
  publisher = {Routledge},
  issn = {13597566 (ISSN)},
  doi = {10.1080/13597566.2025.2471749},
  abstract = {Based on an original data set of 384 federal ministers and 360 provincial ministers from Punjab and Sindh from 1988 till present, we examine the career movements of political elites in Pakistan. We argue that formal institutions enshrined in the constitution pertaining to federal design, the electoral and party system do not provide a complete explanation for the movement in political careers. In fact, informal institutions such as clientelism and dynasticism are far more critical drivers of career choices made by political elites. Contrary to the expectation that in a high-risk, hybrid political context we would find integrated careers, instead, our data set reveals that a majority of politicians prefer to have alternative careers at either the provincial or national level without much mobility between levels of government. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {election,elite politics,federal system,federalism,formal and informal institutions,organization,Pakistan,party politics,political ambition,political elites,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)}
}

@article{Muller.Strom_2004,
  title = {Servants or Oligarchs? {{Politicians}} and Parties in {{Parliamentary}} Democracies},
  author = {M{\"u}ller, W.C. and Str{\o}m, K.},
  year = 2004,
  journal = {Tidsskrift for Samfunnsforskning},
  volume = {45},
  number = {2},
  pages = {421-458+482-483},
  abstract = {In this article we consider the role of political parties in parliamentary democracies within a principal-agent framework. Parliamentary democracies feature a long and indirect chain of delegation from voters to the ultimate policy-makers. Political parties play a central role in containing agency problems along this chain of delegation, but they can only play this role if they are useful for voters as well as for political candidates and officials. Parties have to provide sufficient inducements for political office-holders to submit to the cohesion (discipline) that they impose. Moreover, the policy cohesion that parties induce among office-holders must be sufficient that voters find the party label informative and useful. Parties help voters solve problems of capacity, competence, social choice, and collective action. They also function as effective "informational economizing devices", reduce transaction costs, and help politicians to fulfill their political ambitions of gaining re-election, winning power, and shaping public policy. As parties gain importance as mechanisms of bonding among politicians, however, they reduce incentives for parliamentary oversight of the executive. Hence the institutions of parliamentary democracies do not provide voters with very effective means of ex post control of their political agents. Our empirical review of the use of executive oversight instruments in 17 Western European states suggests that parliamentary control is indeed fairly ineffective. At the same time, these systems exhibit a general decline in the functions that political parties play in facilitating citizen control of their agents.},
  affiliation = {Department of Political Science, University of Mannheim, Germany; Department of Political Science, University of California, San Diego, United States; Peace Research Institute, Oslo, Norway},
  author_keywords = {Delegation; Parliamentary control; Parliamentary democracy; Political parties; Principal-agent theory},
  document_type = {Review},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Delegation,Democracia parlamentaria,Parliamentary control,Parliamentary democracy,Partidos Politicos,Political parties,Principal-agent theory,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)}
}

@article{Mustillo.etal_2025,
  title = {The Logic of Ambitious Legislators in Fluid Party Systems},
  author = {Mustillo, T. and {Polga-Hecimovich}, J. and S{\'a}nchez, F.},
  year = 2025,
  journal = {Legislative Studies Quarterly},
  volume = {50},
  number = {2},
  pages = {148--165},
  publisher = {{John Wiley and Sons Inc}},
  issn = {19399162 (ISSN); 03629805 (ISSN)},
  doi = {10.1111/lsq.12465},
  abstract = {Classic theories of political ambition assume relatively stable and programmatic party systems. However, in many parts of the world, `fluid' or `inchoate' party systems do not provide ambitious legislators with the electoral benefits associated with stable party brands. In this paper, we examine ambition in fluid party systems: What is the frequency of party switching for legislators who seek re-election, and what are their characteristics? What incentives do parties create to push away or retain legislators? And which parties do ambitious legislators seek out? Using a systems approach, we argue that in fluid party systems, legislators' office-seeking behavior is driven by their attitudes towards parties and their constituents, their prospective evaluation of party performance, and ideology. Incentives for politicians to switch parties act as negative feedback mechanisms which keep the party system stuck in a fluid state. We test the determinants of party switching using two data sources from Ecuador: a public records dataset of every legislator who earned re-election from 1979 to 2021, and the Parliamentary Elites in Latin America (PELA) surveys of all legislators from 1994 to 2017. Both sources distinguish between switchers and non-switchers. The results support the conclusion that ambitious legislators in fluid party systems are strategic actors that seek or keep parties to maximize their probability of re-election---and thereby further exacerbate the party system's fluidity. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03Continente: America,04Pais_sigla: ECU,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: unicameral,0Organizacion territorial: unitario,1Diseno experimental: no aplica,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: unidades e individuos,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,Ambicion estatica,Ecuador,inchoate party systems,legislative politics,party switching,political parties,Tipos de ambicion politica,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/UXX9XWHR/Mustillo et al. - 2025 - The logic of ambitious legislators in fluid party systems.pdf}
}

