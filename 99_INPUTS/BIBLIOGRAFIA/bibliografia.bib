@article{Sidorsky_2015,
  type = {Article},
  title = {Moving on up? {{The}} Gendered Ambitions of State-Level Appointed Officials},
  author = {Sidorsky, Kaitlin},
  year = 2015,
  month = dec,
  journal = {Political Research Quarterly},
  volume = {68},
  number = {4},
  pages = {802--815},
  issn = {1938274X},
  doi = {10.1177/1065912915607638},
  abstract = {Many scholars have offered explanations as to why women are underrepresented at all levels of government. Conventional wisdom states that fewer women are in public office due to lower ambition, and that the presence of gendered perceptions among women considering elected office contributes to women's disinterest in the political arena. Using original survey data, this article expands the theory of gendered perceptions to current state-level appointed officeholders to explain their levels of interest in pursuing higher public office. The results indicate that gendered perceptions affect the progressive ambitions of appointees; like studies of ambition in elected officials, this study of appointed officials finds that women are generally less ambitious, and unlike studies of ambition in elected officials, this study of appointed officials finds that women with higher self-assessments are less ambitious rather than more.},
  keywords = {00Ambicion Politica: progresiva,03Continente: America,042Estado: Alaska,042Estado: Arkansas,042Estado: Carolina del Norte,042Estado: Connecticut,042Estado: Dakota del Norte,042Estado: Illinois,042Estado: Iowa,042Estado: Kansas,042Estado: Kentucky,042Estado: Luisiana,042Estado: Massachussetts,042Estado: Michigan,042Estado: Montana,042Estado: Oregon,042Estado: Tennesse,042Estado: Utah,042Estado: Vermont,042Estado: Washington,042Estado: Wisconsin,042Estado: Wyoming,04Pais: EEUU,0Cargo electo: si,0Division funcional: legislativo,0Division territorial: subnacional,1NoExperimental_Tecnicas: encuesta,2022-WoS,2024-WoS,Base documental: NO,gender and politics,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/YB466PCN/Sidorsky - 2015 - Moving on up The gendered ambitions of state-leve.pdf}
