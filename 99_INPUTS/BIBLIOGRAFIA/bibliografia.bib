@article{Flyvbjerg_2006,
  title = {Five {{Misunderstandings About Case-Study Research}}},
  author = {Flyvbjerg, Bent},
  year = 2006,
  month = apr,
  journal = {Qualitative Inquiry},
  volume = {12},
  number = {2},
  pages = {219--245},
  issn = {1077-8004, 1552-7565},
  doi = {10.1177/1077800405284363},
  urldate = {2023-01-09},
  abstract = {This article examines five common misunderstandings about case-study research: (a) theoretical knowledge is more valuable than practical knowledge; (b) one cannot generalize from a single case, therefore, the single-case study cannot contribute to scientific development; (c) the case study is most useful for generating hypotheses, whereas other methods are more suitable for hypotheses testing and theory building; (d) the case study contains a bias toward verification; and (e) it is often difficult to summarize specific case studies. This article explains and corrects these misunderstandings one by one and concludes with the Kuhnian insight that a scientific discipline without a large number of thoroughly executed case studies is a discipline without systematic production of exemplars, and a discipline without exemplars is an ineffective one. Social science may be strengthened by the execution of a greater number of good case studies.},
  langid = {english},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/TXNCQYVD/flyvbjerg2006.pdf;D\:\\OneDrive - Universidad Complutense de Madrid (UCM)\\Zotero\\Flyvbjerg\\Flyvbjerg_2006_Five Misunderstandings About Case-Study Research.pdf}
}

@article{Folke.Rickne_2025,
  title = {The {{Class Ceiling}} in {{Politics}}},
  author = {Folke, O. and Rickne, J.},
  year = 2025,
  journal = {American Political Science Review},
  volume = {119},
  number = {3},
  pages = {1375--1392},
  publisher = {Cambridge University Press},
  issn = {15375943 (ISSN); 00030554 (ISSN)},
  doi = {10.1017/S0003055424001011},
  abstract = {Prior studies have documented that working-class individuals rarely become parliamentarians. We know less about when in the career pipeline to parliament workers disappear, and why. We study these questions using detailed data on the universe of Swedish politicians' careers over a 50-year period. We find roughly equal-sized declines in the proportion of workers on various rungs of the political career ladder ranging from local to national office. We reject the potential explanations that workers lack political ambition, public service motivation, honesty, or voter support. And while workers' average high school grades and cognitive test scores are lower, this cannot explain their large promotion disadvantage, a situation that we label a class ceiling. Organizational ties to blue-collar unions help workers advance, but only to lower-level positions in left-leaning parties. We conclude that efforts to improve workers' numerical representation should apply throughout the career ladder and focus on intra-party processes. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {american},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: incumbentes,01Tipo de investigacion politica: orientada a la teoria,03Continente: Europa,04Pais_sigla: SWE,04Pais: Suecia,0Cargo electo: si,0Cargo: Politicos locales y nacionales electos,0Division funcional: legislativo,0Division territorial: multinivel,0Forma Gobierno: parlamentario,0Organizacion legislativo: unicameral,0Organizacion territorial: unitario,1Diseno experimental: no aplica,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre individuos,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/HU3R49L6/Folke y Rickne - 2025 - The Class Ceiling in Politics.pdf}
}

@article{Foos.Gilardi_2020,
  title = {Does Exposure to Gender Role Models Increase Women's Political Ambition? {{A}} Field Experiment with Politicians},
  author = {Foos, F. and Gilardi, F.},
  year = 2020,
  journal = {Journal of Experimental Political Science},
  volume = {7},
  number = {3},
  pages = {157--166},
  doi = {10.1017/XPS.2019.21},
  abstract = {There is a persistent gender gap in motivations to run for political office. While exposure to role models is widely believed to increase women's political ambition, there is little field experimental evidence on whether exposure to female politicians in realistic settings can increase political ambition. We conducted a field experiment in which a sample of 612 female students was randomly assigned to receive emails inviting them to an event that included career workshops with female politicians, or no email. The treatment increased interest in the ongoing national election campaign, but, against expectations, did not have any positive effect on political ambition. Our results suggest that female politicians who discuss their experience bluntly, instead of following a motivational script, may fail to motivate other women to pursue a political career. These results highlight the need for more research into the type of events and messages that bring more women into politics. \copyright{} 2020 Cambridge University Press. All rights reserved.},
  affiliation = {Department of Government, London School of Economics and Political Science, Houghton Street, London, WC2A 2AE, United Kingdom; Department of Political Science, University of Zurich, Z\"urich, 8050, Switzerland},
