@article{Blais.etal_2019,
  type = {Article},
  title = {Why Do They Run? {{The}} Psychological Underpinnings of Political Ambition},
  author = {Blais, Julie and Pruysers, Scott and Chen, Philip G.},
  year = 2019,
  month = dec,
  journal = {Canadian Journal of Political Science},
  volume = {52},
  number = {4},
  pages = {761--779},
  publisher = {Cambridge University Press},
  issn = {17449324},
  doi = {10.1017/S0008423918001075},
  abstract = {What drives individuals toward a career in politics? Prior research on political ambition has often focused on socio-demographic variables while generally ignoring the importance of individual personality differences. Yet personality consistently predicts political knowledge, interest and participation, suggesting that individual differences may matter in addition to resources and the social environment. To this end, we assess the impact of both the HEXACO and Dark Triad models of personality in predicting nascent political ambition (that is, the initial desire to run for elected office) while controlling for well-established socio-demographic variables (for example, gender, income). Overall, we find considerable support for the predictive power of personality, especially the traits of honesty-humility, extraversion and narcissism. These results have important implications for understanding the kinds of people who are interested in a political career.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,Dark Triad,HEXACO,personality,political ambition,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/TGYFDV4F/Blais et al. - 2019 - Why do they run The psychological underpinnings o.pdf}
}

@article{Blake_1996,
  title = {Against Spiritual Education},
  author = {Blake, N.},
  year = 1996,
  journal = {Oxford Review of Education},
  volume = {22},
  number = {4},
  pages = {443--456},
  doi = {10.1080/0305498960220405},
  abstract = {Spiritual education is only possible within specific religious traditions. In the context of state schools it is a contradiction in terms; and we should beware the political ambition to extend it into that context. Spiritual awareness is a sensitivity to sheer contingency inappropriate to secular institutionalisation. The adequacy of equating spirituality with a sense of the transcendent, as argued recently by David Carr, is questioned. This equation marries the spiritual to the rationally knowable and to a concept of 'a spirit', elisions which each dictate too tendentious an account of spirituality to justify spiritual education. Spiritual awareness of contingency concerns radically general aspects of human existence. Consideration of the mediation of experience through language supports the claim that spirituality is as much concerned with immanence as transcendence; and that awareness of contingency is the more fundamental issue. The sacrifice and intensity which can attend heightened exercises of awareness of corporeality may also betoken spirituality, even in trivial and vulgar physical practices. The suspicion of vulgarity necessarily attends claims to spirituality in all their forms. Spirituality puts in question the fundamentals which underpin education outside religion; and is thus incompatible with it.},
  affiliation = {Institute of Educational Technology, Open University, Walton Hall, Milton Keynes MK7 6AA, United Kingdom},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/Z3IALRIZ/Blake - 1996 - Against spiritual education.pdf}
}

