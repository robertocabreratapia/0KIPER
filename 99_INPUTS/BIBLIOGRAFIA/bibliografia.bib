@article{Clifford.etal_2019,
  type = {Article},
  title = {How Dispositional Empathy Influences Political Ambition},
  author = {Clifford, Scott and Kirkland, Justin H. and Simas, Elizabeth N.},
  year = 2019,
  month = jul,
  journal = {Journal of Politics},
  volume = {81},
  number = {3},
  pages = {1043--1056},
  issn = {14682508},
  doi = {10.1086/703381},
  abstract = {Political representation is fundamentally about advancing the needs and interests of others. Empathy---the ability to share others' feelings and perspectives---ought to be a critical skill for effective representation. Yet the conflict, negativity, and competition that are endemic to politics may prevent empathetic individuals from seeking office. Using an original national survey with an oversample of people who have run for office, we explore how citizens' dispositional empathy influences political ambition. We show that perspective-taking increases ambition, while personal distress depresses ambition. By analyzing feelings toward several different aspects of running for and holding political office, we show the mechanisms through which empathy affects ambition. Finally, we demonstrate that experimentally manipulated perceptions of campaign context moderate the effects of empathy on ambition. Our results provide new insight into how psychological factors interact with political context to shape ambition and hold important implications for the quality of representation.},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03Continente: America,042Estado: Texas,04Pais: EEUU,1Concepto evaluado: relacion entre empatia y postulacion a cargos (expresada),1Diseno experimental: control grupos aleatoriedad,1Diseno experimental: distintos sujetos,1Diseno: dos fases encuesta y luego panel on line,1Empirico: experimental,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Tipo de experimento: laboratorio/online,1Tratamiento: envios masivos de correos con tres niveles: negativa (diamaciones e insultos) neutra (uso de sobres) positiva (disposicion al dialogo).,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: poblacion general,2Panel: YouGov,2Participantes: estudiantes universitarios,2Participantes: Universidad de Houston,2Plataforma experimental: no,2Poblacion: adultos,2Poblacion: residentes EEUU,Base documental: NO,Campanas electorales,Empatia,Experimento,Personalidad,Regresion logistica ordinal,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/JA28QSNB/Clifford et al. - 2019 - How dispositional empathy influences political amb.pdf}
}

