@incollection{Bickers.etal_2009,
  title = {The Political Market for Intergovernmental Cooperation},
  booktitle = {Self-{{Organizing Federalism}}: {{Collaborative Mechanisms}} to {{Mitigate Institutional Collective Action Dilemmas}}},
  author = {Bickers, K.N. and Post, S. and Stein, R.M.},
  year = 2009,
  pages = {161--176},
  doi = {10.1017/CBO9780511642319.009},
  abstract = {The incidence of regional and metropolitan area intergovernmental relations is often explained in terms of efficiency gains for the participating jurisdictions (Stein 1990; Rusk 1993; Waste 1998; Katz 2000; Drier, Mollenkopf, and Swanstrom 2001). It is generally believed that local governments seeking to cut costs or provide a higher quality of services will look to other neighboring jurisdictions and private sector entities to partner with in the provision of goods and services. The economic rationale behind regional and intergovernmental cooperation is well understood. Not obvious are the political and professional motivations that influence decisions to cooperate and collaborate with neighboring jurisdictions. We theorize that local officeholders view decisions to engage or not engage in intergovernmental cooperation as avenues for promoting their political careers. Two different theories that exist in the literature on intergovernmental cooperation lead to two distinctly different expectations about how intergovernmental cooperation affects electoral trajectories. In one view, local elected officials with ambition for higher office (especially higher political offices that represent a larger geography) may pursue intergovernmental relations as a way to promote themselves to a larger constituency. This view draws on the seminal work of Joseph Schlesinger on ambition theory. In a second view, intergovernmental cooperation reflects the goal of incumbents to protect themselves from electoral threats. In this view, a high incidence of intergovernmental cooperation leads to fewer, rather than more, challenges by quality challengers and is thus associated with fewer opportunities for incumbents at lower levels of government to realize their ambitions for higher office. \copyright{} Cambridge University Press 2010.},
  affiliation = {Department of Political Science, University of Colorado, Boulder, CO 80309, United States; Center for Civic Research and Design Rice University, Houston, TX 77251, United States; Department of Political Science Rice University, Houston, TX 77251, United States},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {00Ambicion Politica: efectos,0Cargo electo: si,0Division funcional: ejecutivo,0Division territorial: local,2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: descartado (revision final)},
  annotation = {abstractTranslation:},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/FT43FQCD/Bickers et al. - 2009 - The political market for intergovernmental cooperation.pdf}
}

