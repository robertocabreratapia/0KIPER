@incollection{Kooijmans_2013,
  title = {Dag {{Hammarskj\"old}} 1905-1961: {{A}} Remarkable Man, a Remarkable Secretary-General},
  booktitle = {Peace {{Diplomacy}}, {{Global Justice}} and {{International Agency}}: {{Rethinking Human Security}} and {{Ethics}} in the {{Spirit}} of {{Dag Hammarskjold}}},
  author = {Kooijmans, P.},
  year = 2013,
  pages = {51--55},
  doi = {10.1017/CBO9781139583855.006},
  abstract = {If Dag Hammarskj\"old had lived up to the expectations the Member States of the UN-and in particular the major powers-had when they elected him to the office of Secretary-General, we would not be here today to commemorate him. He was expected to be a competent administrator without political ambitions, but willing to serve the interests of the Member States and not to antagonise the leading nations as his predecessor had done. A competent administrator he was, but he decided to serve the interests of the world organisation as such, as the embodiment of the world community, and steadfastly refused to allow it to become a tool in the hands of the major powers. He certainly was no starry-eyed idealist but was well aware-to use his own words-that `the role of the organization is necessarily a modest one, subordinated as it must be to governments, and through governments to the will of the peoples'. But that did not restrain him from adding immediately that `it is quite realistic to look at the work of the organization as an essential and-within its limits-effective work for building dams against the floods of disintegration and violence'. And he strongly appealed to the members of the Secretariat to meet this challenge jointly. He ardently believed in the values and principles contained in the Charter and in the possibilities the UN, as an organisation, had in being instrumental in restructuring world conditions. And he was able to pass on this belief to a group of people he had gathered around him and who were willing to explore with him new horizons and set off on new daring adventures, like, for example, the instrumentation of peacekeeping, preventive diplomacy and early warning. \copyright{} Cambridge University Press 2014.},
  document_type = {Book Chapter},
  isbn = {978-1-139-58385-5},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Liders y liderazgo,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/KUITI5DN/Kooijmans - 2013 - Dag Hammarskjöld 1905-1961 A remarkable man, a remarkable secretary-general.pdf}
}

@article{Korkut_2019,
  title = {The Discursive Governance of Forced-Migration Management: {{The}} Turkish Shift from Reticence to Activism in Asia},
  author = {Korkut, U.},
  year = 2019,
  journal = {Journal of Refugee Studies},
  volume = {32},
  number = {4},
  pages = {664--682},
  doi = {10.1093/jrs/fey053},
  abstract = {This article shows how similar humanitarian narratives of states can travel across different geographies in response to refugee crises. Empirically, it follows Turkey's position vis-\`a-vis the Syrian and Rohingya refugee crises. Considering Turkey's migration management practices, humanitarian activism narrative, and its political ambition to foster domestic and international audiences for this narrative, this article elaborates on how Turkey has become a humanitarian actor responding both to Syrian and the Rohingya crises. In both cases, the Turkish political discourses have been very resonant of each other, despite Syria and Myanmar being in different geographies and proximities to Turkey. The article also shows how Turkish politicians and the civil servants aspired to enhance visibility and credibility of Turkey as a humanitarian actor. Delineating Turkey's humanitarian narrative shows the role of political agency in forging sympathetic domestic and international audiences. Overall, the Turkish case presents how states operate migration regimes at the cusp of discourses and institutions affecting their forced migration management and humanitarian engagements. \copyright{} 2018 The Author(s). Published by Oxford University Press. All rights reserved.},
  affiliation = {Glasgow Caledonian University, Glasgow, United Kingdom},
  author_keywords = {Audience making; Humanitarianism; Rohingya; Syria; Turkey},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Audience making,Base documental: NO,forced migration,governance approach,humanitarian aid,Humanitarianism,immigrant population,immigration policy,international migration,refugee,Rohingya,social movement,Syria,Turkey,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/3HW8QGVA/Korkut_2019_The discursive governance of forced-migration management.pdf}
}

@article{Krasnodebski_1993,
  title = {Longing for Community: {{Phenomenological}} Philosophy of Politics and the Dilemmas of European Culture},
  author = {Krasnod{\k e}bski, Z.},
  year = 1993,
  journal = {International Sociology},
  volume = {8},
  number = {3},
  pages = {339--353},
  doi = {10.1177/026858093008003005},
  abstract = {Phenomenology enjoys striking popularity in Eastern Europe. For those concerned with phenomenology before the collapse of communism it was an antidote to Marxism in its Soviet version. Its popularity was due to the perhaps naive striving for a true philosophy not manipulated by politics, in that its idealism was interpreted as a protest against the materialistic degradation of the human being. What would Husserl say if he was told about this role of phenomenology? Perhaps he would it consider it as self-evident. His allegedly completely apolitical philosophy had political ambitions, since the struggle for phenomenology was for him not merely a philosophical discussion, but a political struggle with pragmatists, advocates of Realpolitik, nationalists and traditionalists. This paper analyses phenomenology as a radical social philosophy which aimed at the revolutionary renewal of European culture. Well-known for his inclination to work on details and for an arduous theoretical analysis, Husserl was not an advocate of small steps in politics. His political philosophy is then contrasted with that of Helmuth Plessner. From Plessner's point of view Husserl's programme can be seen as a manifestation of the striving for the abolition of society and its replacement by community. In his defence of society, Plessner developed a philosophy of the public sphere as a sphere of social roles, prestige ceremonial, tact and diplomacy, in which the absolute character of the Ego is negated in contact with others. The paper poses questions such as which of these philosophies is more adequate for our time and whether the way shown by Husserl in his programmatic writings is still open to us today. \copyright{} 1993, SAGE Publications. All rights reserved.},
  affiliation = {Universit\"at Bremen, FB 8: Kulturgeschichte Osteurops, Postfach 33 04 40, Bremen, Germany},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/8MLZGI8L/Krasnodębski - 1993 - Longing for community Phenomenological philosophy of politics and the dilemmas of european culture.pdf}
}

@article{Krcmaric.etal_2023,
  title = {Billionaire {{Politicians}}: {{A Global Perspective}}},
  shorttitle = {Billionaire {{Politicians}}},
  author = {Krcmaric, Daniel and Nelson, Stephen C. and Roberts, Andrew},
  year = 2023,
  month = oct,
  journal = {Perspectives on Politics},
  pages = {1--15},
  issn = {1537-5927, 1541-0986},
  doi = {10.1017/S1537592723002761},
  urldate = {2024-04-13},
  abstract = {We introduce an original dataset of formal political participation for over 2,000 individuals included in the Forbes Billionaires List. We find that billionaire politicians are a surprisingly common phenomenon: Over 11\% of the world's billionaires have held or sought political office. Even compared to other elite groups known for producing politicians from their ranks, this is a high rate of political participation. Moreover, billionaires focus their political ambitions on influential positions, have a strong track record of winning elections, and lean to the right ideologically. We also document substantial cross-national variation: a country's number of billionaire politicians is not simply a product of its total number of billionaires, but is instead related to regime type. Specifically, billionaires formally enter the political sphere at a much higher rate in autocracies than in democracies. We conclude by discussing the normative implications of our findings and outlining a new research agenda on billionaire politicians.},
  copyright = {https://www.cambridge.org/core/terms},
  langid = {english},
  keywords = {2024 STATUS: Pendiente de procesar,2024-Scopus,2024-WoS,2024-WoS-> Update - Agregado,Ambicion Naciente,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)}
}

@article{Kreitzer.Osborn_2019,
  type = {Article},
  title = {The Emergence and Activities of Women's Recruiting Groups in the {{U}}.{{S}}.},
  author = {Kreitzer, Rebecca J. and Osborn, Tracy L.},
  year = 2019,
  month = oct,
  journal = {Politics, Groups, and Identities},
  volume = {7},
  number = {4},
  pages = {842--852},
  issn = {2156-5503},
  doi = {10.1080/21565503.2018.1531772},
  abstract = {ABSTRACTUnlike many other countries, the U.S. has not adopted sets of laws or voluntary policies, such as quotas or ``all-women short lists'' in the U.K., to increase women's representation. In lieu of official policy, an informal network of groups has grown around the need to increase the number of women candidates vying for political office in the U.S. Though researchers and the media discuss these groups often, we lack a complete picture of how many groups exist and what they do. This paper builds a descriptive profile of women's recruitment and training in the U.S. using a new census of active women candidate groups. We highlight patterns in where they operate, partisanship, abortion litmus tests, and their participation in recruiting, training, and funding women candidates. We find that organizations operate in all states, but that these organizations are not equally accessible to all groups of women.},
  keywords = {00Ambicion Politica: naciente,2022-WoS,2024-WoS,abortion,Base documental: NO,ca,candidate recruitment,candidate training,political ambition,women candidate groups,Women's representation,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NZNL9LB7/Kreitzer y Osborn - 2019 - The emergence and activities of women's recruiting.pdf}
}

