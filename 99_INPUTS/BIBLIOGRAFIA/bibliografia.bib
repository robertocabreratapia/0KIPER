  author = {P{\'e}rez, A. and Araya, I.A.},
  year = 2017,
  journal = {Journal of Law and Courts},
  volume = {5},
  number = {2},
  pages = {173--197},
  doi = {10.1086/692962},
  abstract = {Students of judicial behavior debate whether justices time their retirement to allow for the nomination of like-minded judges. We formalize the assumptions of strategic retirement theory and derive precise hypotheses about the conditions that moderate the effect of partisan incentives on judicial retirements. The empirical implications are tested with evidence for Supreme Court members under democracies and dictator-ships in six presidential regimes between 1900 and 2004. The theory of strategic retirement finds limited support in the United States and elsewhere. We conclude that researchers should emphasize ``sincere'' motivations for retirement, progressive political ambitions, and---crucial in weakly institutionalized legal systems---political pressures. \copyright{} 2017 by Law and Courts Organized Section of the American Political Science Association. All rights reserved.},
  affiliation = {University of Pittsburgh, United States; Pontificia Universidad Cat\'olicade Chile, Chile},
  document_type = {Article},
