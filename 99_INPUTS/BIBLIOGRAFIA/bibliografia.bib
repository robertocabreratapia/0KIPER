@article{Dancygier.etal_2021,
  type = {Article},
  title = {Candidate Supply Is Not a Barrier to Immigrant Representation: A Case--Control Study},
  author = {Dancygier, Rafaela and Lindgren, Karl Oskar and Nyman, P{\"a}r and Vernby, K{\aa}re},
  year = 2021,
  month = jul,
  journal = {American Journal of Political Science},
  volume = {65},
  number = {3},
  pages = {683--698},
  issn = {15405907},
  doi = {10.1111/ajps.12553},
  abstract = {Immigrants are underrepresented in most democratic parliaments. To explain the immigrant--native representation gap, existing research emphasizes party gatekeepers and structural conditions. But a more complete account must consider the possibility that the representation gap begins at the supply stage. Are immigrants simply less interested in elected office? To test this explanation, we carried out an innovative case--control survey in Sweden. We surveyed elected politicians, candidates for local office, and residents who have not run; stratified these samples by immigrant status; and linked all respondents to local political opportunity structures. We find that differences in political ambition, interest, and efficacy do not help explain immigrants' underrepresentation. Instead, the major hurdles lie in securing a candidate nomination and being placed on an electable list position. We conclude that there is a sufficient supply of potential immigrant candidates, but immigrants' ambition is thwarted by political elites.},
  keywords = {00Ambicion Politica: naciente,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Base documental: NO,Inmigrantes,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/3I7TKH9R/Dancygier et al. - 2021 - Candidate Supply Is Not a Barrier to Immigrant Rep.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NFQFY398/Dancygier et al. - 2021 - Candidate supply is not a barrier to immigrant rep.pdf}
}

@article{Daniel_2016,
