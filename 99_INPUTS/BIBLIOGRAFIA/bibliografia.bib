@article{Costa.Wallace_2021,
  type = {Article},
  title = {More Women Candidates: The Effects of Increased Women's Presence on Political Ambition, Efficacy, and Vote Choice},
  author = {Costa, Mia and Wallace, Isabel},
  year = 2021,
  month = jul,
  journal = {American Politics Research},
  volume = {49},
  number = {4},
  pages = {368--380},
  issn = {15523373},
  doi = {10.1177/1532673X211006386},
  abstract = {The effect of women in politics is vitally important for the study of representation, yet evidence is mixed on the extent to which women's presence influences individuals' symbolic attitudes and behaviors. We use a priming survey experiment to examine how information about increased women candidates in the U.S. affects political ambition, efficacy, and future support for women candidates. We present several different patterns across gender and partisanship. Republicans report higher political ambition after hearing about more women candidates, even when those women are running for the opposite party. Men had higher political efficacy in response to more same-party women running, but not opposite-party women. Importantly, our evidence does not support the widespread notion that women's presence positively influences women's political efficacy or likelihood to vote for female candidates. The findings highlight the importance of considering the effects of women's presence not only for the group that is assumed to benefit.},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03Continente: America,04Pais: EEUU,1Concepto evaluado: efecto mensajes de campana en la ambicion politica segun genero,1Diseno experimental: control grupos aleatoriedad,1Diseno experimental: distintos sujetos,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Tipo de experimento: laboratorio/online,1Tratamiento: antes del experimento "numero de mujeres que legan al Congreso". Basico  [] republicano[ cae el numero de mujeres republicanas en el congreso y democratas alcanzan record],1Tratamiento: antes del experimento se muestra frase "mas mujeres [] participando en elecciones que en el pasado  (control: sin tratamiento neutral [] [democratas] [republicanas]),2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Panel: Lucid-> Cint,2Participantes: adultos,2Plataforma experimental: Qualtrics,2Poblacion: adultos,Amenaza de percibida por genero,Apoyo futuro a mujeres candidatas,Base documental: NO,Brecha de genero,descriptive representation,Eficacia Politica,gender,political efficacy,Representacion descriptiva,Representacion simbolica,survey experiment,symbolic representation,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
