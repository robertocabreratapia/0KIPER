@incollection{Walenta-Bergmann_2022,
  title = {Ideology, {{Trust}} and {{Autonomy}}: {{Differences Between Elected Politicians}} and {{All Other Participants}} of {{Local State-Society Networks}}},
  booktitle = {Palgrave {{Stud}}. {{Sub Natl}}. {{Govern}}.},
  author = {{Walenta-Bergmann}, C.},
