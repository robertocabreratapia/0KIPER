@article{Engstrom.Oconnor_1977,
  title = {State Centralization versus Home Rule: {{A}} Note on Ambition Theory's Powers Proposition},
  author = {Engstrom, R.L. and O'connor, P.F.},
  year = 1977,
  journal = {Political Research Quarterly},
  volume = {30},
  number = {2},
  pages = {288--294},
  doi = {10.1177/106591297703000209},
  abstract = {The powers proposition from ambition theory is an extremely important proposition, for it may be of assistance in accounting for the differential powers and responsibilities associated with varying levels of government, and the various offices and institutions within those levels. Previous examinations of the proposition, utilizing different measures and different issues, have been inconsistent. Prewitt and Nowlin found city councilmen with ambitions toward regional and state government positions to express attitudes more favorable to the expansion of authority at those levels. Thompson, however, found no evidence of extensive behavioral efforts to increase the power of the legislature among constitutional convention delegates who subsequently sought positions or otherwise served within that institution. This research provides another, and we believe more appropriate, test of the proposition. Also utilizing a constituent assembly, it examines behavioral support for home rule - an issue involving the apportionment of authority largely void of other specific policy referents. We have found that differential commitments to local or state ofhces are related to support and opposition to home rule. Statedirected delegates were especially resistant to this delegation of authority, while locally directed delegates were supportive, although to a less impressive extent. The impact of this commitment withstood a control for another highly related variable, the self-identified political philosophies of the convention delegates. The results of this analysis could be interpreted as suggestive that the proposition may be more significant in situations involving the withdrawal rather than the acquisition of power or authority. Certainly, the results offer sufhciently encouraging support for the proposition to argue that increased attention, utilizing different institutional a.nd/or regime settings, be devoted to it. \copyright{} 1977, Sage Publications. All rights reserved.},
  affiliation = {University of New Orleans, United States; Louisiana State University, United States},
  document_type = {Article},
  source = {Scopus},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,042Estado: Luisiana,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: mix,0Cargo: Constituyente,0Division funcional: constituyente,0Division territorial: subnacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Base de datos: propia,1Concepto evaluado: el efecto de la ambicion politica en el fortalecimiento de cargos a los que se espera postular ("power proposition"),1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en la unidad,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,2022-Scopus,2024-Scopus,2Muestra: miembros de un organo constituyente estatal,2Poblacion: miembros de un organo constituyente,Autonomia local (home rule),Base documental: SI,Convencion constitucional,Division de poderes local-estatal,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {0 citations (Crossref) [2024-05-14]},
