@article{Agarwalla.etal_2020,
  title = {Role of Municipal Councillors in the Implementation of Social Protection Schemes for Children---{{A}} Case of {{Ahmedabad}}, {{India}}},
  author = {Agarwalla, A. and Sarin, A. and Gupta, I.},
  year = 2020,
  journal = {Journal of Public Affairs},
  volume = {20},
  number = {2},
  doi = {10.1002/pa.2018},
  abstract = {The 74th constitutional amendment paved the path for strengthening of local governments in India, by devolution of functional and financial powers. The elected local representatives (municipal councillors), as the closest link of the Government to the citizenry, are expected to be the bearers of information regarding the needs and priorities of the people they represent. They can become the champions for effective implementation of service delivery schemes designed locally or at higher levels of governance. This study examines the designated and perceived roles of municipal councillors in the context of the implementation of social protection schemes for children in the city of Ahmedabad. Based on the information collected through personal interviews with a sample of 18 municipal councillors over 4 months, the study brings out the stark absence of designated roles for councillors and the limited perceived role in information dissemination. Councillors' political ambition, experience, and access to the executive machinery come out to be the most critical determinants of the effectiveness of limited mediation role played by councillors to ensure faster delivery of benefits or inclusion of beneficiaries. The need for institutional strengthening and capacity building at the local level also gets substantiated by the analysis. \copyright{} 2019 John Wiley \& Sons, Ltd.},
  affiliation = {Adani Institute of Infrastructure Management, Ahmedabad, 382421, India; Indian Institute of Management, Ahmedabad, Vastrapur, Ahmedabad, 380015, India},
  art_number = {e2018},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Politica Economica-Social,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/989W8HT5/Agarwalla et al. - 2020 - Role of municipal councillors in the implementation of social protection schemes for children—A case.pdf}
}

@article{Agarwalla.etal_2020a,
  title = {Foot-March: {{Large-scale}} Mobilization for a Public Cause or a Tool for Fanning Political Ambition},
  author = {Agarwalla, A. and Gupta, I. and Sarin, A.},
  year = 2020,
  journal = {Journal of Public Affairs},
  volume = {20},
  number = {2},
  doi = {10.1002/pa.1895},
  abstract = {We present the case of an awareness campaign, strategically crafted by a local student political leader, based on a national level policy for urban poor and marginalized, in the city of Ahmedabad in India. The campaign, designed in the form of a foot-march, was aimed at mobilizing the urban poor, but with a clear ambition of gaining visibility for political mileage. This study reinforces that the mediation role taken up by local leaders transcends the traditional policymaking, in democracies with blurred boundaries between the state and citizens. Further, in local governance structures, with weak participatory spaces for the poor, foot-marches have the potential to become an extended invited participatory space. \copyright{} 2019 John Wiley \& Sons, Ltd.},
  affiliation = {Economics and Public Policy Area, Adani Institute of Infrastructure Management, Ahmedabad, India; Public Systems Group, Indian Institute of Management Ahmedabad, Ahmedabad, India},
  art_number = {e1895},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/H9Y4RPQ8/Agarwalla et al. - 2020 - Foot-march Large-scale mobilization for a public cause or a tool for fanning political ambition.pdf}
}

@article{Aguilar_2013,
  title = {The {{European}} Security and Justice Legislator after the {{Lisbon Treaty}}: {{Progress}} toward the Criminal Judicial: {{Cooperation}} in the {{EU}}},
  author = {Aguilar, J.F.L.},
  year = 2013,
  journal = {Teoria y Realidad Constitucional},
  volume = {32},
  number = {2},
  pages = {179--204},
  abstract = {The European approximation and/or harmonization in both criminal matters and criminal procedure legislation got started not so long ago: As a matter of fact, until recently, it all seemed a voluntary exercise of wishful thinking, in as much as it was making on a field so far preserved within the traditional realm of States' sovereignty. The final incorporation of criminal law and criminal judicial cooperation to the sphere of European policy is an outstanding example of the european construction towards areas and competences that had been historically monopolised by national legislators. Indeed, the limitations in this matter of the intergovernmental cooperation in the Third Pillar that emerged with the entry into force of the TEU in 1992, after its conversion into the Area of Freedom, Security and Justice in the subsequent Treaty Amsterdam 1999, have been just recently overcome. Accordingly, some most important Framework Decisions (FD) meaning significant steps in the area of judicial cooperation were taken, through the implementation of specific measures on European security against serious cross-border crime by means of judicial cooperation in criminal matters. The conversion of the Area of Freedom, Security and Justice is a genuine European policy subject to the ordinary legislative procedure (with some specialties) after the Treaty of Lisbon in 2009, together with the projection of the Charter of Fundamental Rights of the EU (i.e., of the principles of legal certainty, of <<proportionality>> and <<necessity>> and/or <<subsidiarity>> in the articulation and application of criminal law) are now, in fact, the most visible expression of the EU's political ambition and constitutional dimension.},
  affiliation = {Universidad de las Palmas de Gran Canaria, Spain},
  author_keywords = {Criminal judicial cooperation; European union; Fundamental rights; Intergovernmental cooperation},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Criminal judicial cooperation,European union,Fundamental rights,Intergovernmental cooperation,Relaciones Internacionales,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Ahedo_2022,
  title = {Giovanni {{Sartori}} (2011). {{C\'omo}} Hacer Ciencia Pol\'itica. {{L\'ogica}}, M\'etodo y Lenguaje En Las Ciencias Sociales. {{Madrid}}: {{Taurus}}},
  shorttitle = {Giovanni {{Sartori}} (2011). {{C\'omo}} Hacer Ciencia Pol\'itica. {{L\'ogica}}, M\'etodo y Lenguaje En Las Ciencias Sociales. {{Madrid}}},
  author = {Ahedo, Unai},
  year = 2022,
  month = jun,
  journal = {Inguruak. Revista Vasca de Sociolog\'ia y Ciencia Pol\'itica},
  number = {72},
  pages = {76},
  issn = {0214-7912},
  doi = {10.18543/inguruak.221},
  urldate = {2024-06-21},
  abstract = {{$<$}p{$>$}En esta obra, el polit\'ologo italiano Giovanni Sartori nos insiste en la necesidad que tenemos en las ciencias sociales de contar con conceptos, t\'erminos y categor\'ias con un significado ampliamente consensuado, claro y preciso. Para el autor, contar con un lenguaje propio y especializado constituye el pilar sobre el que se debe asentar toda disciplina cient\'ifica. Por tanto, antes de optar por el ``ll\'amalo como quieras'' o de ahogarnos en un mar de datos, polit\'ologos y soci\'ologos debemos tratar de determinar sobre qu\'e estamos hablando. Solo as\'i podremos avanzar como disciplinas cient\'ificas.{$<$}/p{$>$}},
  copyright = {http://creativecommons.org/licenses/by-nc-nd/4.0},
  keywords = {Revisado},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/7VL8CY9A/Ahedo_2022_Giovanni Sartori (2011).pdf}
}

@article{Ahedo_2023,
  title = {Populismo, Un Concepto y Una Palabra Controvertida},
  author = {Ahedo, Unai},
  year = 2023,
  month = jun,
  journal = {RIPS: Revista de Investigaciones Pol\'iticas y Sociol\'ogicas},
  volume = {22},
  number = {1},
  issn = {2255-5986, 1577-239X},
  doi = {10.15304/rips.22.1.8278},
  urldate = {2024-06-21},
  abstract = {Populismo es una palabra ambigua y confusa, que genera un ardoroso debate como concepto, pero, tambi\'en como t\'ermino. En este art\'iculo nuestra pretensi\'on es la de profundizar en el status controvertido del populismo como elemento integrante del vocabulario de las ciencias sociales. En primer lugar, profundizaremos en las problem\'aticas y ambig\"uedades que surgen de su uso com\'un, de su uso banal, de su uso en la pugna pol\'itica y partidista diaria. En segundo lugar, indagaremos en los obst\'aculos que se nos plantean en su uso especializado o acad\'emico. Por un lado, debido a la fragmentaci\'on y escasa acumulabilidad de las teor\'ias existentes. Y, por otro lado, debido a la extendida pr\'actica de creaci\'on de neologismos y el empleo de sin\'onimos que encajen con el significado que se otorga al fen\'omeno populista. Este repaso por lo problem\'atico del populismo nos situar\'a inmediatamente en el debate sobre su validez y utilidad como categor\'ia anal\'itica de las ciencias sociales. Una discusi\'on que nos situar\'a ante la disyuntiva de desterrar el t\'ermino del vocabulario cient\'ifico o proseguir en la tarea de encontrar alg\'un tipo de definici\'on. En definitiva, en la compresi\'on del complejo e intricado fen\'omeno populista.},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/5EH3QPAT/Ahedo_2023_Populismo, un concepto y una palabra controvertida.pdf}
}

@article{Akbarzadeh.etal_2020,
  title = {The {{Iranian Kurds}}' Transnational Links: Impacts on Mobilization and Political Ambitions},
  author = {Akbarzadeh, S. and Laoutides, C. and Gourlay, W. and Shahab Ahmed, Z.},
  year = 2020,
  journal = {Ethnic and Racial Studies},
  volume = {43},
  number = {12},
  pages = {2275--2294},
  doi = {10.1080/01419870.2019.1689280},
  abstract = {This paper examines the impact that cross-border contacts and ideals of transnational Kurdish community have on Kurds in Iran. Incorporating survey and interview data from Iranian Kurdish academics, journalists and activists, it analyses how events in the broader Kurdistan region, and the notion of Kurdayet\^i--pan-Kurdish identity--are perceived by Kurds and how these phenomena affect the Kurdish issue. Within the context of long-standing political grievances, the findings highlight an atmosphere of distrust pervading the relationship between the Islamic Republic of Iran and its Kurds, and reveals that as Kurds find it difficult to identify with the Iranian state they turn towards their cross-border ethnic kin. Yet, despite increasing cross-border interaction and recent advances for Syrian and Iraqi Kurds, internal and external dynamics curtail Iranian Kurds' political ambitions and preclude secessionist impulses. \copyright{} 2019 Informa UK Limited, trading as Taylor \& Francis Group.},
  affiliation = {Alfred Deakin Institute, Deakin University, Melbourne, Australia},
  author_keywords = {ethnicity; Iran; Kurdish identity; Kurds; secession; transnational links},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,cross-border relations,ethnicity,ethnopolitics,geopolitics,international relations,Iran,Iraq,Kordestan [Iran],Kurdish identity,Kurdistan [Iraq],Kurds,political relations,political system,Relaciones Internacionales,secession,Syrian Arab Republic,transnational links,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/8BYF3A76/Akbarzadeh et al. - 2020 - The Iranian Kurds’ transnational links impacts on mobilization and political ambitions.pdf}
}

@article{Aksoy_2012,
  title = {Riding the Storm: 'New Istanbul'},
  author = {Aksoy, A.},
  year = 2012,
  journal = {City},
  volume = {16},
  number = {1-2},
  pages = {93--111},
  doi = {10.1080/13604813.2012.662373},
  abstract = {Istanbul is faced with a fundamental dilemma: on the one hand, there is the logic of globalizing the city that is animated and driven by a top-down political ambition; with its drive for wealth creation and increase in the standard of living, for some of its inhabitants at least, through producing the city as a real-estate proposition. And, on the other, there is the principle of the public city with its concern over the common good-inclusive citizenship, the ecological profile, the historic identity and public culture of Istanbul. As the city is colonized by the logic of real-estate-driven growth, becoming globally open, it is losing another kind of openness-the kind of openness that has allowed citizens of all kinds to coexist, and allowed disadvantaged, marginal and incoming migrant communities to survive and make a space for themselves in the city. As Istanbul now becomes a megacity on the trajectory of becoming a regional powerhouse, composed of a fragmentary landscape of gated communities, residential complexes, recreational zones and tourist areas, it ceases to be a real city. Historic districts take their toll in this process, becoming, mono-functional, and in fact, dead spaces. The challenge for civic actors in Istanbul is to negotiate an argument for the public city to survive. The only way for the public city argument to make any headway today is to take into account the fact that the growth-based politics has a popular appeal and support. What is needed is a new kind of critical politics that is able to manage and steer the real-estate-based growth for the public city argument. This is no less a challenge than one of finding a way to ride the storm that is caused by the 'new Istanbul'. \copyright{} 2012 Copyright Taylor and Francis Group, LLC.},
  affiliation = {Cultural Policy and Management Research Centre (KPY), Istanbul Bilgi University, Turkey},
  author_keywords = {civic actors; European Capital of Culture; globalization; heritage policies; historic neighbourhoods; Istanbul; urban regeneration},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,civic actors,European Capital of Culture,globalization,heritage policies,historic neighbourhoods,Istanbul,Politica Economica-Social,urban regeneration,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/RBJ4L2TM/Aksoy - 2012 - Riding the storm 'new istanbul'.pdf}
}

@article{Al-Absi.Al-Absiova_2014,
  title = {Gypsies in the Middle East in Past and Present Contexts},
  author = {{Al-Absi}, M. and {Al-Absiov{\'a}}, E.},
  year = 2014,
  journal = {Annual of Language and Politics and Politics of Identity},
  volume = {8},
  number = {1},
  pages = {79--92},
  abstract = {The article deals with Gypsy issues in the territory of the Middle East. The authors analyse selected contexts of ethno-linguistic, socio-cultural and socio-political identity of the Middle Eastern Gypsy communities with emphasis on Syria and Iraq. They also describe the historical background of the topic, necessary for understanding the current situation of Gypsies in Arab society. Gypsy communities living in the Middle Eastern countries are scattered throughout the ethnically and religiously distinct population of the region. In the host country they are often marginalized and conflicts tend to break out between them and the majority population. Gypsies are not involved in political decision-making processes and have no opportunities to apply for their rights as an ethnic minority. They cannot develop their language and culture and, consequently, their political ambitions. Long-term conflicts in the Middle East hinder the improvement of the status of the Gypsies in Arab society. The authors draw on Western and Arab sources and they also rely on their own experience, gained during their ten-year stay in Syria, and on information from interviews with Syrian Gypsies and Iraqi refugees. \copyright{} 2014 Institute of Political Studies. All rights reserved.},
  affiliation = {Department of Management of Culture and Tourism, Constantine the Philosopher University, Nitra, Slovakia; Constantine the Philosopher University, Nitra, Slovakia},
  author_keywords = {Cultural traditions of Gypsies; Dom of the Middle East; Gypsies of the Middle East; Gypsy dialects; Gypsy language; Political status of Gypsies; Social status of Gypsies},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Cultural traditions of Gypsies,Dom of the Middle East,Gypsies of the Middle East,Gypsy dialects,Gypsy language,Political status of Gypsies,Social status of Gypsies,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

