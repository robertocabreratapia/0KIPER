@article{Martinez_2011,
  title = {{Political Ambition and Loyalty: Influence on Political Behavior}},
  author = {Mart{\'i}nez, Mar{\'i}a del Mar},
  year = 2011,
  journal = {Pol\'itica y Gobierno},
  volume = {18},
  number = {2},
  pages = {231--264},
  issn = {1665-2037},
  abstract = {The objective of this article was to analyze the influence that political contexts and political careers exert on the behavior of legislators, through the use of the Elites Parlamentarias Latinoamericanas (PELA) database of the Universidad de Salamanca, which centers on three Central American countries: Costa Rica, El Salvador and Honduras. Relying on a theoretical division between retrospective and prospective loyalties, the results suggest that the behavior of lawmakers is influenced by their future job prospects. This influence becomes clear when the aspect being evaluated is exclusive, namely, when it does not allow legislators to cultivate loyalties that would secure their professional future without damaging their retrospective loyalties. When political parties control the continuity of political careers, the percentage of lawmakers who place the interests of their districts above the interests of their party is greater among those not seeking to continue their political careers than among those who wish to remain in politics.},
  langid = {spanish},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,041Multipais: Costa Rica,041Multipais: El Salvador,041Multipais: Honduras,04Pais_sigla: MUL,04Pais: multipais,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: unicameral,0Organizacion territorial: unitario,1Concepto evaluado: efecto de la ambicion politica y la lealtad partidaria (retroactiva y prospectiva) en el comportamiento legislativo,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring combinacion: cross-sectional,1Gerring variacion espacial: si entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre unidades,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Poblacion: legisladores de paises unicamerales y con restricciones a la reeleccion,1Tipo de experimento: no aplica,1Unidad de analisis: individuo-legislatura,2022-Scopus,2022-WoS,2024-CLASE,2024-Scielo,2024-Scopus,2024-WoS,2Muestra: legisladores de 3 paises latinoamericanos,Ambition,Base documental: SI,Behavior,Central America,Encuesta: PELA,Lealtad partidaria,Lealtad prospectiva,Lealtad retroactiva,Political career,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
