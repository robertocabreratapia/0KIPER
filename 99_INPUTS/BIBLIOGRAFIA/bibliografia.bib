  issn = {15523373},
  doi = {10.1177/1532673X211013479},
  abstract = {Theoretically, political ambitions paired with elections generate more responsive elected officials. In this paper, we test whether the progressive political ambitions of public officials affect whether and how they respond to their constituents by conducting a experimental audit study where local public officials receive both an electorally related service request and a generic service request. We combine their responses (or non-responses) with data from a survey of these public officials conducted months prior about their political ambition in seeking higher office. On the whole, we find that politically ambitious officials are not more responsive to electorally oriented service requests and that there are not systematic differences in the content of the responses of ambitious and non-ambitious elected officials. In areas of constituency service, ambition does not seem to affect representational behavior, regardless of whether the service requests are electorally related or not.},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,01Diseno investigacion: experimental,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Mix var_cargo,0Division funcional: mix,0Division territorial: local,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: representacion politica y servicio al electorado,1Diseno experimental: control grupos aleatoriedad,1Diseno experimental: distintos sujetos,1Empirico: experimental,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Gerring variacion espacial: no,1Gerring variacion temporal: n/a,1Gerring2 variacion unidad/individuo: n/a,1Metodologia: experimental,1No experimental: no aplica,1NoExperimental_Tecnicas: no aplica,1Tipo de experimento: campo (interaccion en mundo real),1Tratamiento: correo solicitando informacion electoral (registro en censo electoral) o no electoral (reciclaje).,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: cargos locales electos,2Panel: no,2Plataforma experimental: no,2Poblacion: cargos electos,Base documental: SI,Cargo: mix cargos locales,constituency service,Experimento,political ambition,Representacion politica,representation,Servicio al electorado,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {3 citations (Crossref) [2024-05-14]},
