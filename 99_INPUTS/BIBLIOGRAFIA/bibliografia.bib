@incollection{Aniche.Oji_2022,
  title = {Ethno-Political {{Organisations}} as {{Political Pressure Groups}} in {{Nigeria}}},
  booktitle = {Anonymous {{Power}}: {{Parties}}, {{Interest Groups}} and {{Politics}} of {{Decision Mak}}. in {{Nigeria}}'s {{Fourth Republic}} ({{Essays}} in {{Honour}} of {{Elochukwu Amucheazi}})},
  author = {Aniche, E.T. and Oji, O.R.},
  year = 2022,
  pages = {75--99},
  publisher = {Springer Nature},
  doi = {10.1007/978-981-16-6058-0_5},
  abstract = {The emergence of ethno-political organisations pre-dated Nigerian independence and democracy. Most pre-independence political parties in Nigeria were simply transformations or metamorphoses of ethno-political organisations. As a colonial heritage, this trend continued after independence to the extent that some of the political parties in the Second and Fourth Republics were transmutations of ethnic political organisations. Some of these ethno-political organisations-having evolved into formidable ethnic pressure groups-in some cases entered into strong political affiliation or alliance with political parties in order to achieve political aspirations of their members. Perhaps, the colonial legacy of this trajectory is underscored by the fact that the ethnic political organisations are still deeply involved in mobilising support of their ethnic groups for political parties during elections in Nigeria's Fourth Republic. Thus, ethno-political organisations like Ohaneze Ndigbo, Afenifere, Arewa Consultative Forum, Ijaw National Congress and Middle Belt Forum, have become political platforms used by the political class for playing the ethnic cards so as to capture political power. Some of these aforementioned ethno-political organisations have historically expressed and defended divergent views on the current fiscal and structural arrangements of the Nigerian federation. However, some groups of politicians have taken advantage of these divergent interests to hijack the struggles among these ethno-political organisations to further their political ambitions. This has led to the increasing non-formalisation of decision-making in Nigeria. The implication being that the pendulum of decision-making in Nigeria has tilted towards non-formal sectional networks where individual and sectional interests have torpedoed public interests in policy-making. The intense competition between these leaders of ethno-political organisations to control democratic decision-making architecture and the resultant increasing non-formalisation of decision-making have not deepened Nigerian democracy. \copyright{} The Editor(s) (if applicable) and The Author(s), under exclusive licence to Springer Nature Singapore Pte Ltd. 2022.},
  isbn = {978-981166058-0 (ISBN); 978-981166057-3 (ISBN)},
  langid = {english},
  keywords = {2024 STATUS: Pendiente de procesar,2024-Scopus,democracy,Ethnic /organisations,Nigerian federalism,policy process,political parties,pressure groups,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/GZHMCB23/Aniche y Oji - 2022 - Ethno-political Organisations as Political Pressure Groups in Nigeria.pdf}
}

