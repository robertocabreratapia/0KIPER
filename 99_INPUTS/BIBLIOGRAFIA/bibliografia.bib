@article{Sapiro.Farah_1980,
  title = {New Pride and Old Prejudice: {{Political}} Ambition and Role Orientations among Female Partisan Elites},
  author = {Sapiro, V. and Farah, B.G.},
  year = 1980,
  journal = {Women and Politics},
  volume = {1},
  number = {1},
  pages = {13--36},
  doi = {10.1300/J014v01n01_02},
  abstract = {The determinants of women's political orientations are explored in terms of two perspectives: Ambition and gender role and their interrelationship. A sample of 1336 Democratic and Republican delegates to the 1972 national nominating conventions was used to compare the political expectations and aspirations of men and women. Women were found tohave less interest in holding public officebut equalled men in aspiring to party careers. Party as well as sex differences affected the political ambitions of female elites, with Democratic women more likely to pursue public office holding and Republican women remaining committed to the party sphere. Women's roles in the family and at work were also found to influence the development of political ambition among women. In addition, gender roles had an impact on the type of ambition women developed and the styles of activism they pursued. \copyright{} 1980 Taylor \& Francis Group, LLC.},
  affiliation = {University of Wisconsin, Madison, United States; University of Michigan, United States},
  document_type = {Article},
  source = {Scopus},
  keywords = {00Ambicion Politica: intrainstitucional,00Ambicion Politica: no incumbentes,2022-Scopus,2024-Scopus,Base documental: NO,Brecha,Brecha de genero,Delegados a convencion partidaria,Militantes de partido,Partidos Politicos,Roles familiares,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
