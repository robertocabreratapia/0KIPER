@article{Hoyland.etal_2019,
  type = {Article},
  title = {Career Ambitions and Legislative Participation: The Moderating Effect of Electoral Institutions},
  author = {Hoyland, Bjorn and Hobolt, Sara B. and Hix, Simon},
  year = 2019,
  journal = {British Journal of Political Science},
  volume = {49},
  number = {2},
  pages = {491--512},
  issn = {14692112},
  doi = {10.1017/S0007123416000697},
  abstract = {What motivates politicians to engage in legislative activities? In multilevel systems politicians may be incentivized by ambitions to advance their careers either at the state or federal level. This article argues that the design of the electoral institutions influences how politicians respond to these incentives. Analyzing a unique dataset of both 'stated' and 'realized' career ambitions of Members of the European Parliament (MEPs), it finds that those who seek to move from the European to the national (state) level participate less in legislative activities than those who plan to stay at the European (federal) level. For MEPs who aim to move to the state level, attendance and participation in legislative activities is substantively lower among legislators from candidate-centered systems. Importantly, the effect of career ambitions on legislative participation is stronger in candidate-centered systems than in party-centered systems. These findings suggest that the responsiveness associated with candidate-centered systems comes at the expense of legislative activity.},
  keywords = {00Ambicion como variable: independiente,00Ambicion como variable: realizada,00Ambicion Politica: declarada,00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03Continente: Europa,04Pais_sigla: UEE,04Pais: Union Europea,0Cargo electo: si,0Cargo: Europarlamentario,0Division funcional: legislativo,0Division territorial: supranacional,0Forma Gobierno: parlamentario,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto del sistema electoral (foco candidato/partido) en el comportamiento legislativo (participacion) en funcion de ambicion politica del candidato,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: no,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: corte transversal y longitudinal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individuo-legislatura,2022-WoS,2024-WoS,ambition,Base documental: SI,careers,Cuestionario ambicion,electoral systems,European Parliament,legislative participation,Medicion: ambicion declarada encuestas,Medicion: ambicion realizada base de datos,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {21 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/H7RIZAWU/Hoyland et al. - 2019 - Career ambitions and legislative participation th.pdf}
