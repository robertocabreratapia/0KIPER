@article{Hakansson.Grahn_2025,
  title = {The {{Cost}} of {{Debating Harassment Against Politicians}}: {{Are Women}} and {{Men Affected Equally}}?},
  author = {H{\aa}kansson, S. and Grahn, M.},
  year = 2025,
  journal = {Political Behavior},
  publisher = {Springer},
  issn = {15736687 (ISSN); 01909320 (ISSN)},
  doi = {10.1007/s11109-025-10039-1},
  abstract = {Harassment of politicians is a growing global phenomenon, which threatens to erode the quality of democracy and descriptive representation. Past research has examined gender patterns of this violence and its effects on political ambition. We investigate the impact of political harassment on candidate appeal in Sweden, using a multimethod approach. First, a qualitative content analysis demonstrates that Swedish news stories where politicians comment on harassment against politicians often include weakness signals such as being fearful or worried. Second, we use an original conjoint experiment with 1,300 party selectors from six Swedish parties. This analysis shows that commenting on political violence in the media has an adverse effect on candidate appeal, likely because doing so activates politically undesirable images of victimhood. We also find that being associated with the issue is equally damaging to women's and men's political careers. Lastly, we conduct in-depth interviews with Swedish party selectors. These further illustrate that addressing this issue is perceived as deviating from the assertive model of a politician and that political violence is not regarded as a vote-winning issue. As a whole, our results demonstrate that publicly addressing the problem of violence against politicians can harm political careers and thus deter politicians from drawing policy attention to the issue. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {american},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: mix incumbentes y no incumbentes,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: mix experimental y no experimental,03Continente: Europa,04Pais_sigla: SWE,0Cargo electo: no aplica,0Cargo: PENDIENTE,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: parlamentario,0Organizacion legislativo: unicameral,0Organizacion territorial: unitario,1Diseno experimental: distintos sujetos,1Gerring variacion espacial: no,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: unidades e individuos,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1NoExperimental_Tecnicas: entrevista,1Tipo de experimento: laboratorio/online,Candidate recruitment,Conjoint experiment,Gender,Sensitive issues,Sweden,Violence against politicians,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/PRTVXB8E/Håkansson y Grahn - 2025 - The Cost of Debating Harassment Against Politicians Are Women and Men Affected Equally.pdf}
}

