}

@article{Brouard.etal_2013,
  title = {Why Do French {{MPs}} Focus More on Constituency Work than on Parliamentary Work?},
  author = {Brouard, S. and Costa, O. and Kerrouche, E. and Schnatterer, T.},
  year = 2013,
  journal = {Journal of Legislative Studies},
  volume = {19},
  number = {2},
  pages = {141--159},
  doi = {10.1080/13572334.2013.787194},
  abstract = {The relationship between French members of the National Assembly and citizens is paradoxical. On the one hand, the French political culture, constitution and history favour a very abstract conception of representation: MPs are supposed to act as trustees and collectively to embody the French Nation. On the other hand, they are deeply involved in their constituencies and express a great level of satisfaction being there. In order to understand how French MPs reconcile the national and local dimensions of their mandate, the data gathered through face-to-face interviews with MPs are described. Then a scale analysis is provided in order to sum up the local-national orientations of the MPs. Using this scale, it is possible to test the impact of several variables on the territorial focus of MPs: Electoral incentives, political ambition, ideological factors and working conditions at the local and the national level. \copyright{} 2013 Copyright Taylor and Francis Group, LLC.},
  affiliation = {Centre Emile Durkheim, Sciences Po, University of Bordeaux, France},
  author_keywords = {attitudes; France; local; national; scale},
  document_type = {Article},
  source = {Scopus},
