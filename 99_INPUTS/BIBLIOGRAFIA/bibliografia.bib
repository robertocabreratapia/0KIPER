@article{Rodriguez-Teruel_2025,
  title = {A Dual Summit of Power? {{Career}} Movements and Multilevel Circulation in the {{Spanish}} Executive Elite},
  author = {{Rodr{\'i}guez-Teruel}, J.},
  year = 2025,
  journal = {Regional and Federal Studies},
  volume = {35},
  number = {3},
  pages = {363--389},
  publisher = {Routledge},
  issn = {13597566 (ISSN)},
  doi = {10.1080/13597566.2024.2385334},
  abstract = {Drawing from the literature on political ambition, this article examines whether politicians holding executive offices exhibit similar patterns of movement between different levels of government as parliamentary elites. It also tests the influence of various institutional and political variables typical of federal systems. Focusing on Spain, the study classifies career movements based on the initial position and the direction of advancement, analyzing their variations depending on the availability, accessibility, and attractiveness of the structure of opportunities. The article particularly aims to elucidate why certain regions are more advantaged to provide decision-makers with more opportunities to circulate across political layers. Our sample includes cabinet members (prime ministers and ministers) and regional chief executives in Spanish regions from 1980 to 2021. The findings suggest that the status of regions, the availability of parliamentary seats, and the regional party system, among other factors, contribute to understanding regional variations in opportunities for executive level-hoppers. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {Ambition,federal system,federalism,leadership,ministers,occupation,parliament,party politics,political careers,political power,presidents,regional executives,Spain,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: descartado (revision final)}
}

@article{Rogers_2021,
  title = {Federalism and the Welfare State in {{Latin America}}},
  author = {Rogers, M.},
  year = 2021,
  journal = {Regional and Federal Studies},
  volume = {31},
  number = {1},
  pages = {163--184},
  doi = {10.1080/13597566.2020.1749841},
  abstract = {Prominent accounts of federalism lament its functioning in Latin America. Instead of fiscally independent, competitive subunits holding their central governments accountable, Latin America's regions are highly dependent on central allocation. Fiscal centralization has been blamed for subnational profligacy, but has not resulted in abundant social spending or equalized opportunities across regions. Very little research considers if federalism may impact the provision of social welfare in Latin America. In this article, I relate well-known theories of federalism to the Latin American context and discuss how political dynamics of Latin American federalism may impact the welfare state. I argue that federalism exacerbates existing spatial inequalities to make welfare more uneven, interpersonally and spatially. While federalism moves resources through subnational government coffers, this money does not create robust, decentralized welfare states. Rather, federalism provides institutional mechanisms to block redistribution by central governments, and encourages politicized interregional transfers that divert resources from centralized redistribution. \copyright{} 2020 Informa UK Limited, trading as Taylor \& Francis Group.},
  affiliation = {International Studies, Claremont Graduate University, Claremont, CA, United States},
  author_keywords = {federalism; Latin America; political ambition; social welfare; spatial inequality},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,federalism,Latin America,political ambition,social welfare,spatial inequality,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/NBGNJZ5J/Rogers - 2021 - Federalism and the welfare state in Latin America.pdf}
}

