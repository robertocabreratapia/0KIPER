@article{Ma_1996,
  title = {1.2 Billion: Retrospect and Prospect of Population in {{China}}},
  author = {Ma, Jisen},
  year = 1996,
  journal = {International Social Science Journal},
  volume = {148},
  pages = {261--268},
  abstract = {This article reviews how the largest population of any country in the world passed from unchecked growth to planned control. Mao Zedong needed a large population to fulfil his political ambitions, and this led to criticism of Ma Yinchu, who advocated that China practise birth control. The Great Leap Forward resulted in three difficult years during which China lost more than 40 million lives. The subsequent unchecked growth of the population to over 900 million prompted China to implement family planning seriously from the 1970s. China has now included the population issue in its socioeconomic development project, calling on the people to give 'fewer births for more rapid improvement of welfare'. The article points out that radical measures are needed to achieve the goal of keeping the Chinese population below 1.6 billion in the year 2050.},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,birth control,China,developing country,family planning,fertility control,future prospect,population fertility,population policy,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{Macdonald_2025,
  title = {Labor {{Union Membership}} and {{Women}}'s {{Political Ambition}}: {{Evidence}} from the {{United States}}},
  author = {Macdonald, D.},
  year = 2025,
  journal = {Politics and Gender},
  publisher = {Cambridge University Press},
  issn = {1743923X (ISSN); 17439248 (ISSN)},
  doi = {10.1017/S1743923X2400045X},
  abstract = {Women have long been underrepresented in American politics. This is evidenced by women being less likely to run for and hold elected office. Existing scholarship largely focuses on explaining why women are less politically ambitious than their male counterparts but pays less attention to why some women do run for office. To this end, I focus on the potential role of labor union membership. I argue that labor unions can foster political ambition and increase ordinary people's likelihood of running for office. I test this among women in the American mass public, primarily with survey data from the 2010-22 Cooperative Election Study (CES). Overall, I find that labor union membership is significantly associated with women's likelihood of running for office. I also find that this robust relationship is unlikely to be driven by self-selection or omitted variable biases. Overall, these findings help us to better understand the sources of political ambition, illustrate a viable potential pathway to boost women's likelihood of seeking elected office, and underscore the political consequences of organized labor. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {american},
  keywords = {gender,labor unions,political ambition,running for office,United States,women,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/E9AD6548/Macdonald - 2025 - Labor Union Membership and Women's Political Ambition Evidence from the United States.pdf}
}

@article{Maestas_2003,
  title = {The {{Incentive}} to {{Listen}}: {{Progressive Ambition}}, {{Resources}}, and {{Opinion Monitoring}} among {{State Legislators}}},
  shorttitle = {The {{Incentive}} to {{Listen}}},
  author = {Maestas, Cherie D.},
  year = 2003,
  month = may,
  journal = {The Journal of Politics},
  volume = {65},
  number = {2},
  pages = {439--456},
  issn = {0022-3816, 1468-2508},
  doi = {10.1111/1468-2508.t01-3-00008},
  urldate = {2022-08-09},
  abstract = {Abstract Este art\'iculo examina c\'omo la ambici\'on pol\'itica progresiva y los recursos institucionales influyen en el comportamiento de los legisladores, espec\'ificamente en su dedicaci\'on a monitorear las opiniones de sus electores. El argumento central sostiene que los legisladores con aspiraciones a cargos superiores tienen incentivos para prestar mayor atenci\'on a las preferencias ciudadanas, y que este efecto se ve reforzado en legislaturas m\'as profesionalizadas. El marco te\'orico se basa en la tipolog\'ia de ambici\'on pol\'itica de Joseph A. Schlesinger, distinguiendo entre ambici\'on progresiva, est\'atica y discreta. El art\'iculo plantea que la ambici\'on progresiva genera un horizonte estrat\'egico de m\'ultiples elecciones, lo que incentiva a los legisladores a anticipar escenarios futuros y a construir una base de apoyo mediante la atenci\'on sistem\'atica a las preferencias del electorado. Metodol\'ogicamente, el estudio utiliza datos de encuesta a 429 legisladores de ocho estados de Estados Unidos, combinando informaci\'on sobre aspiraciones de carrera, nivel de profesionalizaci\'on legislativa y tiempo dedicado a actividades de recopilaci\'on y an\'alisis de opini\'on p\'ublica. Los resultados muestran que los legisladores con ambici\'on progresiva dedican m\'as tiempo a monitorear las opiniones de sus electores que aquellos con ambici\'on est\'atica o sin ambiciones de carrera. Adem\'as, este efecto es significativamente mayor en legislaturas con mayores recursos, lo que evidencia una interacci\'on entre motivaci\'on individual y contexto institucional. En contraste, la ambici\'on est\'atica no presenta efectos sistem\'aticos sobre este comportamiento. El art\'iculo concluye que la ambici\'on pol\'itica, en combinaci\'on con recursos institucionales, fortalece los mecanismos de representaci\'on al incentivar una mayor atenci\'on a las preferencias ciudadanas. Estos hallazgos sugieren que las legislaturas profesionalizadas pueden mejorar la conexi\'on entre representantes y electores, especialmente cuando est\'an compuestas por actores con aspiraciones de carrera.},
  langid = {english},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,0421Multiestado: Connecticut,0421Multiestado: Delaware,0421Multiestado: Florida,0421Multiestado: Massachussetts,0421Multiestado: Minesota,0421Multiestado: Oklahoma,0421Multiestado: Vermont,0421Multiestado: Wisconsin,042Estado: Federal,042Estado: multiestado,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Legislador Estatal,0Division funcional: legislativo,0Division territorial: subnacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la profesionalizacion de las legislaturas y la ambicion politica en la disposicion a escuchar al electorado,1Diseno experimental: no aplica,1Empirico: no experimental,1Encuesta: propia,1Gerring variacion espacial: si en la unidad,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individuo-profesionalizacion de legislatura,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: legisladores estatales (camara alta y camara baja),2Poblacion: Legisladores estatales,Base documental: SI,Cargo: Legislador estatal,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
