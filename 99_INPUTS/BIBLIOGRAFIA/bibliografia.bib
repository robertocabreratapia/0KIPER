  pages = {469--474},
  doi = {10.1016/S0362-3319(01)00128-8},
  abstract = {Previous research finds that political ambition affects the behavior of members of Congress. However, while this research has measured ambition as a behavior, it is best thought of as a psychology construct. Thus, the body of literature that examines the effects of ambition on legislators' behavior is suspect. This note tests the reliability of the conclusions based on this literature by measuring House members' desire for higher positions. The findings, which are based on surveys of congressional candidates, suggest that while ambition does affect behavior, its effects may be fairly small. \copyright{} 2001 Elsevier Science Inc.},
