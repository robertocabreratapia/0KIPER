  author = {Holmes, J. and Yoshihara, T. and Winner, A.},
  year = 2006,
  journal = {Defense and Security Analysis},
  volume = {22},
  number = {1},
  pages = {5--21},
  doi = {10.1080/14751790600577074},
  abstract = {The Proliferation Security Initiative (PSI) is an information consortium of 15 seafaring nations that are committed to interdict dangerous technologies on their land, around their territorial waters and in their airspace. The emphasis is on combating terrorism, but its implications go well beyond that narrower objective. It is argued that the PRC, which to date has remained aloof, would be an important addition to the initiative. Analyzing China's own geo-political ambitions, PSI is judged inimical. However it is argued that the US should do all it can, through diplomacy, to accommodate China's legitimate interests with the future of the PSI primarily in mind.},
  affiliation = {Center for International Trade and Security, University of Georgia, 120 Holmes/Hunter, Athens, GA 30602, United States; US Air War College, 325 Chennault Circle, Maxwell Air Force Base, AL 36112, United States; Strategic Research Department, US Naval War College, 686 Cushing Road, Newport, RI 02841, United States},
