@article{Basabe_2018,
  type = {Article},
  title = {Discrete Legislative Careers under Weak Party Institutionalization: A Theoretical Proposal and Empirical Evidence Applied to the Ecuadorian Legislature, 1979-2007},
  author = {Basabe, Santiago},
  year = 2018,
  month = apr,
  journal = {Revista de Ciencia Pol\'itica},
  volume = {38},
