@article{Meserve.etal_2009,
  type = {Article},
  title = {Political Ambition and Legislative Behavior in the European Parliament},
  author = {Meserve, Stephen A. and Pemstein, Daniel and Bernhard, William T.},
  year = 2009,
  month = jul,
  journal = {Journal of Politics},
  volume = {71},
  number = {3},
  pages = {1015--1032},
  issn = {00223816},
  doi = {10.1017/S0022381609090859},
  abstract = {Members of the European Parliament (MEPs) typically follow one of two career paths, either advancing within the European Parliament itself or returning to higher offices in their home states. We argue that these different ambitions condition legislative behavior. Specifically, MEPs seeking domestic careers defect from group leadership votes more frequently and oppose legislation that expands the purview of supranational institutions. We show how individual, domestic-party, and national-level variables shape the careers available to MEPs and, in turn, their voting choices. To test the argument, we analyze MEPs roll-call voting behavior in the 5th session of the EP (19992004) using a random effects model that captures idiosyncrasies in voting behavior across both individual MEPs and specific roll-call votes. \copyright{} 2009 Southern Political Science Association.},
