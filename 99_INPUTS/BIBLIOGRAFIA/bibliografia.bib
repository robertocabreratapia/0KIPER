@article{Coffe.Davidson-Schmich_2020,
  title = {The Gendered Political Ambition Cycle in Mixed-Member Electoral Systems},
  author = {Coff{\'e}, H. and {Davidson-Schmich}, L.K.},
  year = 2020,
  journal = {European Journal of Politics and Gender},
  volume = {3},
