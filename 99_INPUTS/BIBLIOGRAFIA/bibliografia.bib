@article{Samuels_2000,
  type = {Article},
  title = {Ambition and Competition: Explaining Legislative Turnover in Brazil},
  author = {Samuels, David},
  year = 2000,
  journal = {Legislative Studies Quarterly},
  volume = {25},
  number = {3},
  pages = {481--497},
  issn = {03629805},
  doi = {10.2307/440417},
  abstract = {50\% of Brazilian incumbent legislators fail to be reelected to their seat, which is weird given that rules seem to encourage incumbency. Two factors explain this puzzle: political ambition, because legislators want to run for higher office (this covers 25\% of the non-reelected legislators) and electoral competition (which accounts for another 25\%). Electoral competition makes reelection harder because: a) the strong candidates leave for higher office, therefore leaving a pool of weak incumbents, 2) strong challenger enter easily because of very open nomination procedures for candidates, and c) the ballot system of at-large, open-list PR undermines the ability of incumbents to protect their status. Thus, Brazilian incumbents are simply unable to ''scare the competition''. (Incidentally, party switching by incumbents is not, according to Samuels, the result of legislators looking for a closer match with their ideologies, but rather the result of having weak electoral positions in their own state).},
  keywords = {00Ambicion Politica: efectos,00Ambicion Politica: extra-legislativa,00Ambicion Politica: incumbentes,00Ambicion Politica: regresiva,00Causas: efecto del contexto institucional,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03Continente: America,04Pais_sigla: BRA,04Pais: Brasil,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado:  estudia la relacion entre ambicion politica dinamica de la competencia electoral y estructura de oportunidades politicas en Brasil.,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unida de analisisis: individuo-legislatura,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: legisladores federales,2Poblacion: legisladores federales,Base documental: SI,Camara Baja,IMPRESO,Reelecion,Teoria de la Ambicion Politica,TEST-BORRAR,Var,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {56 citations (Crossref) [2024-05-14]},
