}

@article{Holman.Schneider_2018,
  type = {Article},
  title = {Gender, Race, and Political Ambition: How Intersectionality and Frames Influence Interest in Political Office},
  author = {Holman, Mirya R. and Schneider, Monica C.},
  year = 2018,
  month = apr,
  journal = {Politics, Groups, and Identities},
  volume = {6},
  number = {2},
  pages = {264--280},
  issn = {2156-5503},
  doi = {10.1080/21565503.2016.1208105},
  abstract = {Political institutions in the U.S. continue to be dominated by men. Media and scholarly accounts often focus on how demand factors, such as political parties and elite networks, and supply factors, such as women's self-confidence and political interest, combine to depress women's representation. Yet, we know little about whether these narratives matter for women's political ambition or how they might influence women of color. We demonstrate that blaming women's underrepresentation on supply vs. demand causes clear changes in women's political ambition. Attributing women's lack of parity to demand factors allows white and Asian women to ``discount'' the possibility that failure rests on their own abilities, thus increasing women's political ambition. Alternatively, framing women's underrepresentation as due to supply factors depresses white and Asian women's political ambition possibly because of stereotype threat. Black women respond in an opposite manner, with depressed political ambition in demand...},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03Continente: America,04Pais: EEUU,1Concepto evaluado: efecto del framing (oferta o demanda) como causa de baja participacion de mujeres en politica en las mujeres segun raza,1Diseno experimental: control grupos aleatoriedad,1Diseno experimental: distintos sujetos,1Empirico: experimental,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Tipo de experimento: laboratorio/online,1Tratamiento: mensaje con explicaciones sobre baja  de mujeres en cargos electos (oferta o demanda),2022-WoS,2024-WoS,2Panel: mTurk,2Participantes: estudiantes y graduados universitarios,2Plataforma experimental: Qualtrics,2Poblacion: adultos,Base documental: NO,Brecha de genero,Brecha racial,Interseccionalidad,Modelo de oferta y demanda de representacion,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/IIBSYK3W/Holman y Schneider - 2018 - Gender, race, and political ambition how intersec.pdf}
}

@article{Holmegaard.etal_2017,
  title = {Why Should {{European}} Higher Education Care about the Retention of Non-Traditional Students?},
  author = {Holmegaard, H.T. and Madsen, L.M. and Ulriksen, L.},
  year = 2017,
  journal = {European Educational Research Journal},
  volume = {16},
  number = {1},
  pages = {3--11},
  doi = {10.1177/1474904116683688},
  abstract = {Equal access to higher education has for long been a political ambition, however, despite the expansion of the number of students now entering higher education it has not yet been achieved. The present special issue offers insights into the encounter between students from non-traditional backgrounds and higher education. Five individual studies from four countries offer a unique contribution to understand non-traditional students' risk of dropping out of higher education as more than a question of academic preparation and hence individual deficits. Together the five papers display a variety of analyses of a key issue for the European Higher Education Area: attracting and retaining a wider group of students. The results show how non-traditional students across countries are made up of a complex mosaic of voices. Hence, the special issue makes a call to move away from the stereotypical images of non-traditional students, and to continue analysing the variety, the complexity and diversity of non-traditional students and their encounter with higher education. \copyright{} 2016, \copyright{} The Author(s) 2016.},
  affiliation = {University of Copenhagen, Denmark},
  author_keywords = {Bourdieu; equal access; higher education; inclusion; Non-traditional students; retention},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Bourdieu,equal access,higher education,inclusion,Non-traditional students,retention,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/5K222AMV/Holmegaard et al_2017_Why should European higher education care about the retention of.pdf}
}

@article{Holmes.etal_2006,
