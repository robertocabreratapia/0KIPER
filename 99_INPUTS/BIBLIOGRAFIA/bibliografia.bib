@article{Dhima_2022,
  title = {Do {{Elites Discriminate}} against {{Female Political Aspirants}}? {{Evidence}} from a {{Field Experiment}}},
  shorttitle = {Do {{Elites Discriminate}} against {{Female Political Aspirants}}?},
  author = {Dhima, Kostanca},
  year = 2022,
  month = mar,
  journal = {Politics \& Gender},
  volume = {18},
  number = {1},
  pages = {126--157},
  issn = {1743-923X, 1743-9248},
  doi = {10.1017/S1743923X20000227},
  urldate = {2022-08-09},
  abstract = {Abstract             Do elites exhibit gender bias when responding to political aspirants? Drawing on theories of gender bias, group attachment, and partisan identity, I conduct the first audit experiment outside the United States to examine the presence of gender bias in the earliest phases of the political recruitment process. Based on responses from 1,774 Canadian legislators, I find evidence of an overall gender bias in favor of female political aspirants. Specifically, legislators are more responsive to female political aspirants and more likely to provide them with helpful advice when they ask how to get involved in politics. This pro-women bias, which exists at all levels of government, is stronger among female legislators and those associated with left-leaning parties. These results suggest that political elites in Canada are open to increasing female political representation and thus should serve as welcome encouragement for women to pursue their political ambitions.},
  langid = {english},
  keywords = {00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,02Orientada a la teoria: experimental,03Continente: America,04Pais: Canada,1Diseno experimental: control grupos balanceo democrafico,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,Ambicion,Aspirantes a candidatos,Base documental: NO,Brecha de genero,Elite gender bias,experiment,Experimento,Metodo: revisado,Metodos experimentales,Proceso de reclutamiento,Reclutamiento politico,recruitment process,Sesgo de genero en las elites,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
