@incollection{Dalby_2016,
  title = {Realism and Geopolitics},
  booktitle = {Realism and Geopolitics},
  author = {Dalby, S.},
  year = 2016,
  pages = {33--47},
  doi = {10.4324/9781315612874-11},
  abstract = {The term geopolitics has many contested meanings. Its historical concerns with living space, the invocation of global equilibrium and the balance of power in Henry Kissinger's political rhetoric, the assumptions of given contexts as the terrain of great-power rivalry, the geography of choke points and shatter-belts in geostrategy are all linked to the term in various ways. The reinvention of `Victorian' approaches (Grygiel, 2006) and specifically the invocation of Halford Mackinder (1904; 1919) and his ideas of an Asian heartland as key to the patterns of world power, in such texts as the travel writer Robert Kaplan's high-profile `Revenge of geography' (2009), poses the questions of what the past teaches us and how the notion of geopolitics is now being re-imagined. `Victorian' formulations suggest the contextual givens for humanity: the determinist invocation of limited environmental opportunities linked to an imperial optic where rivalries are inevitable and war the consequence of political ambition tied to inherently expansionist politics. \copyright{} Klaus Dodds, Merje Kuus and Joanne Sharp 2013. All rights reserved.},
  affiliation = {Trinity College Dublin, Ireland; University of Victoria, Canada; Carleton University, Ottawa, Canada},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@incollection{Damian_2018,
  title = {Women Defending Women: {{Memories}} of Women Day Laborers and Emotional Communities},
  booktitle = {Women Defending Women: {{Memories}} of Women Day Laborers and Emotional Communities},
  author = {Dami{\'a}n, G.E.},
  year = 2018,
  pages = {187--210},
  doi = {10.1007/978-3-319-66317-3_9},
  abstract = {Espinosa analyzes the surprising 2015 day laborer movement in the San Quint\'in Valley, Baja California, Mexico, and the way the members of Women Defending Women, an organization devoted to defending labor and human rights in the Valley, felt moved to recall their traumatic and/or joyful experiences as migrants, day laborers, students, and political activists. Working with Gisela Espinosa, they build a collective memory that contradicts the mainstream narrative that portrays men and women day laborers as passive, defenseless, or simply a social problem. The women excavate in their memories and discover they are actors with agency and expectations, brimming with emotions, replete with social and political ambitions. Here, memory and political-emotional community intertwine. \copyright{} The Author(s) 2018.},
  affiliation = {Division of Social Science and Humanities, Metropolitan Autonomous University-Xochimilco, Mexico City, Mexico},
  document_type = {Book Chapter},
