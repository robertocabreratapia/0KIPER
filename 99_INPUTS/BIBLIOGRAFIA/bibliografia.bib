@article{Herrick.Moore_1993,
  title = {Political {{Ambition}}'s {{Effect}} on {{Legislative Behavior}}: {{Schlesinger}}'s {{Typology Reconsidered}} and {{Revisited}}},
  shorttitle = {Political {{Ambition}}'s {{Effect}} on {{Legislative Behavior}}},
  author = {Herrick, Rebekah and Moore, Michael K.},
  year = 1993,
  month = aug,
  journal = {The Journal of Politics},
  volume = {55},
  number = {3},
  pages = {765--776},
  issn = {0022-3816, 1468-2508},
  doi = {10.2307/2132000},
  urldate = {2023-06-13},
  abstract = {Abstract Este art\'iculo analiza el efecto de la ambici\'on pol\'itica en el comportamiento legislativo, con el objetivo de evaluar si distintos tipos de ambici\'on se traducen en patrones diferenciados de actividad parlamentaria. El estudio se sit\'ua en la tradici\'on de la teor\'ia de la ambici\'on pol\'itica de Joseph A. Schlesinger y busca contrastar emp\'iricamente sus implicaciones conductuales. Metodol\'ogicamente, los autores utilizan datos de legisladores estatales en Estados Unidos, combinando informaci\'on sobre aspiraciones de carrera con indicadores de comportamiento legislativo, tales como la actividad en comit\'es, la producci\'on legislativa y la orientaci\'on hacia el distrito. La ambici\'on pol\'itica se operacionaliza en t\'erminos de aspiraciones hacia cargos superiores, reelecci\'on o salida de la pol\'itica. Los resultados muestran que la ambici\'on pol\'itica tiene efectos sistem\'aticos sobre el comportamiento legislativo, aunque estos var\'ian seg\'un el tipo de ambici\'on. En particular, los legisladores con ambici\'on progresiva tienden a exhibir mayores niveles de actividad legislativa y visibilidad, mientras que aquellos orientados a la reelecci\'on muestran un mayor \'enfasis en la representaci\'on del distrito. El art\'iculo concluye que la ambici\'on pol\'itica constituye un determinante relevante del comportamiento legislativo, pero sus efectos son contingentes al tipo de objetivos de carrera que persiguen los actores. Este hallazgo refuerza la utilidad anal\'itica de distinguir entre diferentes formas de ambici\'on para comprender la conducta parlamentaria.},
  langid = {english},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,00Ambicion Politica: intrainstitucional,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la ambicion politica en el comportamiento legislativo (Presentacion de proyectos actividad en sala especializacion exito apoyo al partido staff),1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: no,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unidad de analisis: individual,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: miembros de la Camara Baja de EEUU,2Poblacion: miembros de la Camara Baja de EEUU,Analisis de carrera 6 periodos despues de la ultima legislatura,Base documental: SI,Periodo: 1954-1984,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {56 citations (Crossref) [2024-05-14]},
