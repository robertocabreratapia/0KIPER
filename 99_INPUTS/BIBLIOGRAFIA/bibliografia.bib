@article{Chiru.etal_2013,
  title = {Standing for {{Reelection Under Different Rules}}: {{Evidence}} from the {{Romanian Legislature}}},
  shorttitle = {Standing for {{Reelection Under Different Rules}}},
  author = {Chiru, Mihail and Gherghina, Sergiu and Stefan, Laurentiu},
  year = 2013,
  month = sep,
  journal = {Problems of Post-Communism},
  volume = {60},
  number = {5},
  pages = {34--44},
  issn = {1075-8216, 1557-783X},
  doi = {10.2753/PPC1075-8216600503},
  urldate = {2022-08-09},
  abstract = {Abstract Este art\'iculo analiza los determinantes de la decisi\'on de los parlamentarios de presentarse a la reelecci\'on en contextos institucionales distintos, utilizando evidencia del parlamento rumano antes y despu\'es de una reforma electoral. A partir de datos originales de encuestas a diputados realizadas en 2003 y 2011, el estudio examina el peso relativo de factores institucionales y actitudinales en la disposici\'on a continuar la carrera legislativa. El dise\~no compara dos sistemas electorales: uno proporcional con listas cerradas y otro centrado en candidatos con distritos uninominales y redistribuci\'on proporcional. Se emplean modelos estad\'isticos que incorporan variables institucionales, como experiencia parlamentaria y cargos ejecutivos, y variables actitudinales, como la percepci\'on de la pol\'itica como profesi\'on y la valoraci\'on del cargo legislativo. Los resultados muestran que los factores actitudinales son los principales predictores de la decisi\'on de competir nuevamente. En particular, la valoraci\'on del cargo parlamentario y la identificaci\'on con una carrera pol\'itica aumentan significativamente la probabilidad de buscar la reelecci\'on. En cambio, variables institucionales presentan efectos d\'ebiles o inconsistentes. Asimismo, el cambio en las reglas electorales tiene un impacto limitado, aunque modifica parcialmente algunos incentivos vinculados a la selecci\'on de candidatos y a la relaci\'on con el electorado. El estudio concluye que la continuidad de las \'elites legislativas depende m\'as de percepciones subjetivas que de posiciones institucionales, lo que matiza las explicaciones centradas exclusivamente en incentivos estructurales. Estos hallazgos contribuyen a la literatura sobre ambici\'on pol\'itica y carreras legislativas, especialmente en democracias postcomunistas, y sugieren la necesidad de incorporar variables actitudinales en el an\'alisis de la reelecci\'on.},
  langid = {english},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: estatica,00Ambicion Politica: incumbentes,00Causas: efecto del contexto institucional,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: Europa,04Pais_sigla: RUM,04Pais: Rumania,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: semipresidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: unitario,1Concepto evaluado: efecto de las variables institucionales y actitudinales de los parlamentarios en su ambicion estatica,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individuo,2022-WoS,2024-WoS,2Muestra: legisladores nacionales,2Poblacion: legisladores nacionales,Base documental: SI,Cargo: Legisladores nacionales,Periodo: 2003 y 2011,TEST-BORRAR,Within-case,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {3 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/UV4A5BJN/Chiru et al. - 2013 - Standing for Reelection Under Different Rules Evi.pdf}
}

