@article{Olsen_2011,
  title = {`` {{{\emph{Those About}}}}{\emph{ to }}{{{\emph{Die Salute You}}}} '': {{Sacrifice}}, the {{War}} in {{Iraq}} and the {{Crisis}} of the {{American Imperial Society}}},
  shorttitle = {`` {{{\emph{Those About}}}}{\emph{ to }}{{{\emph{Die Salute You}}}} ''},
  author = {Olsen, Florian},
  year = 2011,
  month = apr,
  journal = {Geopolitics},
  volume = {16},
  number = {2},
  pages = {410--437},
  issn = {1465-0045, 1557-3028},
  doi = {10.1080/14650045.2010.538876},
  urldate = {2022-08-09},
  abstract = {This exploratory article argues that the mobilisation process for the war in Iraq has revealed and exacerbated the fault lines across American society and brought on a crisis in army-society relationships in the US to which the state has ultimately responded by announcing it would withdraw troops from Iraq. To explore these tensions, I present the analytical framework of ``American imperial society'' as an alternative problematisation of `empire' and hope to show its utility to highlight how the repercussions of the US's political ambitions abroad are felt far beyond the battlefield. In doing so, it also provides the first account of empire which builds on the sociology of Pierre Bourdieu. I finally explore these questions by looking at the debate taking place over the meaning and legitimacy of American military sacrifice in three major American newspapers and two magazines},
  langid = {english},
  keywords = {2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,analytical framework,armed forces,Base documental: NO,civil society,civil-military relationship,imperialism,Iraq,mobility,Relaciones Internacionales,United States,war,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/7SJWWTS6/Olsen_2011_“ iThose About to Die Salute You-i ”.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/CKF4RM9G/Olsen - 2011 - “ Those About to Die Salute You ” Sacrific.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/WGUAAYZ3/Olsen - 2011 - “ Those About to Die Salute You ” Sacrific.pdf}
