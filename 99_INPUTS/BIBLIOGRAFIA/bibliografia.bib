@article{Mansell.etal_2022,
  type = {Article},
  title = {Competitive Loss, Gendered Backlash and Sexism in Politics},
  author = {Mansell, Jordan and Harell, Allison and Thomas, Melanee and Gosselin, Tania},
  year = 2022,
  month = mar,
  journal = {Political Behavior},
  volume = {44},
  number = {1},
  pages = {455--476},
  issn = {15736687},
  doi = {10.1007/s11109-021-09724-8},
  abstract = {Politics is often seen as a zero-sum game, so understanding how competition affects political behavior is a fruitful, yet underexplored area of study. Reactions to competition are known to be gendered, as women are significantly more aware of and averse to the potential negative effects of competition---risk and loss---than are men. Participants (n = 1296) completed an experiment involving a non-political competitive task, where they were randomly assigned to receive a negative cue about their individual or gendered group's poor performance. Following this, we assessed their levels of political ambition, efficacy, interest, and sexism. We hypothesize that: (1) negative performance feedback on a competitive task will decrease political ambition, efficacy, and interest among women; and (2) men who receive negative feedback about their performance relative to women will report higher levels of sexism. We use a non-binary measure of masculinity/femininity that helps explain how gender identity affects these outcomes. Evidence does not support the conclusion that negative feedback about competition contributes to women's lower levels of psychological engagement with politics. However, results show that negative performance feedback, particularly when it is relative to women, increases sexism in men. Furthermore, the effect of negative feedback on sexism is larger when men identify more strongly as masculine. We argue that threatening men's relative performance partly explains larger trends of backlash against women in politics.},
  keywords = {00Ambicion como variable: dependiente,00Ambicion Politica: causas,00Ambicion Politica: naciente,00Ambicion Politica: no incumbentes,01Tipo de estudio: causal,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: experimental,03Continente: America,04Pais: EEUU,1Concepto evaluado: reaccion a la competencia segun sexo,1Diseno experimental: control grupos aleatoriedad,1Diseno experimental: distintos sujetos,1Empirico: experimental,1Experimental: experimento real (aleatoriedad manipulacion medicion y control),1Tipo de experimento: laboratorio/online,1Tratamiento: feedback negativo sobre desempeno individual/genero en tareas competitivas,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Panel: mTurk,2Participantes: adultos,2Participantes: panel Mturk,2Participantes: residentes EEUU,2Plataforma experimental: Qualtrics,2Poblacion: >18 anos,2Poblacion: residentes EEUU,Backlash,Base documental: NO,Brecha de genero,Competition,Experiment,Experimento,Gender gaps,Political ambition,Political efficacy,Political interest,Reaccion a la competencia,Sexism,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/6GKZ4WKF/Mansell et al. - 2022 - Competitive loss, gendered backlash and sexism in .pdf}
}

@article{Manthorpe.Iliffe_2020,
  title = {Muddling along in the City: {{Framing}} the Cityscape of Dementia},
  author = {Manthorpe, J. and Iliffe, S.},
  year = 2020,
  journal = {Dementia (Basel, Switzerland)},
  volume = {19},
  number = {7},
  pages = {2184--2198},
  doi = {10.1177/1471301218817451},
  abstract = {There is growing interest in the social geography of dementia, with the development of dementia-friendly communities, localities and cities in the developed world. This paper considers the claims being made for cities to be risky spaces for people with dementia. It debates this through an analysis based on Bacchi's `representation of problems' framework, evidencing this with policy documents and research findings. This reveals that the city is often seen as problematic for people with dementia, despite evidence to the contrary, and that local politicians are making claims for cities to be responsive dementia communities. The nature of local political ambitions is illustrated by strategies from London and from Manchester in the UK. \copyright{} The Author(s) 2018.},
  affiliation = {Social Care Workforce Research Unit, Kings College London, United Kingdom; Primary Care for Older People, Research Department of Primary Care Population Health, University College London, United Kingdom},
  author_keywords = {cities; dementia-friendly; policy claims; representation of problems; risk},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,cities,Cities,city,city planning,City Planning,dementia,Dementia,dementia-friendly,England,Environment Design,environmental planning,human,Humans,London,policy claims,procedures,public policy,Public Policy,representation of problems,risk,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/MVB4BTWY/Manthorpe y Iliffe - 2020 - Muddling along in the city Framing the cityscape of dementia.pdf}
}

