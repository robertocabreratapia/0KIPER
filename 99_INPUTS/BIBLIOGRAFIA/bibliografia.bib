}

@inproceedings{OBrien_2010,
  title = {Forgers of Law and Their Readers: {{The}} Crafting of {{English}} Political Identities between the Norman Conquest and the {{Magna Carta}}},
  booktitle = {{{PS}} - {{Political Science}} and {{Politics}}},
  author = {O'Brien, B.R.},
  year = 2010,
  volume = {43},
  pages = {467--473},
  doi = {10.1017/S1049096510000594},
  abstract = {A short time after 1206 and before 1215, a Londoner assembled a massive collection of older and near contemporary English laws, called the Leges Anglorum by historians, and inserted long interpolations and spurious codes that enunciated many of the principles that guided the baronial opposition to King John and later became part of the Magna Carta. To those familiar with the struggle leading up to the creation of the Magna Carta, these principles should cause no surprise. These ancient laws were made to proclaim that in the kingdom right and justice ought to reign more than perverse will (ECf4, 11.1.A.6; Liebermann 1903, 635). In another part of the collection, King Arthur, making his first appearance in English law, is credited with establishing as law the requirement that all nobles, knights, and freemen of the whole kingdom of Britain swear to defend the kingdom against foreigners and enemies (ECf4, 32.A.5-7; Liebermann 1903, 655). More surprising is the attribution of the regularly assembled Hustings court in London to the Trojans (who became the Britons). The seventh-century West Saxon king, Ine, suddenly looms large in the ranks of Britain's lawmakers; he not only reigns for the good of all, but is also given the lordly virtues of twelfth-century chivalric romance: he is generous, wise, prudent, moderate, strong, just, spirited, and warlike (as was appropriate for the time and place) (ECf4, 32.C.2, 32.C.8; Liebermann 1903, 658-59). A confection of bits of other law, attributed here to King Alfred, orders an end to vice, national education for freemen, and unity for all as if sworn brothers for the utility of the kingdom (Leges Angl, Pseudo-Alfred 1-6; Liebermann 1894, 19-20). Finally, in the grandest statement of English political ambition, Arthur appears again as the great conqueror, whose spirit was not satisfied by Britain alone: Courageously and speedily he subjugated all Scandinavia, which is now called Norway, and all the islands beyond, namely Iceland and Greenland, which belong to Norway, Sweden, Ireland, Gotland, Denmark, Samland, Vinland, Curland, Runoe, Finland, Wirland, Estland, Karelien,Lapland, and all other lands and islands of the eastern Ocean as far as Russia (ECf4, 32.E; Liebermann 1903, 659). Copyright \copyright{} 2010 American Political Science Association.},
  affiliation = {Institute of Historical Research, United Kingdom},
  document_type = {Conference Paper},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/7DTDUHKW/O'Brien - 2010 - Forgers of law and their readers The crafting of English political identities between the norman co.pdf}
}

@incollection{OBrien_2020,
  title = {Manufacturing {{Realities}}: {{Truth Is What You Can Get Away With}}},
  booktitle = {Rhetor. {{Politic}}. {{Soc}}.},
  author = {O'Brien, S.B.},
  year = 2020,
  volume = {Part F803},
  pages = {11--37},
  publisher = {Palgrave Macmillan},
  doi = {10.1007/978-3-030-50551-6_2},
  abstract = {This chapter explains how Donald Trump utilizes the wrestling concept of kayfabe to forge his own reality. Kayfabe involves pretending an event, action, or activity is absolutely real, no matter how contrived or fabricated it happens to be in actuality. This chapter explores how manufacturing spaces impact perception. The chapter looks at the origins of modern professional wrestling within the circus and theater. The specialized language of wrestling comes directly from the circus, which also helped develop its theatrical mannerisms. It also explores others who have manufactured realities to help create and controls ideas within spaces. It looks at Disney parks, Dan Rice, John R. Brinkley, and Father Charles Coughlin. All three men (Rice, Brinkley, and Coughlin) had political ambitions and used their fame to help achieve them. \copyright{} 2020, The Author(s).},
  isbn = {29475147 (ISSN)},
  langid = {english},
  keywords = {2024 STATUS: Pendiente de procesar,2024-Scopus,Dan Rice,Father Charles Coughlin,John R. Brinkley,Kayfabe,Manufactured reality,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/6UIGUAUJ/O’Brien - 2020 - Manufacturing Realities Truth Is What You Can Get Away With.pdf}
}

@article{OBrien_2025,
  title = {The Rise and Rise of {{Mauricio Macri}}: Football, Culture and Presidential Politics in {{Argentina}} 1991--2023},
  author = {O'Brien, J.},
  year = 2025,
  journal = {Soccer and Society},
  volume = {26},
  number = {2},
  pages = {349--361},
  publisher = {Routledge},
  issn = {17439590 (ISSN); 14660970 (ISSN)},
  doi = {10.1080/14660970.2024.2446066},
  abstract = {Mauricio Macri's defeat in the 2019 Presidential Election suggested the end of his political career in the volatile world of Argentinian politics. Yet months after his rejection by the electorate, he emerged as executive chairman of the FIFA Foundation, keeping him in the public eye, and offering the possibility of a political comeback. This article charts the rise of a political outsider to the zenith of state power. The exploitation of football was pivotal in promoting Macri's political ambitions, framing a construction of Presidentialism within the traditional synthesis between football and politics in Argentinian society. It also examines his adherence to neoliberal ideology during his tenure as President of Boca Juniors, a giant in the Argentinian game, and his two terms as Mayor of Buenos Aires between 2007--2015. Finally, the article considers the implications of his victory in the 2015 Presidential Election, as the first non - Peronist to head the government since 1945. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {ZFiltro1: descartado (falsos positivos)}
}

