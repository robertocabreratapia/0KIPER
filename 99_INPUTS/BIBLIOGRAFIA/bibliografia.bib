@article{Levine.Hyde_1977,
  type = {Article},
  title = {Incumbency and the Theory of Political Ambition: A Rational-Choice Model},
  author = {Levine, Martin D. and Hyde, Mark S.},
  year = 1977,
  journal = {The Journal of Politics},
  volume = {39},
  number = {4},
  pages = {959--983},
  issn = {0022-3816},
  doi = {10.2307/2129937},
  abstract = {A substantial body of literature has accumulated within the discipline of political science that may be roughly classified under the heading of "political recruitment." These studies have attempted to isolate social, psychological, and political variables that induce or inhibit individuals to run for elective office. In this paper we will build upon these existing efforts in developing an original model of candidacy decisions. Specifically, we present a model of the choice process of political incumbents in deciding whether to seek reelection to their own or higher offices, or retire. This original model is in the form of a calculus presumed to represent the decisional process of rational officeholders. As a rational-calculus theory, it is derived, as well, from the other utility theoretic formulations of individual choice. Before considering these other economic models and the development of our own from them, we offer in the following section a brief review of some of the less formal treatments of the recruitment process},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: causas\elementos considerados,00Ambicion Politica: discreta,00Ambicion Politica: estatica,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,01No Empirico: positivo,01Tipo de investigacion politica: positivo,02Orientada a la teoria: no aplica,03Continente: no,04Pais_sigla: N/A,04Pais: No Aplica,0Cargo electo: si,0Cargo: No_aplica_nad,0Division funcional: no aplica,0Division territorial: no aplica,0Forma Gobierno: no aplica,0Organizacion legislativo: no aplica,0Organizacion territorial: no aplica,1Diseno experimental: no aplica,1Gerring variacion espacial: n/a,1Gerring variacion temporal: n/a,1Gerring2 variacion unidad/individuo: n/a,1Metodologia: no aplica,1No experimental: no aplica,1NoExperimental_Tecnicas: no aplica,1Tipo de experimento: no aplica,2022-WoS,2024-WoS,Base documental: SI,Eleccion racional,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {8 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/DFZ83LVY/Levine y Hyde - 1977 - Incumbency and the theory of political ambition a.pdf}
}

