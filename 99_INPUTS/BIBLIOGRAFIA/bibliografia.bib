@article{TerrelongeS._1980,
  title = {Ambition {{Theory}} and the {{Black Politician}}},
  author = {Terrelonge S., Pauline},
  year = 1980,
  month = mar,
  journal = {The Western Political Quarterly},
  volume = {33},
  number = {1},
  eprint = {447622},
  eprinttype = {jstor},
  pages = {94},
  issn = {00434078},
  doi = {10.2307/447622},
  urldate = {2022-08-09},
  abstract = {Este art\'iculo examina la aplicabilidad de la teor\'ia de la ambici\'on pol\'itica al estudio de los pol\'iticos afroamericanos en Estados Unidos, evaluando en qu\'e medida los supuestos derivados del modelo general explican sus decisiones de carrera. El trabajo se sit\'ua en la tradici\'on te\'orica desarrollada por Joseph A. Schlesinger, pero introduce una perspectiva cr\'itica al considerar las condiciones espec\'ificas que enfrentan estos actores. El argumento central sostiene que la teor\'ia de la ambici\'on, formulada a partir de experiencias mayoritariamente blancas, no captura plenamente las restricciones estructurales y oportunidades diferenciadas que enfrentan los pol\'iticos afroamericanos. Factores como la discriminaci\'on, la estructura de oportunidades electorales y la distribuci\'on geogr\'afica del electorado condicionan de manera particular sus decisiones de carrera. A partir de evidencia emp\'irica, el art\'iculo muestra que, aunque los pol\'iticos afroamericanos exhiben patrones de ambici\'on comparables en t\'erminos generales, sus trayectorias est\'an m\'as fuertemente mediadas por limitaciones externas que restringen las oportunidades de progresi\'on pol\'itica. Esto se traduce en estrategias diferenciadas y en una menor probabilidad de avanzar hacia cargos superiores en comparaci\'on con sus contrapartes blancas. El art\'iculo concluye que la teor\'ia de la ambici\'on pol\'itica requiere ser matizada para incorporar desigualdades estructurales que afectan las decisiones de carrera. En este sentido, aporta una extensi\'on del marco te\'orico al introducir el papel de factores raciales en la configuraci\'on de la ambici\'on pol\'itica.},
  langid = {american},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: discreta,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Mix var_cargo,0Division funcional: mix,0Division territorial: multinivel,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la raza y otras variables sociales y politicas en la ambicion politica de los negros,1Diseno experimental: no aplica,1Empirico: no experimental,1Encuesta: propia,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Poblacion: politicos de raza negra electos para un cargo publico,1Tipo de experimento: no aplica,2022-WoS,2024-WoS,2Muestra: negros incumbentes en cargos publicos en 1974 (local estatal federal),Base documental: SI,Brecha racial,Cuestionario ambicion,Politicos negros,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
