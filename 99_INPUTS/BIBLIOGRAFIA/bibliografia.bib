@article{Cox.Morgenstern_2001,
  title = {Latin {{America}}'s {{Reactive Assemblies}} and {{Proactive Presidents}}},
  author = {Cox, Gary W. and Morgenstern, Scott},
  year = 2001,
  month = jan,
  journal = {Comparative Politics},
  volume = {33},
  number = {2},
  eprint = {422377},
  eprinttype = {jstor},
  pages = {171},
  issn = {00104159},
  doi = {10.2307/422377},
  urldate = {2022-08-09},
  abstract = {Este art\'iculo examina el papel de las legislaturas en Am\'erica Latina, proponiendo una tipolog\'ia que distingue entre asambleas reactivas y proactivas en funci\'on de su capacidad para influir en el proceso legislativo frente al poder ejecutivo. A partir de un an\'alisis comparado, los autores cuestionan la visi\'on predominante que caracteriza a los congresos latinoamericanos como instituciones d\'ebiles y subordinadas. El marco te\'orico se centra en la interacci\'on entre presidentes y legislaturas, destacando c\'omo las reglas institucionales, los poderes formales del ejecutivo y las caracter\'isticas del sistema de partidos configuran distintos patrones de comportamiento legislativo. Se identifican condiciones bajo las cuales las legislaturas pueden actuar de manera proactiva, iniciando y moldeando legislaci\'on, o de forma reactiva, limit\'andose a responder a las iniciativas del ejecutivo. El an\'alisis emp\'irico se basa en evidencia comparada de varios pa\'ises de la regi\'on, considerando variables como el control de agenda, las facultades de veto, los mecanismos de urgencia legislativa y la cohesi\'on partidaria. Los resultados muestran una variaci\'on significativa entre casos: mientras algunas legislaturas poseen capacidad efectiva de intervenci\'on, otras operan con m\'argenes restringidos, dependiendo en gran medida de las iniciativas presidenciales. El art\'iculo concluye que el comportamiento legislativo en Am\'erica Latina no puede entenderse de manera uniforme. La distinci\'on entre asambleas reactivas y proactivas permite capturar esta heterogeneidad y ofrece un marco anal\'itico \'util para estudiar la din\'amica ejecutivo legislativo en sistemas presidenciales.},
  langid = {american},
