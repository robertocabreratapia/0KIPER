@article{Hohmann.etal_2025,
  title = {An {{Early Leak}} in the {{Pipeline}}--{{Online Abuse}} as a {{Barrier}} for {{Young Women}}'s {{Political Engagement}}},
  author = {H{\"o}hmann, D. and Latteier, T. and Bailer, S.},
  year = 2025,
  journal = {Journal of Women, Politics and Policy},
  publisher = {Routledge},
  issn = {1554477X (ISSN)},
  doi = {10.1080/1554477X.2025.2552573},
  abstract = {To what extent does online abuse on social media platforms obstruct an equal representation of women and men in politics? We investigate the frequency, character, and consequences of online abuse among youth party members and ask to what extent it affects women's and men's decisions to pursue a career in politics. Empirically, we draw on an original survey of youth party members in Switzerland. The results show pronounced gendered patterns in the character and consequences of online abuse. First, young women are more likely to be attacked based on their gender. Second, women youth party members are more likely to indicate that personal experiences with abuse on social media are an obstacle to their political work as well as a reason for them to resign from politics. Our analysis demonstrates that online abuse discourages many young women from running for political office before their actual political careers have even begun. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {american},
  keywords = {Online abuse,political ambition,violence against women in politics,women and politics,youth parties,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/MGUEQTVF/Höhmann et al. - 2025 - An Early Leak in the Pipeline–Online Abuse as a Barrier for Young Women’s Political Engagement.pdf}
}

@article{Hojbjerg_2010,
  title = {Victims and Heroes: {{Manding}} Historical Imagination in a Conflict-Ridden Border Region ({{Liberia-Guinea}})},
  author = {H{\o}jbjerg, C.K.},
  year = 2010,
  journal = {African Social Studies Series},
  volume = {24},
  pages = {273--293},
  doi = {10.1163/ej.9789004190009.i-375.107},
  abstract = {Victimization, autochthony and citizenship, power, and nation-building constitute recurrent, interrelated themes in post-war Manding historical memory in the border area between Liberia and Guinea. While the perceived history of the Manding diverges from academic, historical knowledge as well as from neighbouring peoples' recollection of the past, it informs about the position and role of the marginalized, but at the same time military victorious Manding in a reshuffled Liberian political culture. The chapter suggests that contemporary Mande memory work serves a double purpose. On the one hand, Manding historical imagination gives expression to political ambitions and conveys claims to a number of basic civic rights, including citizenship. On the other, there is a moral value to heroic memories of the past as a means to recreate communal life and to come to terms with the experience of prolonged years of political marginalisation, violent deatch, loss of property and exile.},
  affiliation = {MINDLab, Department of Anthropology, Aarhus University, Denmark},
  document_type = {Review},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Relaciones Internacionales,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@article{HoldenBates.etal_2025,
  title = {Which {{MPs}} Get Elevated to the {{UK House}} of {{Lords}}?},
  author = {Holden Bates, S. and Horncastle, W.C.R. and Bhattacharya, C. and McKay, S.},
  year = 2025,
