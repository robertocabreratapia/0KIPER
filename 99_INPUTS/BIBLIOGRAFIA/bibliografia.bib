  doi = {10.2307/2111397},
  abstract = {This paper focuses upon gender differences in the motives of political activists. Using data from questionnaires submitted by 3,000 California political party activists and leaders over a 20-year period, it documents the relatively low level of political ambition-defined in terms of a desire for political self-enhancement-among the women studied and the way in which the ambition gender gap has been closing in recent years. It probes the characteristics associated with ambition among the women respondents and explores the consequences for political parties as organizations that may result from changes in the ambition-gender relationship.},
