@article{Robins_2018,
  title = {Freedom Is Something People Take and People Are as Free as They Want to Be, or What We Learned from {{Gezi Park}}},
  author = {Robins, K.},
  year = 2018,
  journal = {City},
  volume = {22},
  number = {3},
  pages = {396--411},
  doi = {10.1080/13604813.2018.1473128},
  abstract = {This discussion seeks to draw out some of the lessons that were learned as a consequence of involvement in the Gezi Park protests in Istanbul in the summer of 2013. A key concern is with the relationship between the power politics of the state, on the one hand, and the emancipatory aspirations of the activists involved in the struggle to save Gezi Park from the bulldozers of real-estate capital and from the political ambitions of the ruling party in government. What is emphasised is the growing force of authoritarianism in the contemporary Turkish context. Whilst the protests were eventually defeated by the state's repressive apparatuses, we can say that there were important lessons about the ideal nature of democratic politics that were learned by the protesting opposition. A central focus of the discussion is on what can be learned through the trajectory of an event. The article contrasts the principles underpinning the nation-state mentality with those that may be produced in the urban space and context. \copyright{} 2018, \copyright{} 2018 Informa UK Limited, trading as Taylor \& Francis Group.},
  affiliation = {Istanbul, Turkey},
  author_keywords = {authoritarianism; event; Gezi Park; human freedom; nation state versus city; persistent utopia; servitude},
  document_type = {Article},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,authoritarianism,Base documental: NO,event,Gezi Park,human freedom,nation state versus city,persistent utopia,servitude,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/UCCIU58S/Robins - 2018 - Freedom is something people take and people are as free as they want to be, or what we learned from.pdf}
}

@incollection{Robles_2016,
  title = {Santiago {{Carrillo Solares}}},
  booktitle = {Political {{Leadership}} in the {{Spanish Transition}} to {{Democracy}} (1975-1982)},
  author = {Robles, A.},
  year = 2016,
  pages = {77--92},
  abstract = {This chapter attempts to explain the main leadership characteristics of Santiago Carrillo Solares, the General Secretary of the Communist Party of Spain during the Spanish Transition. Previous research on political leadership conducted by Burns, Tucker, Kellerman, Blondel, Nye Jr., and Linz -among others- establishes the theoretical and methodological starting point for this analysis, which necessarily considers the interaction between the leader, the followers and the situation as a unique observation. Following Linz's typology, Santiago Carrillo was an innovative leader in the 1970s, although he can also be classified as authoritarian (Blondel) and contextual (Nye Jr.). Carrillo and the Communist Party of Spain actively collaborated in the political democratization and decentralization of Spain, enabling national reconciliation through consensus. However, the enormous political capital accumulated by Carrillo and the effort made to adapt to the new political situation lacked the courage to achieve political success. Thus, despite Carrillo being the leader of the largest opposition party during the second half of the dictatorship, from 1977 onwards the communist strength lost its supremacy, being left with a torn internal structure and without outside support. The gap between the communist leader and his followers rapidly widen. The political ambition of the veteran leader, the typology of his internal leadership and voters' preferences caused the failure of both personally Carrillo and collectively the Communist Party in its Eurocommunist version. \copyright{} 2016 Nova Science Publishers, Inc.},
  affiliation = {Universidad de Granada, Granada, Spain},
  author_keywords = {Democracy; Leadership; Santiago Carrillo; Spanish transition},
  document_type = {Book Chapter},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Democracy,Leadership,Santiago Carrillo,Spanish transition,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)},
  annotation = {abstractTranslation:}
}

