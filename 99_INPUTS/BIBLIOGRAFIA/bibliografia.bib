@article{Herrick_1998,
  type = {Meeting Abstract},
  title = {Political Ambition and Legislative Style.},
  author = {Herrick, R},
  year = 1998,
  month = feb,
  journal = {Legislative Studies Quarterly},
  volume = {23},
  number = {1},
  pages = {146},
  publisher = {COMPARATIVE LEGISLATIVE RES CENTER},
  address = {UNIV OF IOWA, W307 SEASHORE HALL, IOWA CITY, IA 52242-1409 USA},
  issn = {0362-9805},
  abstract = {Abstract Este art\'iculo examina la relaci\'on entre ambici\'on pol\'itica y estilo legislativo, cuestionando los supuestos predominantes en la literatura sobre el efecto de la ambici\'on en el comportamiento de los miembros del Congreso. En particular, se plantea que las conclusiones previas pueden ser problem\'aticas debido a una medici\'on inadecuada de la ambici\'on, entendida como un constructo psicol\'ogico que ha sido inferido a partir de comportamientos observados. El estudio propone una medici\'on directa de la ambici\'on pol\'itica, basada en el deseo declarado de los legisladores de acceder a cargos superiores. A partir de datos de encuesta a candidatos, se eval\'ua c\'omo distintos niveles de ambici\'on se asocian con variaciones en el estilo legislativo, entendido en t\'erminos de patrones de actividad y comportamiento pol\'itico. Los resultados indican que la ambici\'on pol\'itica s\'i influye en el comportamiento legislativo, pero no de la manera uniforme que sugiere la literatura previa. En particular, la relaci\'on entre ambici\'on y estilo es m\'as compleja y depende de c\'omo se mida la ambici\'on. Esto lleva a revisar inferencias anteriores que vinculaban directamente ciertos comportamientos con tipos espec\'ificos de ambici\'on. El art\'iculo concluye que una medici\'on m\'as precisa de la ambici\'on pol\'itica es necesaria para comprender su efecto en el comportamiento legislativo. Este hallazgo tiene implicaciones relevantes para el estudio de las decisiones de carrera y su relaci\'on con la actividad parlamentaria, al subrayar la importancia de distinguir entre motivaciones subyacentes y comportamientos observables.},
  affiliation = {Oklahoma State Univ, Stillwater, OK 74078 USA.},
  da = {2022-10-09},
  doc-delivery-number = {YU951},
  journal-iso = {Legis. Stud. Q.},
