@article{Meinhold.Hadley_1995,
  type = {Article},
  title = {Lawyers as {{Political-Party Activists}}},
  author = {Meinhold, S S and Hadley, C D},
  year = 1995,
  month = jun,
  journal = {Social Science Quarterly},
  volume = {76},
  number = {2},
  pages = {364--380},
  issn = {0038-4941},
  abstract = {Objective. This paper explores the applicability of traditional explanations of lawyer-legislator dominance to the arena of political parties. Methods. The authors use an unusually large survey of southern county party activists to examine whether lawyers tend to dominate party leadership positions, engage in practice building, and express political ambition. In addition, the authors examine whether lawyers tend to be recruited by political parties or whether they are more self-motivated. Results. Surprisingly, lawyers are not as abundant among county political party activists as they are among most other government positions. Consistent with previous research, however, lawyer-activists do tend to dominate party leadership positions. They also are more likely to engage in politics with the intent of making business contacts. Lawyers are more self-motivated than other party activists and are more likely to be recruited for their party positions by other party members or elected officials. Conclusions. The impact of legal training on the behavior and attitudes of political party activists is considerable and reinforces the importance of lawyers in politics.},
  langid = {american},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: causas,00Ambicion Politica: progresiva,1NoExperimental_Tecnicas: encuesta,2022-WoS,2024-WoS,Abogados,Base documental: NO,Militantes de partido,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/ZAPGXU8W/MEINHOLD y HADLEY - 1995 - LAWYERS AS POLITICAL-PARTY ACTIVISTS.pdf}
}

@book{Melby.etal_2009,
  title = {Gender Equality and Welfare Politics in {{Scandinavia}}: {{The}} Limits of Political Ambition?},
  author = {Melby, K. and Ravn, A.-B. and Wetterberg, C.C.},
  year = 2009,
  pages = {1--244},
  abstract = {Gender equality is often seen as a hallmark of the Nordic countries. This book explores this notion by examining the meanings of gender that underpin policies in the Scandinavian welfare states, historically and today. The book focuses on three Scandinavian countries - Denmark, Norway and Sweden - and explores the policy reforms that have occurred relating to family and care. Beginning with the radical marriage reform carried through in all the three countries in the early decades of the 20th century, the book progresses to explore contemporary challenges to the traditional model of equality, including equal rights for fathers, multiculturalism and a critical young generation. The book focuses on differences as well as similarities between the countries and discusses the relevance of talking about a Nordic model. Stressing the importance of viewing the concept of equality in its historical context, the book critically investigates and discusses the Scandinavian 'success story' portrayed in normative political theory and presents an historical analysis of the development of gendered citizenship rights. It will be a valuable collection for researchers, lecturers and graduate students who work with historical and contemporary studies on welfare state and gender models from different disciplinary or interdisciplinary perspectives. \copyright{} Kari Melby, Anna-Birte Ravn and Christina Carlsson Wetterberg 2008. All rights reserved.},
  affiliation = {Department of Interdisciplinary Studies, Culture/Centre for Feminist and Gender Studies, Norwegian University of Science and Technology (NTNU), Trondheim, Norway; Faculty of Arts, Norwegian University of Science and Technology (NTNU), Trondheim, Norway; Gender Division of Work and Social Change at FREIA, Centre for Feminist Research, Aalborg University, Denmark; \"Orebro University, Sweden},
  document_type = {Book},
  source = {Scopus},
  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,ZBaseIntegrada: si,ZFiltro1: descartado (falsos positivos)}
}

@book{Mello_2021,
  title = {Qualitative Comparative Analysis: An Introduction to Research Design and Application},
  shorttitle = {Qualitative Comparative Analysis},
  author = {Mello, Patrick A.},
  year = 2021,
  publisher = {Georgetown University Press},
  address = {Washington, DC},
  abstract = {"Social phenomena can rarely be attributed to single causes. Drawing on set theory and the language of necessary and sufficient conditions, Qualitative Comparative Analysis (QCA) is a case-based research method that is ideally suited to capture causal complexity. QCA regards cases as combinations of conditions. It compares the conditions of each case in a structured way to identify the necessary and sufficient conditions for an outcome. While QCA has become increasingly popular and seen a substantial increase of applications across the social sciences and management, introductory textbooks have not kept pace with this development. In this textbook, Patrick A. Mello teaches students, scholars, and self-learners the fundamentals of QCA, research design, interpretation of results, and how to communicate findings. This concise and accessible textbook provides a hands-on introduction to QCA that will be ideal for use within a broader qualitative methods course and in intensive short courses"--},
  isbn = {978-1-64712-146-4},
  lccn = {H62},
  keywords = {Research Methodology,Social sciences,Statistical methods},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/SCJBYJ9L/Mello - 2021 - Qualitative comparative analysis an introduction to research design and application.pdf}
}

