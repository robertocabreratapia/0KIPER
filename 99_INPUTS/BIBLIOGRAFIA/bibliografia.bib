@article{Lindberg_2010,
  title = {What Accountability Pressures Do {{MPs}} in {{Africa}} Face and How Do They Respond? {{Evidence}} from {{Ghana}}},
  shorttitle = {What Accountability Pressures Do {{MPs}} in {{Africa}} Face and How Do They Respond?},
  author = {Lindberg, Staffan I.},
  year = 2010,
  month = mar,
  journal = {The Journal of Modern African Studies},
  volume = {48},
  number = {1},
  pages = {117--142},
  issn = {0022-278X, 1469-7777},
  doi = {10.1017/S0022278X09990243},
  urldate = {2023-04-08},
  abstract = {ABSTRACT             How African politicians, especially legislators, behave on a daily basis is still largely unknown. This article gives a unique empirical account of the daily accountability pressures and the strategies that Members of Parliament (MPs) in Ghana employ in responding to the demands that they face. While literature on political clientelism focuses on explanatory factors like lack of political credibility, political machines capable of effective monitoring, autonomy of brokers, high levels of poverty, and political competiveness, the role of institutions has been overlooked. While the existing literature suggests that political clientelism is an optimal strategy in the context of weak institutions, the present analysis finds that the institution of the office of Member of Parliament in Ghana is strong, but shaped by informal norms in ways that favour the provision of private goods in clientelistic networks. The analysis also points to theoretical lessons on how political clientelism can endogenously undermine the conditions for its own existence.},
  langid = {english},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/ZF23YUTY/Lindberg_2010_What accountability pressures do MPs in Africa face and how do they respond.pdf;D\:\\OneDrive - Universidad Complutense de Madrid (UCM)\\Zotero\\Lindberg\\Lindberg_2010_What accountability pressures do MPs in Africa face and how do they respond.pdf}
}

@article{Little_1994,
  type = {Article},
  title = {A {{Systematic Analysis}} of {{Members}}'  {{Environments}} and {{Their Expectations}} of {{Elected Leaders}}},
  author = {Little, Thomas H.},
