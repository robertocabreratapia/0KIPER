  keywords = {2022-Scopus,2024-Scopus,Base documental: NO,Division funcional: judicial,Teoria del retiro estrategico,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: descartado (fuera de alcance)},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/K74BAMC9/Pérez y Araya - 2017 - Strategic retirement in comparative perspective Supreme court justices in presidential regimes.pdf}
}

@article{Perkins_1986,
  title = {Political Ambition among Black and White Women: {{An}} Intragender Test of Socialization Model},
