@article{Dutton_1975,
  title = {The {{Political Ambitions}} of {{Local Legislators}}: {{A Comparative Perspective}}},
  shorttitle = {The {{Political Ambitions}} of {{Local Legislators}}},
  author = {Dutton, William H.},
  year = 1975,
  month = jun,
  journal = {Polity},
  volume = {7},
  number = {4},
  pages = {504--522},
  issn = {0032-3497, 1744-1684},
  doi = {10.2307/3234193},
  urldate = {2022-08-09},
  abstract = {Este art\'iculo examina las ambiciones pol\'iticas de los legisladores locales, con el objetivo de identificar los factores que estructuran sus decisiones de carrera dentro del sistema pol\'itico. A partir de evidencia emp\'irica original, el estudio analiza c\'omo los actores en cargos legislativos subnacionales definen sus aspiraciones futuras, distinguiendo entre orientaciones hacia la permanencia en el cargo, la progresi\'on hacia posiciones superiores o la salida de la pol\'itica. El marco anal\'itico se inscribe en la tradici\'on de la teor\'ia de la ambici\'on pol\'itica desarrollada por Joseph A. Schlesinger, enfatizando la relaci\'on entre oportunidades institucionales, incentivos del entorno pol\'itico y caracter\'isticas individuales. Metodol\'ogicamente, el autor emplea datos de encuesta a legisladores locales, incorporando variables relativas a trayectoria pol\'itica, percepciones sobre el cargo y evaluaciones del contexto electoral. Los resultados muestran que las ambiciones pol\'iticas no son homog\'eneas y se distribuyen de manera sistem\'atica seg\'un factores como la experiencia previa, la edad, la posici\'on dentro de la estructura pol\'itica y la percepci\'on de oportunidades de avance. En particular, los legisladores con mayores recursos pol\'iticos y mejor posicionamiento institucional tienden a manifestar ambiciones progresivas, mientras que aquellos con menores oportunidades se inclinan hacia la permanencia o la retirada. El art\'iculo concluye que las decisiones de carrera en niveles subnacionales responden a una combinaci\'on de incentivos estructurales y evaluaciones subjetivas, lo que refuerza la utilidad del enfoque de la ambici\'on pol\'itica para explicar el comportamiento de las \'elites locales. Este an\'alisis contribuye a ampliar la literatura m\'as all\'a del nivel nacional, mostrando la relevancia del \'ambito local para el estudio de las carreras pol\'iticas.},
  langid = {english},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Buffalo,042Estado: California,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Consejero local,0Division funcional: legislativo,0Division territorial: local,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: efecto de la ambicion politica en la rendicion de cuentas y la respuesta al electorado.,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: unidades e individuos,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: entrevista,1Tipo de experimento: no aplica,1Unidad de analisis: individuo-legislatura,2022-WoS,2024-WoS,2Muestra: Consejeros locales de Buffallo y la Bahia de San Francisco,2Poblacion: Consejeros locales de Buffallo y la Bahia de San Francisco,Base documental: SI,Electoral accountability,Teoria de la responsabilidad electoral,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
