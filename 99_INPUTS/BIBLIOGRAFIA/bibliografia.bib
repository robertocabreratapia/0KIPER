@article{Treul_2009,
  type = {Article},
  title = {Ambition and Party Loyalty in the {{U}}.{{S}}. Senate},
  author = {Treul, Sarah A.},
  year = 2009,
  month = may,
  journal = {American Politics Research},
  volume = {37},
  number = {3},
  pages = {449--464},
  issn = {1532673X},
  doi = {10.1177/1532673X08322260},
  abstract = {This article examines the role progressive ambition plays in the U.S. Senate. I analyze the effect ambition has on party loyalty in the upper chamber. The theoretical argument is that senators with ambition for higher office are more loyal to the party than their colleagues who never make a bid for higher office because of their need to appeal to the party base to secure the party's nomination. I posit the following hypothesis to test this theory: A senator who seeks higher office will be more likely to vote with the party on party votes than those senators who never run for the presidency. My findings indicate that ambitious senators are more loyal to the party than their colleagues who never make a bid for higher office. That is, senators who run for higher office recognize the importance of the party when it comes to successfully navigating the primary season. \copyright{} 2009 SAGE Publications.},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,00Ambicion Politica: progresiva,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Senador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Concepto evaluado: estudia el efecto de la ambicion progresiva en la disciplina partidaria de los senadores estadounidenses.,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: no,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre individuos,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unidad de analisis: individual,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Poblacion: senadores,Ambicion politica solo puede ser evaluada a lo largo de la carrera,Base documental: SI,Camara Alta,Cargo: Legisladores,Cargo: Senadores,Distingue la investigacion sobre causas de la de consecuencias,legislative behavior,Legislative behavior,Marco: causas y consecuencias,Muestra: senadores,party loyalty,Party loyalty,Periodo: 1963-2004,political ambition,Political ambition,Progressive ambition,progressive ambition,TEST-BORRAR,U.S. Senate,US Senate,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
