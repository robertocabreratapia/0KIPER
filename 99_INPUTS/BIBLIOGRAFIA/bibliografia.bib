@article{Aars.etal_2012,
  title = {The {{Careers}} of {{European Local Councillors}}: {{A Cross-National Comparison}}},
  shorttitle = {The {{Careers}} of {{European Local Councillors}}},
  author = {Aars, Jacob and Offerdal, Audun and Rysavy, Dan},
  year = 2012,
  month = jan,
  journal = {Lex localis - Journal of Local Self-Government},
  volume = {10},
  number = {1},
  pages = {63--84},
  issn = {1855-363X, 1581-5374},
  doi = {10.4335/10.1.63-84},
  urldate = {2022-08-09},
  abstract = {This article is concerned with the political careers of local councillors. More specifically, the key question is about a possible professionalization of councillor careers at the local level in Europe. If the careers of local councillors tend to follow a number of standard routes, to what degree can these be perceived of as professionalized? In our effort to identify dominant courses of mobility, we distinguish between three successive stages of councillor careers: Pre-electoral experiences, in-council orientations, and future career aspirations. In the ideal model of professionalization there is a strong link between career stages. Professionalization is seen as a unidirectional process by which an occupational group gradually acquires the traits of a profession. By and large, local political careers in European countries do not adhere to the linear model of professionalization. Instead, a fits-and-start model seems more suitable, indicating that professional careers to a large extent are shaped incrementally, through learning and practical experience.},
  keywords = {00Ambicion Politica: causas,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: Europa,04Pais_sigla: MUL,04Pais: multipais,0Cargo electo: si,0Cargo: Consejero local,0Division funcional: legislativo,0Division territorial: local,0Forma Gobierno: mix,0Organizacion legislativo: mix,0Organizacion territorial: mix,1Concepto evaluado: efecto de la "profesionalizacion" (experiencia previa en el cargo y ambicion politica) en el patron de carrera politica,1Diseno experimental: no aplica,1Empirico: no experimental,1Encuesta: MAELG Municipal Assemblies in European Local Governance,1Gerring combinacion: cross-sectional,1Gerring variacion espacial: si entre unidades,1Gerring variacion temporal: no,1Gerring2 variacion unidad/individuo: entre unidades,1Metodologia: no experimental,1No experimental: sincronico/corte transversal,1NoExperimental_Tecnicas: encuesta,1Tipo de experimento: no aplica,1Unidad de analisis: individual,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: Consejeros Locales de 16 paises europeos,2Poblacion: Consejeros locales,AMB_TIPO_VARIABLE: nominal ordinal,Base documental: SI,Local councillors,Medicion: ambicion declarada al inicio de la carrera,Metodo de analisis/inferencia: tabla de contingencia,Modelo analisis/,Political ambitions,Political careers,Political parties,Profesionalizacion,Professionalization,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {6 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/XBMBHVLH/Aars et al_2012_The Careers of European Local Councillors.pdf}
