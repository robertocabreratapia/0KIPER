@article{Hain_1976,
  type = {Article},
  title = {Constituency Characteristics, Political Ambition and Advancement},
  author = {Hain, Paul L.},
  year = 1976,
  month = jan,
  journal = {American Politics Research},
  volume = {4},
  number = {1},
  pages = {47--62},
  issn = {15523373},
  doi = {10.1177/1532673X7600400102},
  abstract = {Abstract Este art\'iculo analiza la relaci\'on entre las caracter\'isticas de la circunscripci\'on, la ambici\'on pol\'itica y el comportamiento de los legisladores, con el objetivo de determinar en qu\'e medida el entorno electoral condiciona las decisiones de carrera y la orientaci\'on de la actividad pol\'itica. A partir de un dise\~no emp\'irico basado en datos de legisladores estatales en Estados Unidos, el estudio eval\'ua c\'omo distintos contextos distritales influyen en las aspiraciones futuras de los representantes. El marco te\'orico se apoya en la literatura sobre ambici\'on pol\'itica, particularmente en la distinci\'on entre ambici\'on progresiva, est\'atica y discreta. El autor plantea que las caracter\'isticas socioecon\'omicas y pol\'iticas de la circunscripci\'on generan incentivos diferenciados que afectan tanto las decisiones de carrera como el tipo de representaci\'on ejercida. Metodol\'ogicamente, el an\'alisis incorpora variables relativas a competitividad electoral, composici\'on demogr\'afica y estructura partidaria del distrito. Los resultados indican que los legisladores que representan distritos m\'as competitivos o pol\'iticamente complejos tienden a mostrar menores niveles de ambici\'on progresiva y mayor orientaci\'on hacia la reelecci\'on. En contraste, aquellos en distritos m\'as seguros presentan una mayor disposici\'on a buscar cargos superiores. Asimismo, las caracter\'isticas de la circunscripci\'on influyen en el comportamiento representativo, reforzando estrategias m\'as orientadas al electorado en contextos competitivos. El art\'iculo concluye que la ambici\'on pol\'itica no puede entenderse al margen del contexto electoral en el que operan los legisladores. Las condiciones de la circunscripci\'on estructuran tanto las decisiones de carrera como las estrategias de representaci\'on, lo que subraya la importancia de integrar factores contextuales en el an\'alisis de la ambici\'on pol\'itica.},
  keywords = {00Ambicion Politica: bloqueada,00Ambicion Politica: causas,00Ambicion Politica: causas\ efectos sistema partidos,00Ambicion Politica: expresada,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: America,042Estado: Federal,04Pais_sigla: USA,04Pais: EEUU,0Cargo electo: si,0Cargo: Legislador Estatal,0Division funcional: legislativo,0Division territorial: subnacional,0Forma Gobierno: presidencial,0Organizacion legislativo: bicameral,0Organizacion territorial: federal,1Base de datos: ampliada a partir de otra,1Concepto evaluado: impacto del sistema de partidos politicos y de la estructura de oportunidades politicas en la ambicion politica de los legisladores estatales,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en y entre unidades,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: unidades e individuos,1Longitudinal: cohorte,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: base de datos,1Tipo de experimento: no aplica,1Unidad de analisis: individuo-cohorte,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: legisladores estatales,2Poblacion: legisladores estatales,Base documental: SI,Cargo: Legislador estatal,Compara ambicion expresada versus realizada,Periodo: 1957-1970,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {0 citations (Crossref) [2024-05-14]},
