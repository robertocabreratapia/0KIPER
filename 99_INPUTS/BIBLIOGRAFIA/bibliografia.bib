}

@article{Allen.etal_2020,
  type = {Article},
  title = {What Is a Career Politician? {{Theories}}, Concepts, and Measures},
  author = {Allen, Nicholas and Magni, Gabriele and Searing, Donald and Warncke, Philip},
  year = 2020,
  month = may,
  journal = {European Political Science Review},
  volume = {12},
  number = {2},
  pages = {199--217},
  publisher = {Cambridge University Press},
  issn = {17557747},
  doi = {10.1017/S1755773920000077},
  abstract = {This paper examines the concept career politician. It seeks to clarify, systematize, and measure this ambiguous multidimensional concept in order to facilitate testing theories and hypotheses associated with it. We argue that career politicians are full-time politicians who lack significant experience in the wider world and have other distinguishing attributes for which they are both appreciated and criticized. From claims and critiques put forward by political scientists, journalists, publics, and politicians, we extract four principal dimensions: Strong Commitment, Narrow Occupational Background, Narrow Life Experience, and Strong Ambition. These dimensions and their indicators fit Wittgenstein's family-resemblance conceptual structure, which is how we analyze, measure and validate them with data from a longitudinal study of British MPs spanning 1971-2016.},
  keywords = {00Ambicion como variable: independiente,00Ambicion Politica: efectos,00Ambicion Politica: incumbentes,01Diseno investigacion: no experimental,01Tipo de investigacion politica: orientada a la teoria,02Orientada a la teoria: no experimental,03/06: ok,03Continente: Europa,04Pais_sigla: UKI,04Pais: UK,0Cargo electo: si,0Cargo: Legislador nacional,0Division funcional: legislativo,0Division territorial: nacional,0Forma Gobierno: parlamentario,0Organizacion legislativo: bicameral,0Organizacion territorial: unitario,1Concepto evaluado: politico de carrera reconocido por: fuerte compromiso carencia de experiencia de vida y relevante fuera de la politica y fuerte ambicion politica.,1Diseno experimental: no aplica,1Empirico: no experimental,1Gerring variacion espacial: si en la unidad,1Gerring variacion temporal: si,1Gerring2 variacion unidad/individuo: entre individuos,1Longitudinal: cohorte,1Metodologia: no experimental,1No experimental: diacronico/longitudinal,1NoExperimental_Tecnicas: entrevista,1Tipo de experimento: no aplica,1Unidad de analisis: individuo,2022-Scopus,2022-WoS,2024-Scopus,2024-WoS,2Muestra: miembro de la Camara Baja de UK en periodo 1971-1974 reentrevistados en 2012-2016,AMB_TIPO_VARIABLE: nominal ordinal,Base documental: SI,Camara Baja,career politician,careerist,carrera politica,family-resemblance concepts,political ambition,political class,professional politician,Teoria de la Ambicion Politica,TEST-BORRAR,ZBaseIntegrada: si,ZFiltro1: incluido,ZFiltro2: incluido (incumbentes electos),ZFiltro3: incluido (Base Documental)},
  annotation = {22 citations (Crossref) [2024-05-14]},
  file = {/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/T9QF6VCI/Allen et al. - 2020 - What is a career politician Theories, concepts, a.pdf;/run/user/1000/doc/1bd3da54/Zotero-NoTocar/storage/VMK5293X/Allen et al_2020_What is a career politician.pdf}
